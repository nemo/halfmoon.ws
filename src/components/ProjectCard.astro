---
import Box from './Box.astro';

export interface Props {
  name: string;
  role: string;
  summary: string;
  brandColor: string;
  link?: string;
  href?: string;
  heroImage?: string;
}

const { name, role, summary, brandColor, link, href, heroImage } = Astro.props;
const detailHref = href ?? link ?? '#';
---

<Box class="pcard">
  <header class="pcard__head">
    <h3 class="pcard__title">{name}</h3>
    <p class="pcard__sub">{role}</p>
  </header>

  <div class="pcard__sub-container">
    <a
      class="pcard__media"
      href={detailHref}
      style={`--brand: ${brandColor};`}
      aria-label={name}
    >
      {
        heroImage ? (
          <img src={heroImage} alt="" loading="lazy" decoding="async" />
        ) : null
      }
    </a>

    <div class="pcard__content">
      <p class="pcard__body">{summary}</p>
      {
        (href || link) && (
          <a class="pcard__link" href={detailHref}>
            Learn more
          </a>
        )
      }
    </div>
  </div>
</Box>

<style>
  .pcard {
    display: flex;
    flex-direction: column;
  }

  /* Headline block: TITLE + SUB-TITLE, pb 15px. */
  .pcard__head {
    padding-bottom: 15px;
  }

  .pcard__title {
    font-family: var(--font-display);
    font-size: var(--fs-title);
    font-weight: var(--fw-regular);
    text-transform: uppercase;
    color: var(--box-fg);
  }

  .pcard__sub {
    font-family: var(--font-display);
    font-size: var(--fs-sub);
    font-weight: var(--fw-regular);
    color: var(--box-muted);
  }

  /* Sub-Container: image block + content column, side-by-side. */
  .pcard__sub-container {
    display: flex;
    align-items: flex-start;
    max-width: var(--subcontainer-max);
  }

  .pcard__media {
    display: block;
    flex: 0 0 auto;
    width: 315px;
    max-width: 100%;
    aspect-ratio: 315 / 180;
    border-radius: var(--radius);
    background-color: var(--brand);
    overflow: hidden;
  }

  .pcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pcard__content {
    flex: 1 0 0;
    min-width: 0;
    padding-left: var(--box-pad);
  }

  .pcard__body {
    font-family: var(--font-display);
    font-size: var(--fs-list);
    font-weight: var(--fw-regular);
    line-height: var(--lh-tight);
    color: var(--box-fg);
    padding-bottom: var(--box-pad);
  }

  .pcard__link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--fs-list);
    font-weight: var(--fw-regular);
    color: var(--accent);
    transition: opacity 0.15s ease;
  }

  .pcard__link:hover {
    opacity: 0.75;
  }

  /* Mobile: image block on top, content below (image full width of box). */
  @media (max-width: 480px) {
    .pcard__sub-container {
      flex-direction: column;
      align-items: stretch;
    }

    .pcard__media {
      width: 100%;
    }

    .pcard__content {
      padding-left: 0;
      padding-top: var(--box-pad);
    }
  }
</style>

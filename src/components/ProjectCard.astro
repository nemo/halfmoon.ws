---
import Box from './Box.astro';

export interface Props {
  name: string;
  role: string;
  summary: string;
  brandColor: string;
  link?: string;
  href?: string;
  heroImage?: string;
  imageFit?: 'cover' | 'contain';
}

const { name, role, summary, brandColor, link, href, heroImage, imageFit = 'cover' } = Astro.props;
const detailHref = href ?? link ?? '#';
---

<Box class="pcard" style={`--brand: ${brandColor};`}>
  <header class="pcard__head">
    <h3 class="pcard__title">{name}</h3>
    <p class="pcard__sub">{role}</p>
  </header>

  <div class="pcard__sub-container">
    <a
      class:list={['pcard__media', imageFit === 'contain' && 'is-contain']}
      href={detailHref}
      style={`--brand: ${brandColor};`}
      aria-label={name}
    >
      {
        heroImage ? (
          <img src={heroImage} alt="" loading="lazy" decoding="async" />
        ) : null
      }
    </a>

    <div class="pcard__content">
      <p class="pcard__body">{summary}</p>
      {
        (href || link) && (
          <a class="pcard__link" href={detailHref}>
            Learn more
          </a>
        )
      }
    </div>
  </div>
</Box>

<style>
  .pcard {
    display: flex;
    flex-direction: column;
    /* The card takes on the project's core color; text flips to white. */
    background-color: var(--brand);
    --box-fg: #ffffff;
    --box-muted: rgba(255, 255, 255, 0.72);
    color: #ffffff;
    transition:
      background-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  /* Thoughtful hover: the background deepens into a richer shade of the
     project's own color, with a subtle lift. */
  .pcard:hover {
    background-color: color-mix(in srgb, var(--brand) 82%, #000 18%);
    transform: translateY(-3px);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
  }

  @media (prefers-reduced-motion: reduce) {
    .pcard {
      transition: background-color 0.3s ease;
    }
    .pcard:hover {
      transform: none;
    }
  }

  /* Headline block: TITLE + SUB-TITLE, pb 15px. */
  .pcard__head {
    padding-bottom: 15px;
  }

  .pcard__title {
    font-family: var(--font-display);
    font-size: var(--fs-title);
    font-weight: var(--fw-regular);
    text-transform: uppercase;
    color: var(--box-fg);
  }

  .pcard__sub {
    font-family: var(--font-display);
    font-size: var(--fs-sub);
    font-weight: var(--fw-regular);
    color: var(--box-muted);
  }

  /* Sub-Container: image block + content column, side-by-side. */
  .pcard__sub-container {
    display: flex;
    align-items: flex-start;
    max-width: var(--subcontainer-max);
  }

  /* A small thumbnail mark, same rounded corners as every other box. */
  .pcard__media {
    display: block;
    box-sizing: border-box;
    flex: 0 0 auto;
    width: 88px;
    max-width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius);
    background-color: rgba(0, 0, 0, 0.12);
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .pcard:hover .pcard__media {
    transform: scale(1.04);
  }

  .pcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Logo-style images: full logo centered on a white plate, not cropped. */
  .pcard__media.is-contain {
    background-color: #ffffff;
    padding: 10px;
  }

  .pcard__media.is-contain img {
    object-fit: contain;
  }

  .pcard__content {
    flex: 1 0 0;
    min-width: 0;
    padding-left: var(--box-pad);
  }

  .pcard__body {
    font-family: var(--font-display);
    font-size: var(--fs-list);
    font-weight: var(--fw-regular);
    line-height: var(--lh-tight);
    color: var(--box-fg);
    padding-bottom: var(--box-pad);
  }

  .pcard__link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--fs-list);
    font-weight: var(--fw-regular);
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }

  .pcard__link:hover {
    opacity: 1;
  }

  /* Mobile: image block on top, content below (image full width of box). */
  @media (max-width: 480px) {
    .pcard__sub-container {
      flex-direction: column;
      align-items: stretch;
    }

    .pcard__media {
      width: 100%;
    }

    .pcard__content {
      padding-left: 0;
      padding-top: var(--box-pad);
    }
  }
</style>

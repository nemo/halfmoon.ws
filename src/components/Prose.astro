---
// Styles the long-form MDX article body. Used inside dark boxes, so colors
// are box-relative. Long-form body is Inter 16px / line-height 1.3.
export interface Props {
  /** Optional accent color for links (defaults to the brick-red accent). */
  accent?: string;
}
const { accent } = Astro.props;
---

<div class="prose" style={accent ? `--prose-accent: ${accent};` : undefined}>
  <slot />
</div>

<style>
  .prose {
    --prose-accent: var(--accent);
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-tight);
    color: var(--box-fg);
  }

  .prose > :global(* + *) {
    margin-top: 1em;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--fs-title);
    font-weight: var(--fw-regular);
    text-transform: uppercase;
    line-height: var(--lh-tight);
    margin-top: 1.5em;
  }

  .prose :global(h3),
  .prose :global(h4) {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: var(--fw-regular);
    line-height: var(--lh-tight);
    margin-top: 1.25em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.25em;
  }

  .prose :global(li + li) {
    margin-top: 0.35em;
  }

  .prose :global(a) {
    color: var(--prose-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--box-muted);
    padding-left: var(--box-pad);
    color: var(--box-muted);
    font-style: italic;
  }

  .prose :global(img),
  .prose :global(video) {
    width: 100%;
    border-radius: var(--radius);
    margin-block: 1em;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid rgba(249, 250, 251, 0.16);
    margin-block: 1.5em;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: rgba(249, 250, 251, 0.1);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    font-family: var(--font-mono);
    background: rgba(0, 0, 0, 0.35);
    color: var(--box-fg);
    padding: var(--box-pad);
    border-radius: var(--radius);
    overflow-x: auto;
    font-size: var(--fs-list);
    line-height: var(--lh-tight);
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(figure) {
    margin: 0;
  }

  .prose :global(figcaption) {
    font-size: var(--fs-list);
    color: var(--box-muted);
    margin-top: var(--box-pad);
  }
</style>

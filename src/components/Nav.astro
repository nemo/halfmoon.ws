---
import TileRow from './TileRow.astro';
import Box from './Box.astro';
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/about', label: 'Find Me' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/principles', label: 'Principles' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<TileRow class="nav" as="nav" aria-label="Primary" stackAt="mobile">
  <Box variant="light" class="nav__wordmark" as="a" href="/">NIMA GARDIDEH</Box>

  {
    links.map((link) => (
      <Box
        as="a"
        href={link.href}
        class="nav__link"
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        {link.label}
      </Box>
    ))
  }

  <Box class="nav__toggle">
    <ThemeToggle />
  </Box>
</TileRow>

<style>
  /* Compact nav row — boxes ~30px tall, centered single line of text. */
  .nav :global(.box) {
    display: flex;
    align-items: center;
    min-height: 30px;
    padding-block: 0;
  }

  .nav__wordmark {
    font-family: var(--font-display);
    font-size: var(--fs-wordmark);
    font-weight: var(--fw-regular);
    text-transform: uppercase;
    white-space: nowrap;
    /* wordmark hugs its text rather than spreading like the link tiles. */
    flex: 0 0 auto !important;
  }

  .nav__link {
    font-family: var(--font-display);
    font-size: var(--fs-nav);
    font-weight: var(--fw-regular);
    text-transform: uppercase;
    color: var(--box-fg);
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .nav__link:hover {
    color: var(--accent);
  }

  .nav__link[aria-current='page'] {
    color: var(--accent);
  }

  .nav__toggle {
    flex: 0 0 auto !important;
    justify-content: center;
  }

  /* Mobile: wordmark spans its own row; the link tiles + toggle wrap as
     compact chips (hugging their text) rather than stacking full-width. */
  @media (max-width: 480px) {
    .nav__wordmark {
      flex: 1 1 100% !important;
    }

    .nav :global(.nav__link),
    .nav__toggle {
      flex: 1 1 auto !important;
    }
  }
</style>

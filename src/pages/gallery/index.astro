---
import GalleryShell from '../../layouts/GalleryShell.astro';
import data from '../../data/gallery-concepts.json';

const concepts = data.concepts ?? [];
---

<GalleryShell title="Halfmoon — 5 original concepts">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <main class="wrap">
    <header class="masthead">
      <p class="eyebrow">halfmoon.ws · five originals</p>
      <h1>Five ways the site could be <em>unforgettable</em>.</h1>
      <p class="lede">
        Not style skins — five interactive concepts, each driven by a real idea
        about you (Sound Hallucinations, "free will is limited", "Home is Planet
        Earth", the four-self, the engineer-poet). They come alive on click and
        cursor, so open each one full-screen. Then tell me which to build out.
      </p>
      <p class="back"><a href="/">← back to the current site</a></p>
    </header>

    <ul class="grid">
      {
        concepts.map((c, i) => (
          <li class="card">
            <a class="card__link" href={`/gallery/${c.slug}`}>
              <span class="card__shot">
                <img
                  src={`/gallery-thumbs/${c.slug}.png`}
                  alt={`${c.name} concept preview`}
                  loading="lazy"
                  decoding="async"
                />
                <span class="card__no">{String(i + 1).padStart(2, '0')}</span>
              </span>
              <span class="card__meta">
                <span class="card__name">{c.name}</span>
                <span class="card__tag">{c.tagline}</span>
                <span class="card__summary">{c.summary}</span>
                <span class="card__cta">Open full-screen →</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>

  <style>
    :global(html) { background: #08080a; }
    :global(body) {
      margin: 0;
      font-family: 'Inter', system-ui, sans-serif;
      color: #ececf0;
      -webkit-font-smoothing: antialiased;
    }

    .wrap {
      max-width: 1180px;
      margin: 0 auto;
      padding: clamp(36px, 6vw, 88px) clamp(20px, 4vw, 48px) 100px;
    }
    .masthead { max-width: 760px; margin-bottom: clamp(36px, 5vw, 60px); }
    .eyebrow {
      font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase;
      color: #7d7d88; margin: 0 0 18px;
    }
    .masthead h1 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: clamp(30px, 5vw, 52px); font-weight: 600; line-height: 1.05;
      letter-spacing: -0.01em; margin: 0 0 18px; color: #fff;
    }
    .masthead h1 em { font-style: italic; color: #c9b8ff; }
    .lede { font-size: 16px; line-height: 1.6; color: #b3b3bd; margin: 0 0 18px; }
    .back a {
      color: #9a9aa6; font-size: 14px; text-decoration: none;
      border-bottom: 1px solid #34343c; padding-bottom: 1px;
    }
    .back a:hover { color: #fff; }

    .grid {
      list-style: none; margin: 0; padding: 0; display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 24px;
    }
    .card__link {
      display: flex; flex-direction: column; text-decoration: none; color: inherit;
      background: #121214; border: 1px solid #232329; border-radius: 16px;
      overflow: hidden; height: 100%;
      transition: transform .28s ease, border-color .28s ease, box-shadow .28s ease;
    }
    .card__link:hover {
      transform: translateY(-5px); border-color: #45454f;
      box-shadow: 0 22px 50px rgba(0,0,0,.5);
    }
    .card__shot {
      position: relative; display: block; aspect-ratio: 16 / 10; overflow: hidden;
      background: #08080a; border-bottom: 1px solid #232329;
    }
    .card__shot img {
      width: 100%; height: 100%; object-fit: cover; object-position: center;
      display: block; transition: transform .4s ease;
    }
    .card__link:hover .card__shot img { transform: scale(1.03); }
    .card__no {
      position: absolute; top: 12px; left: 14px; font-size: 12px;
      letter-spacing: 0.1em; color: #fff; mix-blend-mode: difference;
    }
    .card__meta { display: flex; flex-direction: column; gap: 7px; padding: 20px 22px 24px; }
    .card__name { font-family: 'Fraunces', serif; font-size: 22px; font-weight: 600; color: #fff; }
    .card__tag { font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: #8f8f9a; }
    .card__summary { font-size: 14px; line-height: 1.55; color: #abacb5; margin-top: 2px; }
    .card__cta { font-size: 13px; color: #c9b8ff; margin-top: 8px; }

    @media (prefers-reduced-motion: reduce) {
      .card__link, .card__shot img { transition: none; }
    }
  </style>
</GalleryShell>

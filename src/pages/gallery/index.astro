---
import GalleryShell from '../../layouts/GalleryShell.astro';
import data from '../../data/gallery-concepts.json';

const concepts = data.concepts ?? [];
---

<GalleryShell title="Halfmoon — 15 quiet concepts">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <main class="wrap">
    <header class="masthead">
      <p class="eyebrow">halfmoon.ws · fifteen quiet directions</p>
      <h1>Simple, and <em>elegant</em>.</h1>
      <p class="lede">
        Fifteen restrained concepts — each built around a single quiet gesture
        on a spare, paper-calm page. The motion is slow and ambient, so open
        each one full-screen and let it breathe. Then tell me which to build out.
      </p>
      <p class="back"><a href="/">← back to the current site</a></p>
    </header>

    <ul class="grid">
      {
        concepts.map((c, i) => (
          <li class="card">
            <a class="card__link" href={`/gallery/${c.slug}`}>
              <span class="card__shot">
                <img
                  src={`/gallery-thumbs/${c.slug}.png`}
                  alt={`${c.name} concept preview`}
                  loading="lazy"
                  decoding="async"
                />
              </span>
              <span class="card__meta">
                <span class="card__no">{String(i + 1).padStart(2, '0')}</span>
                <span class="card__name">{c.name}</span>
                <span class="card__tag">{c.tagline}</span>
                <span class="card__summary">{c.summary}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>

  <style>
    :global(html) { background: #f3efe8; }
    :global(body) {
      margin: 0;
      font-family: 'Inter', system-ui, sans-serif;
      color: #2a2622;
      -webkit-font-smoothing: antialiased;
    }

    .wrap {
      max-width: 1180px;
      margin: 0 auto;
      padding: clamp(40px, 7vw, 100px) clamp(22px, 4vw, 52px) 110px;
    }
    .masthead { max-width: 660px; margin-bottom: clamp(40px, 6vw, 72px); }
    .eyebrow {
      font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase;
      color: #9a9084; margin: 0 0 20px;
    }
    .masthead h1 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(38px, 6vw, 64px); font-weight: 500; line-height: 1.04;
      letter-spacing: 0.005em; margin: 0 0 20px; color: #221f1b;
    }
    .masthead h1 em { font-style: italic; font-weight: 400; }
    .lede {
      font-size: 16px; line-height: 1.65; color: #6b635a; margin: 0 0 22px;
      max-width: 56ch;
    }
    .back a {
      color: #8a8175; font-size: 14px; text-decoration: none;
      border-bottom: 1px solid #d8d0c4; padding-bottom: 1px;
    }
    .back a:hover { color: #221f1b; }

    .grid {
      list-style: none; margin: 0; padding: 0; display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 28px 24px;
    }
    .card__link {
      display: flex; flex-direction: column; text-decoration: none; color: inherit;
      transition: transform .3s ease;
    }
    .card__link:hover { transform: translateY(-3px); }
    .card__shot {
      display: block; aspect-ratio: 16 / 10; overflow: hidden;
      background: #fff; border: 1px solid #e3dccf;
      border-radius: 4px;
    }
    .card__shot img {
      width: 100%; height: 100%; object-fit: cover; object-position: center;
      display: block; transition: transform .5s ease;
    }
    .card__link:hover .card__shot img { transform: scale(1.025); }
    .card__meta { display: flex; flex-direction: column; gap: 5px; padding: 16px 2px 0; }
    .card__no { font-size: 11px; letter-spacing: 0.12em; color: #b3a99a; }
    .card__name {
      font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 500;
      color: #221f1b; line-height: 1.1;
    }
    .card__tag { font-size: 12.5px; font-style: italic; color: #8a8175; }
    .card__summary { font-size: 13.5px; line-height: 1.5; color: #6b635a; margin-top: 4px; }

    @media (prefers-reduced-motion: reduce) {
      .card__link, .card__shot img { transition: none; }
    }
  </style>
</GalleryShell>

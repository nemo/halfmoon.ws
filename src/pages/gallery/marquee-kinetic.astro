    @media (max-width: 480px) {
      .nav__mark {
        font-size: 18px;
      }
      .proj:hover .proj__name {
        transform: none;
      }
      .proj:hover .proj__media {
        transform: none;
      }
    }

    /* ---------- REDUCED MOTION ---------- */
    @media (prefers-reduced-motion: reduce) {
      :global(html) {
        scroll-behavior: auto;
      }
      .topbar__track,
      .band__track,
      .proj__tickerTrack,
      .hero__railTrack {
        transform: none !important;
        animation: none !important;
      }
      .hero__asterisk,
      .hero__scrollArrow {
        animation: none !important;
      }
      .hero__head .reveal,
      .hero__kick {
        opacity: 1 !important;
        transform: none !important;
        animation: none !important;
      }
      .dot {
        animation: none !important;
      }
    }

  <script>
    // Kinetic marquee engine: each [data-marquee] loops infinitely via
    // requestAnimationFrame, and its speed + direction respond to scroll
    // velocity — restless when you scroll, calm when you stop.
    type Track = {
      el: HTMLElement;
      base: number; // px/sec baseline
      dir: number; // 1 or -1
      axis: 'x' | 'y';
      half: number; // half the content extent (one duplicated set)
      offset: number;
    };

    const prefersReduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    function init() {
      if (prefersReduced) return;
      const nodes = Array.from(
        document.querySelectorAll<HTMLElement>('[data-marquee]')
      );

      const extent = (el: HTMLElement, axis: 'x' | 'y') =>
        axis === 'y' ? el.scrollHeight : el.scrollWidth;

      const tracks: Track[] = nodes.map((el) => {
        const axis: 'x' | 'y' = el.dataset.axis === 'y' ? 'y' : 'x';
        // Duplicate children so the loop is seamless.
        el.innerHTML = el.innerHTML + el.innerHTML;
        return {
          el,
          base: parseFloat(el.dataset.speed || '24'),
          dir: parseFloat(el.dataset.dir || '1'),
          axis,
          half: extent(el, axis) / 2,
          offset: Math.random() * 60,
        };
      });

      const recalc = () =>
        tracks.forEach((t) => (t.half = extent(t.el, t.axis) / 2));
      window.addEventListener('resize', recalc);

      // scroll velocity -> boost
      let lastY = window.scrollY;
      let velocity = 0;
      let scrollDir = 1;
      window.addEventListener(
        'scroll',
        () => {
          const y = window.scrollY;
          const dy = y - lastY;
          if (dy !== 0) scrollDir = dy > 0 ? 1 : -1;
          velocity = Math.min(Math.abs(dy) * 8, 900);
          lastY = y;
        },
        { passive: true }
      );

      let last = performance.now();
      function frame(now: number) {
        const dt = Math.min((now - last) / 1000, 0.05);
        last = now;
        velocity *= 0.9; // decay back to calm

        for (const t of tracks) {
          // Scroll velocity adds speed; scroll direction can flip the ribbon.
          const speed = (t.base + velocity) * t.dir * scrollDir;
          t.offset += speed * dt;
          if (t.half > 0) {
            // wrap within [0, half) so motion is seamless either direction
            t.offset = ((t.offset % t.half) + t.half) % t.half;
          }
          t.el.style.transform =
            t.axis === 'y'
              ? `translate3d(0,${-t.offset}px,0)`
              : `translate3d(${-t.offset}px,0,0)`;
        }
        requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    // Fonts can change width; recalc once they load.
    if ((document as any).fonts?.ready) {
      (document as any).fonts.ready.then(() => {
        window.dispatchEvent(new Event('resize'));
      });
    }
  </script>

---
import GalleryShell from '../../layouts/GalleryShell.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Pearmill has no heroImage in frontmatter — fall back to its known asset.
const imageFor = (p: (typeof projects)[number]) =>
  p.data.heroImage ??
  (p.slug === 'pearmill' ? '/media/pearmill/pearmill.png' : null);

const nav = [
  { label: 'Find Me', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Principles', href: '/principles' },
];

// rotating accent swatch + skew so the asymmetric grid reads as a zine
const accents = ['#FFE600', '#FF4DD8', '#B6FF1A', '#FF3B30'];
---

<GalleryShell title="Nima Gardideh" trend="Neo-Brutalism">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Public+Sans:wght@400;600;800&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <a class="skip" href="#main">SKIP TO CONTENT</a>

  <!-- scrolling marquee strip -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {Array.from({ length: 2 }).map(() => (
        <span class="marquee__group">
          <span>FOUNDER</span><span class="dot">●</span>
          <span>ARTIST</span><span class="dot">●</span>
          <span>ENGINEER</span><span class="dot">●</span>
          <span>MUSICIAN</span><span class="dot">●</span>
          <span>POET</span><span class="dot">●</span>
          <span>BROOKLYN</span><span class="dot">●</span>
        </span>
      ))}
    </div>
  </div>

  <!-- chunky bordered nav -->
  <header class="topbar">
    <a class="wordmark" href="/">
      <span class="wordmark__tick" aria-hidden="true">★</span>
      NIMA&nbsp;GARDIDEH
    </a>
    <nav class="nav" aria-label="Primary">
      {nav.map((n) => (
        <a class="nav__link" href={n.href}>{n.label.toUpperCase()}</a>
      ))}
    </nav>
    <a class="social" href="https://x.com/ngardideh" target="_blank" rel="noopener">
      @NGARDIDEH ↗
    </a>
  </header>

  <main id="main">
    <!-- HERO -->
    <section class="hero">
      <div class="hero__tags" aria-hidden="true">
        <span class="tag tag--pink">BROOKLYN</span>
        <span class="tag tag--yellow">EST. NOW</span>
        <span class="tag tag--lime">NO FILLER</span>
      </div>
      <h1 class="hero__head">
        <span class="word">A&nbsp;FOUNDER,</span>
        <span class="word word--pink">ARTIST,</span>
        <span class="word">ENGINEER,</span>
        <span class="word word--out">&amp;&nbsp;MUSICIAN</span>
        <span class="word word--small">BASED&nbsp;IN&nbsp;BROOKLYN.</span>
      </h1>

      <div class="hero__side">
        <div class="hero__stats" aria-hidden="true">
          <div class="stat stat--pink"><b>15+</b><span>YEARS BUILDING</span></div>
          <div class="stat stat--lime"><b>3X</b><span>FOUNDER</span></div>
        </div>
        <div class="hero__about card card--shadow">
          <div class="card__label">// ABOUT</div>
          <p>
            I spend most of my time at <mark>Pearmill</mark>, where we help companies
            grow through art and technology — the only place I've felt like an
            artist, entrepreneur, and engineer at once. Beyond that I write poetry,
            blog, and dance.
          </p>
          <a class="btn" href="/about">FIND ME →</a>
        </div>
      </div>

      <div class="hero__stamp" aria-hidden="true">
        <div class="stamp">
          <span>SELECTED</span><span>WORK</span><span>↓↓↓</span>
        </div>
      </div>
    </section>

    <hr class="rule" />

    <!-- SECTION HEADER -->
    <div class="sec-head">
      <h2 class="sec-head__title">PROJECTS</h2>
      <span class="sec-head__count">[{String(projects.length).padStart(2, '0')}]</span>
      <span class="sec-head__meta">SCROLL · BUILT · SHIPPED</span>
    </div>

    <!-- PROJECTS GRID -->
    <section class="grid">
      {projects.map((p, i) => {
        const img = imageFor(p);
        const accent = accents[i % accents.length];
        return (
          <article
            class={`pcard pcard--${i % 4}`}
            style={`--brand:${p.data.brandColor}; --accent:${accent};`}
          >
            <div class="pcard__media" style={`background:${p.data.brandColor}`}>
              {img ? (
                <img
                  src={img}
                  alt={p.data.name}
                  loading="lazy"
                  decoding="async"
                  style={`object-fit:${p.data.imageFit ?? 'cover'}`}
                />
              ) : (
                <div class="pcard__block">{p.data.name}</div>
              )}
              <span class="pcard__no">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <div class="pcard__body">
              <h3 class="pcard__name">{p.data.name.toUpperCase()}</h3>
              <div class="pcard__meta">
                <span class="chip">{p.data.role.toUpperCase()}</span>
                <span class="chip chip--ghost">{p.data.period}</span>
              </div>
              <p class="pcard__summary">{p.data.summary}</p>
              {p.data.link && (
                <a class="btn btn--sm" href={p.data.link} target="_blank" rel="noopener">
                  VISIT ↗
                </a>
              )}
            </div>
          </article>
        );
      })}
    </section>

    <hr class="rule" />

    <!-- FOOTER -->
    <footer class="footer">
      <div class="footer__big">LET'S&nbsp;MAKE<br />SOMETHING&nbsp;LOUD.</div>
      <div class="footer__cols">
        <div class="footer__col">
          <span class="footer__k">FIND ME</span>
          <a href="https://x.com/ngardideh" target="_blank" rel="noopener">@NGARDIDEH ↗</a>
        </div>
        <div class="footer__col">
          <span class="footer__k">PAGES</span>
          {nav.map((n) => <a href={n.href}>{n.label.toUpperCase()}</a>)}
        </div>
        <div class="footer__col">
          <span class="footer__k">© 2026</span>
          <span class="footer__note">NIMA GARDIDEH — BROOKLYN, NY. RAW &amp; UNPOLISHED ON PURPOSE.</span>
        </div>
      </div>
    </footer>
  </main>

  <style is:global>
    *,
    *::before,
    *::after { box-sizing: border-box; }

    :root {
      --ink: #000000;
      --paper: #ffffff;
      --pink: #ff4dd8;
      --yellow: #ffe600;
      --red: #ff3b30;
      --lime: #b6ff1a;
      --bd: 3px solid var(--ink);
      --bd-fat: 4px solid var(--ink);
      --sh: 6px 6px 0 var(--ink);
      --sh-lg: 10px 10px 0 var(--ink);
      --display: 'Archivo Black', 'Public Sans', system-ui, sans-serif;
      --body: 'Public Sans', system-ui, sans-serif;
      --mono: 'Space Mono', ui-monospace, monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: var(--body);
      font-weight: 600;
      line-height: 1.45;
      /* subtle zine grid texture */
      background-image:
        linear-gradient(var(--paper) 0 0),
        repeating-linear-gradient(0deg, #0000 0 38px, #00000010 38px 39px),
        repeating-linear-gradient(90deg, #0000 0 38px, #00000010 38px 39px);
      background-blend-mode: normal;
      -webkit-font-smoothing: antialiased;
    }

    a { color: inherit; text-decoration: none; }
    mark { background: var(--yellow); padding: 0 .15em; box-decoration-break: clone; }

    .skip {
      position: absolute; left: -999px; top: 0;
      background: var(--ink); color: var(--paper);
      padding: 10px 14px; font-family: var(--mono); z-index: 50;
    }
    .skip:focus { left: 8px; top: 8px; }

    /* ---------- TOPBAR ---------- */
    .topbar {
      position: sticky; top: 0; z-index: 30;
      display: flex; align-items: stretch; flex-wrap: wrap;
      gap: 0;
      background: var(--paper);
      border-bottom: var(--bd-fat);
    }
    .wordmark {
      font-family: var(--display);
      font-size: clamp(16px, 2vw, 22px);
      letter-spacing: -.02em;
      display: flex; align-items: center; gap: 10px;
      padding: 16px 20px;
      border-right: var(--bd-fat);
      white-space: nowrap;
    }
    .wordmark__tick {
      display: inline-grid; place-items: center;
      width: 26px; height: 26px;
      background: var(--pink); color: var(--ink);
      border: var(--bd); border-radius: 50%;
      font-size: 13px; transform: rotate(-8deg);
    }
    .nav {
      display: flex; flex: 1; align-items: stretch; flex-wrap: wrap;
    }
    .nav__link {
      font-family: var(--mono); font-weight: 700; font-size: 13px;
      letter-spacing: .04em;
      display: flex; align-items: center;
      padding: 0 18px;
      border-right: var(--bd);
      transition: none;
    }
    .nav__link:hover { background: var(--yellow); }
    .nav__link:nth-child(2):hover { background: var(--lime); }
    .nav__link:nth-child(3):hover { background: var(--pink); }
    .nav__link:nth-child(4):hover { background: var(--red); color: var(--paper); }
    .social {
      font-family: var(--mono); font-weight: 700; font-size: 13px;
      display: flex; align-items: center; padding: 0 20px;
      background: var(--ink); color: var(--paper);
    }
    .social:hover { background: var(--pink); color: var(--ink); }

    /* ---------- MARQUEE ---------- */
    .marquee {
      overflow: hidden;
      background: var(--ink);
      border-bottom: var(--bd-fat);
      padding: 8px 0;
    }
    .marquee__track {
      display: flex; width: max-content;
      animation: scroll 22s linear infinite;
    }
    .marquee__group {
      display: flex; align-items: center; gap: 22px; padding-right: 22px;
      font-family: var(--display); color: var(--yellow);
      font-size: 16px; letter-spacing: .02em; white-space: nowrap;
    }
    .marquee__group .dot { color: var(--pink); font-size: 10px; }
    @keyframes scroll { to { transform: translateX(-50%); } }

    /* ---------- HERO ---------- */
    .hero {
      position: relative;
      padding: clamp(28px, 5vw, 64px) clamp(18px, 5vw, 56px) clamp(40px, 6vw, 72px);
      display: grid;
      grid-template-columns: 1.55fr 1fr;
      grid-template-areas: 'tags tags' 'head about';
      gap: clamp(20px, 3vw, 40px) clamp(24px, 4vw, 56px);
      align-items: end;
    }
    .hero__tags { grid-area: tags; display: flex; gap: 12px; flex-wrap: wrap; }
    .tag {
      font-family: var(--mono); font-weight: 700; font-size: 12px;
      letter-spacing: .05em;
      padding: 6px 12px; border: var(--bd);
      box-shadow: 3px 3px 0 var(--ink);
    }
    .tag--pink { background: var(--pink); transform: rotate(-2deg); }
    .tag--yellow { background: var(--yellow); transform: rotate(1.5deg); }
    .tag--lime { background: var(--lime); transform: rotate(-1deg); }

    .hero__head {
      grid-area: head;
      margin: 0;
      font-family: var(--display);
      line-height: .92;
      letter-spacing: -.03em;
      text-transform: uppercase;
      display: flex; flex-direction: column;
    }
    .word {
      font-size: clamp(38px, 8vw, 104px);
      display: inline-block;
      opacity: 0; transform: translateY(18px);
      animation: rise .6s cubic-bezier(.2,.9,.2,1) forwards;
    }
    .word:nth-child(1) { animation-delay: .05s; }
    .word:nth-child(2) { animation-delay: .12s; }
    .word:nth-child(3) { animation-delay: .19s; }
    .word:nth-child(4) { animation-delay: .26s; }
    .word:nth-child(5) { animation-delay: .33s; }
    .word--pink { color: var(--pink); }
    .word--out {
      color: var(--paper);
      -webkit-text-stroke: 3px var(--ink);
      text-stroke: 3px var(--ink);
      text-shadow: 4px 4px 0 var(--ink);
      paint-order: stroke fill;
    }
    .word--small {
      font-family: var(--body);
      font-weight: 800;
      font-size: clamp(15px, 2.2vw, 26px);
      letter-spacing: -.01em;
      margin-top: 14px;
      max-width: 16ch;
    }

    /* cards */
    .card {
      border: var(--bd-fat);
      background: var(--paper);
      padding: 22px;
    }
    .card--shadow { box-shadow: var(--sh-lg); }
    .card__label {
      font-family: var(--mono); font-weight: 700; font-size: 12px;
      letter-spacing: .08em; margin-bottom: 10px;
      display: inline-block; background: var(--ink); color: var(--paper);
      padding: 3px 8px;
    }
    .hero__side {
      grid-area: about;
      align-self: end;
      display: flex; flex-direction: column; gap: clamp(16px, 2vw, 22px);
    }
    .hero__stats {
      display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
      opacity: 0; transform: translateY(18px);
      animation: rise .6s cubic-bezier(.2,.9,.2,1) .38s forwards;
    }
    .stat {
      border: var(--bd-fat); box-shadow: var(--sh);
      padding: 12px 14px; display: flex; flex-direction: column; gap: 2px;
    }
    .stat b {
      font-family: var(--display); font-size: clamp(28px, 4vw, 40px);
      line-height: .9; letter-spacing: -.03em;
    }
    .stat span { font-family: var(--mono); font-weight: 700; font-size: 10px; letter-spacing: .08em; }
    .stat--pink { background: var(--pink); transform: rotate(-1.5deg); }
    .stat--lime { background: var(--lime); transform: rotate(1.5deg); }
    .hero__about {
      opacity: 0; transform: translateY(18px);
      animation: rise .6s cubic-bezier(.2,.9,.2,1) .42s forwards;
    }
    .hero__about p { margin: 0 0 18px; font-size: 16px; }

    .hero__stamp {
      position: absolute;
      right: clamp(18px, 5vw, 56px);
      top: clamp(20px, 4vw, 40px);
      pointer-events: none;
    }
    .stamp {
      display: grid; place-items: center;
      width: 96px; height: 96px; border-radius: 50%;
      border: var(--bd-fat); background: var(--lime);
      font-family: var(--mono); font-weight: 700; font-size: 11px;
      letter-spacing: .06em; text-align: center;
      box-shadow: var(--sh);
      transform: rotate(12deg);
      animation: spinwobble 6s ease-in-out infinite;
    }
    .stamp span { display: block; line-height: 1.2; }

    /* buttons w/ press motion */
    .btn {
      display: inline-block;
      font-family: var(--display);
      font-size: 15px; letter-spacing: -.01em;
      padding: 12px 20px;
      background: var(--yellow); color: var(--ink);
      border: var(--bd-fat);
      box-shadow: var(--sh);
      transition: transform .08s linear, box-shadow .08s linear, background .08s linear;
    }
    .btn:hover { background: var(--pink); }
    .btn:active,
    .btn:focus-visible {
      transform: translate(6px, 6px);
      box-shadow: 0 0 0 var(--ink);
    }
    .btn--sm { font-size: 12px; padding: 8px 14px; box-shadow: 4px 4px 0 var(--ink); background: var(--paper); }
    .btn--sm:hover { background: var(--accent); }

    /* ---------- RULES + SECTION HEAD ---------- */
    .rule {
      border: none;
      height: 8px;
      margin: 0;
      background:
        repeating-linear-gradient(45deg, var(--ink) 0 14px, transparent 14px 28px);
      border-top: var(--bd-fat);
      border-bottom: var(--bd-fat);
    }
    .sec-head {
      display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;
      padding: clamp(20px, 3vw, 34px) clamp(18px, 5vw, 56px) 6px;
    }
    .sec-head__title {
      font-family: var(--display);
      font-size: clamp(34px, 6vw, 72px);
      margin: 0; letter-spacing: -.03em;
    }
    .sec-head__count { font-family: var(--mono); font-weight: 700; font-size: 20px; color: var(--pink); }
    .sec-head__meta {
      margin-left: auto;
      font-family: var(--mono); font-size: 12px; letter-spacing: .1em;
      background: var(--ink); color: var(--paper); padding: 5px 10px;
    }

    /* ---------- PROJECT GRID ---------- */
    .grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: clamp(18px, 2.4vw, 30px);
      padding: clamp(20px, 3vw, 36px) clamp(18px, 5vw, 56px) clamp(36px, 5vw, 64px);
    }
    .pcard {
      border: var(--bd-fat);
      background: var(--paper);
      box-shadow: var(--sh-lg);
      display: flex; flex-direction: column;
      overflow: hidden;
      opacity: 0; transform: translateY(26px);
      animation: rise .6s cubic-bezier(.2,.9,.2,1) forwards;
      transition: transform .1s linear, box-shadow .1s linear;
    }
    /* clashing asymmetric placement */
    .pcard--0 { grid-column: span 7; }
    .pcard--1 { grid-column: span 5; transform: translateY(26px) rotate(0deg); }
    .pcard--2 { grid-column: span 5; }
    .pcard--3 { grid-column: span 7; }
    .pcard--0 { animation-delay: .08s; }
    .pcard--1 { animation-delay: .16s; }
    .pcard--2 { animation-delay: .24s; }
    .pcard--3 { animation-delay: .32s; }

    .pcard:hover {
      transform: translate(6px, 6px);
      box-shadow: 0 0 0 var(--ink);
    }

    .pcard__media {
      position: relative;
      border-bottom: var(--bd-fat);
      aspect-ratio: 16 / 9;
      overflow: hidden;
    }
    .pcard__media img {
      width: 100%; height: 100%; display: block;
      filter: contrast(1.05) saturate(1.1);
    }
    .pcard__block {
      width: 100%; height: 100%;
      display: grid; place-items: center;
      font-family: var(--display); color: var(--paper); font-size: 28px;
    }
    .pcard__no {
      position: absolute; top: 0; left: 0;
      font-family: var(--display); font-size: 18px;
      background: var(--ink); color: var(--paper);
      padding: 6px 12px; border-right: var(--bd); border-bottom: var(--bd);
    }

    .pcard__body { padding: clamp(16px, 2vw, 24px); display: flex; flex-direction: column; gap: 12px; }
    .pcard__name {
      font-family: var(--display);
      font-size: clamp(22px, 3vw, 36px);
      margin: 0; letter-spacing: -.02em; line-height: 1;
    }
    .pcard__meta { display: flex; gap: 8px; flex-wrap: wrap; }
    .chip {
      font-family: var(--mono); font-weight: 700; font-size: 11px;
      letter-spacing: .04em;
      padding: 4px 9px; border: var(--bd);
      background: var(--brand); color: var(--ink);
    }
    .chip--ghost { background: var(--paper); }
    .pcard__summary { margin: 0; font-size: 15px; font-weight: 600; max-width: 60ch; }

    /* ---------- FOOTER ---------- */
    .footer {
      border-top: var(--bd-fat);
      background: var(--ink);
      color: var(--paper);
      padding: clamp(28px, 5vw, 60px) clamp(18px, 5vw, 56px);
    }
    .footer__big {
      font-family: var(--display);
      font-size: clamp(34px, 8vw, 100px);
      line-height: .9; letter-spacing: -.03em;
      color: var(--paper);
      -webkit-text-stroke: 0;
    }
    .footer__big::after { content: ' ⚡'; color: var(--yellow); }
    .footer__cols {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 24px; margin-top: clamp(28px, 4vw, 48px);
      border-top: 3px solid var(--paper); padding-top: 22px;
    }
    .footer__col { display: flex; flex-direction: column; gap: 8px; }
    .footer__col a { font-family: var(--mono); font-weight: 700; font-size: 13px; width: fit-content; }
    .footer__col a:hover { background: var(--yellow); color: var(--ink); }
    .footer__k {
      font-family: var(--mono); font-size: 11px; letter-spacing: .12em;
      color: var(--lime); margin-bottom: 4px;
    }
    .footer__note { font-family: var(--mono); font-size: 12px; line-height: 1.5; color: #cfcfcf; }

    /* ---------- ANIMATIONS ---------- */
    @keyframes rise {
      to { opacity: 1; transform: translateY(0) rotate(0); }
    }
    @keyframes spinwobble {
      0%, 100% { transform: rotate(12deg); }
      50% { transform: rotate(-6deg) scale(1.04); }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation: none !important; transition: none !important; }
      .word, .hero__about, .hero__stats, .pcard { opacity: 1; transform: none; }
      .marquee__track { animation: none; }
    }

    /* ---------- RESPONSIVE (390) ---------- */
    @media (max-width: 880px) {
      .topbar { flex-direction: column; align-items: stretch; }
      .wordmark { border-right: none; border-bottom: var(--bd); justify-content: center; }
      .nav { border-bottom: var(--bd); }
      .nav__link { flex: 1; justify-content: center; padding: 12px; border-right: var(--bd); }
      .social { justify-content: center; padding: 12px; }

      .hero {
        grid-template-columns: 1fr;
        grid-template-areas: 'tags' 'head' 'about';
        align-items: start;
      }
      .hero__stamp { display: none; }

      .sec-head__meta { margin-left: 0; }

      .grid { grid-template-columns: 1fr; }
      .pcard--0, .pcard--1, .pcard--2, .pcard--3 { grid-column: 1 / -1; }

      .footer__cols { grid-template-columns: 1fr; }
    }
  </style>
</GalleryShell>

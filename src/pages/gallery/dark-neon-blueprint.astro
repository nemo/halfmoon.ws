---
import GalleryShell from '../../layouts/GalleryShell.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Pearmill has no heroImage in frontmatter — fall back to the known asset.
const imageFor = (p: (typeof projects)[number]) =>
  p.data.heroImage ?? '/media/pearmill/pearmill.png';

const nav = [
  { label: 'Find Me', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Principles', href: '/principles' },
];
---

<GalleryShell title="Nima Gardideh" trend="Dark-Mode Neon Blueprint">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="canvas">
    <!-- full-page blueprint grid + galactic glow underlay -->
    <div class="grid-underlay" aria-hidden="true"></div>
    <div class="glow glow-a" aria-hidden="true"></div>
    <div class="glow glow-b" aria-hidden="true"></div>
    <div class="scanline" aria-hidden="true"></div>

    <header class="topbar">
      <a class="wordmark" href="/">
        <span class="mark-dot" aria-hidden="true"></span>
        <span class="mark-text">NIMA GARDIDEH</span>
      </a>
      <nav class="nav" aria-label="Primary">
        {nav.map((n) => (
          <a class="nav-link" href={n.href}>
            <span class="nav-bracket">[</span>{n.label}<span class="nav-bracket">]</span>
          </a>
        ))}
      </nav>
      <a class="ship" href="https://x.com/ngardideh" target="_blank" rel="noopener">
        @ngardideh
      </a>
    </header>

    <main>
      <!-- HERO: node-graph blueprint with glowing connections -->
      <section class="hero">
        <svg class="node-graph" viewBox="0 0 1200 520" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <defs>
            <linearGradient id="wire" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#3B82F6" />
              <stop offset="50%" stop-color="#8B5CF6" />
              <stop offset="100%" stop-color="#D946EF" />
            </linearGradient>
          </defs>
          <g class="wires" stroke="url(#wire)" fill="none" stroke-width="1.1">
            <path d="M120 90 L420 230 L760 120 L1080 300" />
            <path d="M80 360 L360 250 L640 400 L980 240 L1140 420" />
            <path d="M240 470 L520 320 L860 460 L1120 140" />
            <path d="M760 120 L860 460" />
            <path d="M420 230 L520 320" />
          </g>
          <g class="nodes" fill="#22D3EE">
            <circle cx="420" cy="230" r="3" />
            <circle cx="760" cy="120" r="3" />
            <circle cx="360" cy="250" r="3" />
            <circle cx="640" cy="400" r="3" />
            <circle cx="980" cy="240" r="3" />
            <circle cx="520" cy="320" r="3" />
            <circle cx="860" cy="460" r="3" />
            <circle cx="1080" cy="300" r="2.4" />
            <circle cx="1120" cy="140" r="2.4" />
          </g>
        </svg>

        <div class="hero-inner">
          <span class="eyebrow">
            <span class="eyebrow-dot" aria-hidden="true"></span>
            brooklyn, ny <span class="eyebrow-sep">·</span> systems &amp; stages
          </span>
          <h1 class="headline">
            a <em>founder</em>, <em>artist</em>, <em>engineer</em>, and
            <em>musician</em> based in Brooklyn.
          </h1>
          <p class="lede">
            Building products and performances at the seam where engineering
            discipline meets artistic intent.
          </p>
          <div class="cta-row">
            <a class="cta cta-primary" href="/projects">
              View projects
              <span class="arrow" aria-hidden="true">→</span>
            </a>
            <a class="cta cta-ghost" href="/about">Find me</a>
          </div>
          <ul class="stat-strip" aria-label="At a glance">
            <li><span class="stat-k">scope</span><span class="stat-v">art × technology</span></li>
            <li><span class="stat-k">building since</span><span class="stat-v">~2012</span></li>
            <li><span class="stat-k">status</span><span class="stat-v live">shipping</span></li>
          </ul>
        </div>
      </section>

      <!-- BENTO: projects -->
      <section class="work" aria-labelledby="work-label">
        <div class="section-head">
          <span id="work-label" class="mono-label">/ selected_work</span>
          <span class="mono-count">{String(projects.length).padStart(2, '0')} entries</span>
        </div>

        <div class="bento">
          {projects.map((p, i) => (
            <a
              class={`card card-${i}`}
              href={p.data.link ?? `/projects/${p.slug}`}
              target={p.data.link ? '_blank' : undefined}
              rel={p.data.link ? 'noopener' : undefined}
              style={`--brand:${p.data.brandColor};`}
            >
              <div class="card-glow" aria-hidden="true"></div>
              <div class="card-media" data-fit={p.data.imageFit ?? 'cover'}>
                <img src={imageFor(p)} alt={`${p.data.name} preview`} loading="lazy" />
              </div>
              <div class="card-body">
                <div class="card-top">
                  <span class="card-name">{p.data.name}</span>
                  <span class="card-period mono">{p.data.period}</span>
                </div>
                <span class="card-role mono">{p.data.role}</span>
                <p class="card-summary">{p.data.summary}</p>
                <span class="card-visit mono">
                  {p.data.link ? 'open ↗' : 'read →'}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- ABOUT -->
      <section class="about" aria-labelledby="about-label">
        <span id="about-label" class="mono-label">/ about</span>
        <p class="about-body">
          I spend most of my time at <strong>Pearmill</strong>, where we help
          companies grow through art and technology — the only place I've felt
          like an artist, entrepreneur, and engineer at once. Beyond that I
          write poetry, blog, and dance.
        </p>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-l">
        <span class="mark-dot small" aria-hidden="true"></span>
        <span class="mono">NIMA GARDIDEH</span>
      </div>
      <div class="footer-mid mono">© {new Date().getFullYear()} — Brooklyn, NY</div>
      <a class="footer-x mono" href="https://x.com/ngardideh" target="_blank" rel="noopener">
        @ngardideh ↗
      </a>
    </footer>
  </div>

  <style>
    @layer dnb {
      :global(html) {
        scroll-behavior: smooth;
      }
      :global(body) {
        margin: 0;
        background: #08080b;
        color: #e7e9f0;
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .canvas {
        position: relative;
        min-height: 100vh;
        overflow: clip;
        --blue: #3b82f6;
        --violet: #8b5cf6;
        --magenta: #d946ef;
        --cyan: #22d3ee;
        --panel: #14141a;
        --hair: rgba(255, 255, 255, 0.08);
      }

      /* ── blueprint grid underlay ── */
      .grid-underlay {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(123, 145, 220, 0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(123, 145, 220, 0.06) 1px, transparent 1px);
        background-size: 22px 22px;
        mask-image: radial-gradient(120% 90% at 50% 0%, #000 35%, transparent 100%);
        -webkit-mask-image: radial-gradient(120% 90% at 50% 0%, #000 35%, transparent 100%);
        opacity: 0;
        animation: gridIn 1.2s 0.1s ease forwards;
      }
      @keyframes gridIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      .glow {
        position: fixed;
        z-index: 0;
        pointer-events: none;
        filter: blur(90px);
        border-radius: 50%;
        will-change: transform;
      }
      .glow-a {
        top: -180px;
        left: 50%;
        width: 720px;
        height: 520px;
        transform: translateX(-50%);
        background: radial-gradient(closest-side, rgba(139, 92, 246, 0.42), transparent 70%);
        animation: drift 16s ease-in-out infinite alternate;
      }
      .glow-b {
        top: 120px;
        right: -120px;
        width: 520px;
        height: 520px;
        background: radial-gradient(closest-side, rgba(59, 130, 246, 0.3), transparent 70%);
        animation: drift 20s 1s ease-in-out infinite alternate-reverse;
      }
      @keyframes drift {
        from { transform: translate(-50%, 0) scale(1); }
        to { transform: translate(-46%, 30px) scale(1.08); }
      }
      .scanline {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.4;
        background: repeating-linear-gradient(
          to bottom,
          transparent 0 3px,
          rgba(255, 255, 255, 0.012) 3px 4px
        );
      }

      /* ── layout shell ── */
      .topbar,
      main,
      .footer {
        position: relative;
        z-index: 2;
        max-width: 1120px;
        margin-inline: auto;
        padding-inline: clamp(20px, 5vw, 48px);
      }

      .mono {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
      }

      /* ── topbar ── */
      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-block: 22px;
        opacity: 0;
        transform: translateY(-10px);
        animation: fadeDown 0.7s 0.15s ease forwards;
      }
      @keyframes fadeDown {
        to { opacity: 1; transform: none; }
      }
      .wordmark {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: #fff;
      }
      .mark-dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--cyan), var(--violet));
        box-shadow: 0 0 12px 1px rgba(34, 211, 238, 0.7);
        animation: pulse 3.2s ease-in-out infinite;
      }
      .mark-dot.small {
        width: 8px;
        height: 8px;
      }
      @keyframes pulse {
        0%, 100% { box-shadow: 0 0 8px 0 rgba(34, 211, 238, 0.5); }
        50% { box-shadow: 0 0 16px 3px rgba(139, 92, 246, 0.8); }
      }
      .mark-text {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.16em;
      }
      .nav {
        display: flex;
        gap: 4px;
      }
      .nav-link {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12.5px;
        letter-spacing: 0.04em;
        color: #9aa0b4;
        text-decoration: none;
        padding: 7px 10px;
        border-radius: 7px;
        transition: color 0.2s, background 0.2s;
      }
      .nav-bracket {
        color: transparent;
        transition: color 0.2s;
      }
      .nav-link:hover {
        color: #fff;
        background: rgba(139, 92, 246, 0.08);
      }
      .nav-link:hover .nav-bracket {
        color: var(--cyan);
      }
      .ship {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        color: #cdd2e3;
        text-decoration: none;
        padding: 8px 14px;
        border-radius: 8px;
        border: 1px solid var(--hair);
        background: rgba(255, 255, 255, 0.02);
        transition: border-color 0.25s, box-shadow 0.25s, color 0.2s;
      }
      .ship:hover {
        color: #fff;
        border-color: rgba(34, 211, 238, 0.5);
        box-shadow: 0 0 0 1px rgba(34, 211, 238, 0.25), 0 0 24px -4px rgba(34, 211, 238, 0.5);
      }

      /* ── hero ── */
      .hero {
        position: relative;
        padding-block: clamp(56px, 12vh, 130px) clamp(48px, 8vh, 96px);
      }
      .node-graph {
        position: absolute;
        inset: -40px -10% 0;
        width: 120%;
        height: 100%;
        z-index: 0;
        opacity: 0.68;
        pointer-events: none;
        mask-image: radial-gradient(85% 95% at 60% 40%, #000 5%, transparent 82%);
        -webkit-mask-image: radial-gradient(85% 95% at 60% 40%, #000 5%, transparent 82%);
      }
      .wires path {
        stroke-dasharray: 1600;
        stroke-dashoffset: 1600;
        filter: drop-shadow(0 0 4px rgba(139, 92, 246, 0.7));
        animation: draw 2.6s ease forwards;
      }
      .wires path:nth-child(2) { animation-delay: 0.3s; }
      .wires path:nth-child(3) { animation-delay: 0.6s; }
      .wires path:nth-child(4) { animation-delay: 0.85s; }
      .wires path:nth-child(5) { animation-delay: 1s; }
      @keyframes draw {
        to { stroke-dashoffset: 0; }
      }
      .nodes circle {
        filter: drop-shadow(0 0 6px rgba(34, 211, 238, 0.9));
        opacity: 0;
        animation: nodeIn 0.5s ease forwards 2.4s, nodePulse 4s ease-in-out infinite 3s;
      }
      @keyframes nodeIn { to { opacity: 1; } }
      @keyframes nodePulse {
        0%, 100% { r: 3; }
        50% { r: 4.5; }
      }

      .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 800px;
      }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11.5px;
        letter-spacing: 0.1em;
        text-transform: lowercase;
        color: #b9c0d8;
        margin-bottom: 24px;
        padding: 7px 14px 7px 11px;
        border-radius: 999px;
        border: 1px solid rgba(34, 211, 238, 0.22);
        background:
          linear-gradient(180deg, rgba(34, 211, 238, 0.06), rgba(139, 92, 246, 0.04));
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.02),
          0 0 26px -8px rgba(34, 211, 238, 0.45);
        opacity: 0;
        animation: rise 0.7s 0.3s ease forwards;
      }
      .eyebrow-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--cyan);
        box-shadow: 0 0 8px 1px var(--cyan);
        animation: pulse 2.4s ease-in-out infinite;
      }
      .eyebrow-sep {
        color: var(--violet);
        opacity: 0.8;
      }
      .headline {
        font-size: clamp(2.3rem, 6vw, 4.1rem);
        line-height: 1.04;
        letter-spacing: -0.02em;
        font-weight: 600;
        margin: 0;
        color: #f4f5fa;
        opacity: 0;
        animation: rise 0.8s 0.42s ease forwards;
      }
      .headline em {
        font-style: normal;
        background: linear-gradient(120deg, var(--blue), var(--violet) 45%, var(--magenta));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .lede {
        max-width: 50ch;
        margin: 22px 0 0;
        font-size: clamp(1rem, 1.6vw, 1.15rem);
        line-height: 1.6;
        color: #a7adc2;
        opacity: 0;
        animation: rise 0.8s 0.54s ease forwards;
      }
      @keyframes rise {
        from { opacity: 0; transform: translateY(14px); }
        to { opacity: 1; transform: none; }
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 34px;
        opacity: 0;
        animation: rise 0.8s 0.66s ease forwards;
      }
      .cta {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        letter-spacing: 0.03em;
        text-decoration: none;
        padding: 13px 22px;
        border-radius: 11px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: transform 0.2s, box-shadow 0.3s, border-color 0.25s;
      }
      .cta-primary {
        position: relative;
        color: #fff;
        background: linear-gradient(120deg, #2563eb, #7c3aed 55%, #c026d3);
        box-shadow: 0 0 0 1px rgba(139, 92, 246, 0.4),
          0 8px 30px -8px rgba(124, 58, 237, 0.8);
        animation: haloPulse 3.4s ease-in-out infinite;
      }
      @keyframes haloPulse {
        0%, 100% { box-shadow: 0 0 0 1px rgba(139, 92, 246, 0.4), 0 8px 30px -8px rgba(124, 58, 237, 0.65); }
        50% { box-shadow: 0 0 0 1px rgba(217, 70, 239, 0.55), 0 10px 42px -6px rgba(217, 70, 239, 0.8); }
      }
      .cta-primary:hover {
        transform: translateY(-2px);
      }
      .cta-primary .arrow {
        transition: transform 0.2s;
      }
      .cta-primary:hover .arrow {
        transform: translateX(4px);
      }
      .cta-ghost {
        color: #cdd2e3;
        border: 1px solid var(--hair);
        background: rgba(255, 255, 255, 0.02);
      }
      .cta-ghost:hover {
        color: #fff;
        border-color: rgba(34, 211, 238, 0.5);
        box-shadow: 0 0 24px -6px rgba(34, 211, 238, 0.5);
      }

      .stat-strip {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 0;
        margin: 44px 0 0;
        padding: 14px 0 0;
        border-top: 1px solid var(--hair);
        opacity: 0;
        animation: rise 0.8s 0.78s ease forwards;
      }
      .stat-strip li {
        display: flex;
        flex-direction: column;
        gap: 3px;
        padding-right: 36px;
        margin-right: 36px;
        border-right: 1px solid var(--hair);
      }
      .stat-strip li:last-child {
        border-right: 0;
        margin-right: 0;
        padding-right: 0;
      }
      .stat-k {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10.5px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #6e7490;
      }
      .stat-v {
        font-size: 14px;
        color: #dfe2ee;
      }
      .stat-v.live {
        color: var(--cyan);
        position: relative;
        padding-left: 16px;
      }
      .stat-v.live::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--cyan);
        box-shadow: 0 0 10px 1px var(--cyan);
        animation: pulse 2s ease-in-out infinite;
      }

      /* ── section head ── */
      .section-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 22px;
      }
      .mono-label,
      .mono-count {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.08em;
      }
      .mono-label { color: var(--violet); }
      .mono-count { color: #6e7490; }

      /* ── bento ── */
      .work {
        padding-block: clamp(36px, 6vh, 64px);
      }
      .bento {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 16px;
      }
      .card {
        position: relative;
        grid-column: span 3;
        overflow: hidden;
        border-radius: 16px;
        border: 1px solid var(--hair);
        background: linear-gradient(180deg, rgba(20, 20, 26, 0.85), rgba(8, 8, 11, 0.85));
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        opacity: 0;
        transform: translateY(18px);
        animation: rise 0.7s ease forwards;
        transition: border-color 0.3s, transform 0.3s, box-shadow 0.4s;
      }
      .card-0 { grid-column: span 4; animation-delay: 0.1s; }
      .card-1 { grid-column: span 2; animation-delay: 0.18s; }
      .card-2 { grid-column: span 2; animation-delay: 0.26s; }
      .card-3 { grid-column: span 4; animation-delay: 0.34s; }

      .card-glow {
        position: absolute;
        inset: -1px;
        z-index: 0;
        border-radius: 16px;
        opacity: 0;
        background: radial-gradient(120% 80% at 50% 0%, var(--brand), transparent 60%);
        transition: opacity 0.4s;
      }
      .card:hover {
        transform: translateY(-4px);
        border-color: color-mix(in srgb, var(--brand) 55%, transparent);
        box-shadow: 0 18px 50px -20px color-mix(in srgb, var(--brand) 80%, transparent),
          0 0 0 1px color-mix(in srgb, var(--brand) 30%, transparent);
      }
      .card:hover .card-glow {
        opacity: 0.16;
      }
      .card:focus-visible {
        outline: 2px solid var(--cyan);
        outline-offset: 2px;
      }

      .card-media {
        position: relative;
        z-index: 1;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        border-bottom: 1px solid var(--hair);
        background:
          radial-gradient(80% 120% at 50% 0%, color-mix(in srgb, var(--brand) 22%, transparent), transparent 70%),
          #0c0c11;
      }
      .card-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }
      .card-media[data-fit='contain'] img {
        object-fit: contain;
        padding: 22px;
      }
      .card:hover .card-media img {
        transform: scale(1.03);
      }

      .card-body {
        position: relative;
        z-index: 1;
        padding: 18px 20px 20px;
        display: flex;
        flex-direction: column;
        gap: 7px;
        flex: 1;
      }
      .card-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
      }
      .card-name {
        font-size: 1.18rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: #f4f5fa;
      }
      .card-period {
        font-size: 11px;
        color: #6e7490;
        white-space: nowrap;
      }
      .card-role {
        font-size: 11px;
        letter-spacing: 0.04em;
        color: var(--brand);
        filter: brightness(1.25);
      }
      .card-summary {
        margin: 4px 0 0;
        font-size: 13.5px;
        line-height: 1.55;
        color: #9aa0b4;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .card-visit {
        margin-top: auto;
        padding-top: 12px;
        font-size: 11px;
        letter-spacing: 0.06em;
        color: #cdd2e3;
        transition: color 0.2s;
      }
      .card:hover .card-visit {

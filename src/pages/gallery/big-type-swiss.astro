---
import GalleryShell from '../../layouts/GalleryShell.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);

const projectImage = (p: (typeof projects)[number]) =>
  p.slug === 'pearmill' ? '/media/pearmill/pearmill.png' : p.data.heroImage;

const nav = [
  { label: 'Find Me', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Principles', href: '/principles' },
];
---

<GalleryShell title="Nima Gardideh" trend="Big-Type Swiss Revival">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;700;800;900&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="page">
    <!-- ============ TOP BAR ============ -->
    <header class="bar">
      <a class="wordmark" href="/">
        Nima<span class="wm-sep"> </span>Gardideh
      </a>
      <nav class="nav" aria-label="Primary">
        {nav.map((n) => (
          <a class="nav-link" href={n.href}>{n.label}</a>
        ))}
      </nav>
      <a class="social" href="https://x.com/ngardideh" target="_blank" rel="noopener">
        @ngardideh
        <span class="social-arrow" aria-hidden="true">↗</span>
      </a>
    </header>

    <!-- ============ HERO ============ -->
    <section class="hero" aria-labelledby="hero-h">
      <div class="hero-meta">
        <span class="kicker">Index — Brooklyn, NY</span>
        <span class="kicker">©2026 / Portfolio</span>
      </div>

      <h1 id="hero-h" class="hero-h">
        <span class="ln ln-1"><em>a</em> founder,</span>
        <span class="ln ln-2">artist,</span>
        <span class="ln ln-3">engineer <span class="amp">&amp;</span></span>
        <span class="ln ln-4">musician.</span>
      </h1>

      <div class="hero-foot">
        <span class="kicker">Scroll</span>
        <span class="hero-rule" aria-hidden="true"></span>
        <span class="kicker">Index 01 — 04</span>
      </div>

      <p class="hero-sub">
        Based in Brooklyn — building companies through art and technology,
        and making things that bend sound, image, and language into each other.
      </p>
    </section>

    <!-- ============ MARQUEE BAND ============ -->
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        <span>Founder</span><span class="dot">●</span>
        <span>Artist</span><span class="dot">●</span>
        <span>Engineer</span><span class="dot">●</span>
        <span>Musician</span><span class="dot">●</span>
        <span>Poet</span><span class="dot">●</span>
        <span>Founder</span><span class="dot">●</span>
        <span>Artist</span><span class="dot">●</span>
        <span>Engineer</span><span class="dot">●</span>
        <span>Musician</span><span class="dot">●</span>
        <span>Poet</span><span class="dot">●</span>
      </div>
    </div>

    <!-- ============ PROJECTS ============ -->
    <section class="work" aria-labelledby="work-h">
      <div class="work-head">
        <h2 id="work-h" class="section-h">Selected Work</h2>
        <span class="count">[ {String(projects.length).padStart(2, '0')} ]</span>
      </div>

      <ol class="proj-list">
        {projects.map((p, i) => (
          <li class="proj" style={`--brand:${p.data.brandColor}`}>
            <a class="proj-link" href={p.data.link} target="_blank" rel="noopener">
              <span class="proj-no">{String(i + 1).padStart(2, '0')}</span>

              <div class="proj-main">
                <h3 class="proj-name">{p.data.name}</h3>
                <p class="proj-summary">{p.data.summary}</p>
              </div>

              <div class="proj-aside">
                <span class="proj-role">{p.data.role}</span>
                <span class="proj-period">{p.data.period}</span>
                <span class="proj-go">View ↗</span>
              </div>

              <div class={`proj-thumb fit-${p.data.imageFit ?? 'cover'}`}>
                <img src={projectImage(p)} alt={`${p.data.name} — ${p.data.role}`} loading="lazy" />
              </div>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <!-- ============ ABOUT ============ -->
    <section class="about" aria-labelledby="about-h">
      <span class="kicker about-kicker">About</span>
      <h2 id="about-h" class="about-h">
        I spend most of my time at <span class="hl">Pearmill</span>, where we
        help companies grow through art and technology.
      </h2>
      <p class="about-body">
        It's the only place I've felt like an artist, entrepreneur, and engineer
        at once. Beyond that I write poetry, blog, and dance.
      </p>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="foot">
      <div class="foot-grid">
        <span class="foot-mark">Nima Gardideh</span>
        <nav class="foot-nav" aria-label="Footer">
          {nav.map((n) => (
            <a href={n.href}>{n.label}</a>
          ))}
        </nav>
        <a class="foot-x" href="https://x.com/ngardideh" target="_blank" rel="noopener">
          @ngardideh ↗
        </a>
      </div>
      <div class="foot-base">
        <span>Brooklyn, New York</span>
        <span>Set in Archivo &amp; Inter</span>
        <span>©2026</span>
      </div>
    </footer>
  </div>

  <script>
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* kinetic hero: subtle parallax + tracking shift on scroll */
    const hero = document.querySelector<HTMLElement>('.hero-h');
    if (hero && !reduce) {
      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const y = window.scrollY;
          const k = Math.min(y / 700, 1);
          hero.style.transform = `translate3d(${-k * 3.5}vw, ${y * -0.08}px, 0)`;
          hero.style.opacity = String(1 - k * 0.35);
          ticking = false;
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    /* reveal project rows as they enter */
    const rows = document.querySelectorAll<HTMLElement>('.proj');
    if (rows.length) {
      if (reduce || !('IntersectionObserver' in window)) {
        rows.forEach((r) => r.classList.add('in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                (e.target as HTMLElement).classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.18, rootMargin: '0px 0px -8% 0px' },
        );
        rows.forEach((r) => io.observe(r));
        /* failsafe: ensure nothing stays hidden if it never intersects */
        window.setTimeout(() => rows.forEach((r) => r.classList.add('in')), 450);
      }
    }
  </script>

  <style>
    :root {
      --paper: #fafaf7;
      --ink: #0a0a0a;
      --red: #e5170a;
      --rule: rgba(10, 10, 10, 0.14);
      --pad: clamp(20px, 4.5vw, 64px);
    }

    * {
      box-sizing: border-box;
    }

    .page {
      margin: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: 'Inter', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow-x: clip;
      min-height: 100vh;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .kicker {
      font-family: 'Archivo', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    /* ---------- TOP BAR ---------- */
    .bar {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 24px;
      padding: 22px var(--pad);
      border-bottom: 2px solid var(--ink);
      position: sticky;
      top: 0;
      background: var(--paper);
      z-index: 50;
    }

    .wordmark {
      font-family: 'Archivo', sans-serif;
      font-weight: 900;
      font-size: 15px;
      letter-spacing: -0.02em;
      text-transform: uppercase;
    }
    .wm-sep::before {
      content: '';
    }

    .nav {
      display: flex;
      gap: 28px;
      justify-content: center;
    }
    .nav-link {
      font-family: 'Archivo', sans-serif;
      font-weight: 500;
      font-size: 13px;
      letter-spacing: 0.01em;
      position: relative;
      padding: 4px 0;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -2px;
      width: 100%;
      height: 2px;
      background: var(--red);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.32s cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    .nav-link:hover::after,
    .nav-link:focus-visible::after {
      transform: scaleX(1);
    }

    .social {
      font-family: 'Archivo', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.01em;
      display: inline-flex;
      gap: 4px;
      align-items: center;
    }
    .social-arrow {
      transition: transform 0.3s ease;
    }
    .social:hover .social-arrow {
      transform: translate(2px, -2px);
    }

    /* ---------- HERO ---------- */
    .hero {
      padding: clamp(48px, 8vw, 120px) var(--pad) clamp(28px, 4vw, 56px);
    }

    .hero-meta {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      color: var(--ink);
      margin-bottom: clamp(28px, 5vw, 64px);
      border-bottom: 1px solid var(--rule);
      padding-bottom: 14px;
    }

    .hero-h {
      margin: 0;
      font-family: 'Archivo', sans-serif;
      font-weight: 900;
      font-size: clamp(64px, 16.8vw, 288px);
      line-height: 0.82;
      letter-spacing: -0.045em;
      text-transform: none;
      will-change: transform, opacity;
    }
    .hero-h .ln {
      display: block;
    }
    /* the giant lines clip the left edge intentionally */
    .hero-h .ln-2 {
      margin-left: -0.04em;
    }
    .hero-h em {
      font-style: normal;
      color: var(--red);
    }
    .hero-h .amp {
      color: var(--red);
      font-weight: 800;
    }
    .hero-h .ln-4 {
      color: var(--ink);
    }

    .hero-sub {
      margin: clamp(28px, 4vw, 52px) 0 0;
      max-width: 46ch;
      margin-left: auto;
      font-size: clamp(15px, 1.4vw, 19px);
      line-height: 1.5;
      color: rgba(10, 10, 10, 0.78);
    }

    .hero-foot {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-top: clamp(36px, 5vw, 72px);
      opacity: 0;
      animation: fade 0.8s ease 0.7s forwards;
    }
    .hero-foot .kicker {
      color: rgba(10, 10, 10, 0.55);
      white-space: nowrap;
    }
    .hero-rule {
      flex: 1;
      height: 2px;
      background: var(--ink);
      transform-origin: left;
      animation: ruleGrow 1.1s cubic-bezier(0.16, 0.84, 0.32, 1) 0.6s both;
    }
    @keyframes ruleGrow {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }

    /* load-in animation */
    .ln {
      opacity: 0;
      transform: translateY(0.18em);
      animation: rise 0.9s cubic-bezier(0.16, 0.84, 0.32, 1) forwards;
    }
    .ln-1 { animation-delay: 0.05s; }
    .ln-2 { animation-delay: 0.16s; }
    .ln-3 { animation-delay: 0.27s; }
    .ln-4 { animation-delay: 0.38s; }
    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(0.22em);
        letter-spacing: 0.02em;
      }
      to {
        opacity: 1;
        transform: translateY(0);
        letter-spacing: -0.045em;
      }
    }
    .hero-meta,
    .hero-sub {
      opacity: 0;
      animation: fade 0.8s ease forwards;
    }
    .hero-meta { animation-delay: 0.1s; }
    .hero-sub { animation-delay: 0.55s; }
    @keyframes fade {
      to { opacity: 1; }
    }

    /* ---------- MARQUEE ---------- */
    .marquee {
      background: var(--red);
      color: var(--paper);
      border-top: 2px solid var(--ink);
      border-bottom: 2px solid var(--ink);
      overflow: hidden;
      padding: 14px 0;
    }
    .marquee-track {
      display: inline-flex;
      align-items: center;
      gap: 28px;
      white-space: nowrap;
      font-family: 'Archivo', sans-serif;
      font-weight: 800;
      font-size: clamp(26px, 4vw, 52px);
      letter-spacing: -0.02em;
      text-transform: uppercase;
      will-change: transform;
      animation: scroll 24s linear infinite;
    }
    .marquee-track .dot {
      font-size: 0.4em;
      transform: translateY(-0.25em);
    }
    @keyframes scroll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ---------- WORK ---------- */
    .work {
      padding: clamp(56px, 9vw, 140px) var(--pad) clamp(40px, 6vw, 80px);
    }
    .work-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      border-bottom: 2px solid var(--ink);
      padding-bottom: 16px;
      margin-bottom: 8px;
    }
    .section-h {
      margin: 0;
      font-family: 'Archivo', sans-serif;
      font-weight: 800;
      font-size: clamp(13px, 1.2vw, 15px);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .count {
      font-family: 'Archivo', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.12em;
      color: var(--red);
    }

    .proj-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .proj {
      border-bottom: 1px solid var(--rule);
      opacity: 0;
      transform: translateY(28px);
      transition:
        opacity 0.7s cubic-bezier(0.16, 0.84, 0.32, 1),
        transform 0.7s cubic-bezier(0.16, 0.84, 0.32, 1);
    }
    .proj.in {
      opacity: 1;
      transform: none;
    }
    .proj:last-child {
      border-bottom: 2px solid var(--ink);
    }
    .proj-link {
      display: grid;
      grid-template-columns: 3.2rem minmax(0, 1fr) 12rem 8.5rem;
      gap: clamp(16px, 2.5vw, 40px);
      align-items: baseline;
      padding: clamp(28px, 4vw, 52px) 0;
      transition: padding-left 0.4s cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    .proj-link:hover,
    .proj-link:focus-visible {
      padding-left: clamp(8px, 1.5vw, 24px);
    }

    .proj-no {
      font-family: 'Archivo', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.06em;
      color: rgba(10, 10, 10, 0.45);
      padding-top: 0.7em;
    }

    .proj-main {
      min-width: 0;
    }
    .proj-name {
      margin: 0;
      font-family: 'Archivo', sans-serif;
      font-weight: 900;
      font-size: clamp(40px, 7vw, 116px);
      line-height: 0.92;
      letter-spacing: -0.04em;
      transition: color 0.3s ease;
    }
    .proj-link:hover .proj-name,
    .proj-link:focus-visible .proj-name {
      color: var(--brand);
    }
    .proj-summary {
      margin: 18px 0 0;
      max-width: 56ch;
      font-size: clamp(14px, 1.2vw, 16px);
      line-height: 1.55;
      color: rgba(10, 10, 10, 0.74);
    }

    .proj-aside {
      display: flex;
      flex-direction: column;
      gap: 6px;
      font-family: 'Archivo', sans-serif;
      padding-top: 0.7em;
    }
    .proj-role {
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.02em;
    }
    .proj-period {
      font-weight: 500;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(10, 10, 10, 0.5);
    }
    .proj-go {
      margin-top: 8px;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--red);
      opacity: 0;
      transform: translateY(4px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .proj-link:hover .proj-go,
    .proj-link:focus-visible .proj-go {
      opacity: 1;
      transform: translateY(0);
    }

    .proj-thumb {
      width: 8.5rem;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      background: var(--brand);
      align-self: center;
      filter: grayscale(1) contrast(1.04);
      transition: filter 0.45s ease, transform 0.45s cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    .proj-thumb img {
      width: 100%;
      height: 100%;
      display: block;
      mix-blend-mode: multiply;
    }
    .fit-cover img {
      object-fit: cover;
    }
    .fit-contain img {
      object-fit: contain;
    }
    .proj-link:hover .proj-thumb,
    .proj-link:focus-visible .proj-thumb {
      filter: grayscale(0) contrast(1);
      transform: scale(1.03);
    }

    /* ---------- ABOUT ---------- */
    .about {
      padding: clamp(64px, 10vw, 160px) var(--pad);
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      max-width: 1100px;
    }
    .about-kicker {
      color: var(--red);
      display: block;
      margin-bottom: 28px;
    }
    .about-h {
      margin: 0;
      font-family: 'Archivo', sans-serif;
      font-weight: 800;
      font-size: clamp(28px, 4.6vw, 64px);
      line-height: 1.02;
      letter-spacing: -0.03em;
      max-width: 20ch;
    }
    .about-h .hl {
      color: var(--red);
    }
    .about-body {
      margin: clamp(28px, 3vw, 44px) 0 0;
      max-width: 50ch;
      margin-left: auto;
      font-size: clamp(15px, 1.4vw, 19px);
      line-height: 1.55;
      color: rgba(10, 10, 10, 0.78);
    }

    /* ---------- FOOTER ---------- */
    .foot {
      border-top: 2px solid var(--ink);
      padding: clamp(36px, 5vw, 64px) var(--pad) 28px;
    }
    .foot-grid {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 24px;
      padding-bottom: clamp(40px, 6vw, 72px);
    }
    .foot-mark {
      font-family: 'Archivo', sans-serif;
      font-weight: 900;
      font-size: clamp(20px, 3vw, 34px);
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }
    .foot-nav {
      display: flex;
      gap: 24px;
      justify-content: center;
      flex-wrap: wrap;
    }
    .foot-nav a {
      font-family: 'Archivo', sans-serif;
      font-weight: 500;
      font-size: 13px;
    }
    .foot-nav a:hover {
      color: var(--red);
    }
    .foot-x {
      font-family: 'Archivo', sans-serif;
      font-weight: 800;
      font-size: clamp(15px, 1.8vw, 20px);
      letter-spacing: -0.01em;
      color: var(--red);
      transition: opacity 0.25s ease;
    }
    .foot-x:hover {
      opacity: 0.6;
    }
    .foot-base {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      border-top: 1px solid var(--rule);
      padding-top: 18px;
      font-family: 'Archivo', sans-serif;
      font-weight: 500;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(10, 10, 10, 0.5);
    }

    /* ---------- RESPONSIVE ---------- */
    @media (max-width: 1024px) {
      .proj-link {
        grid-template-columns: 2.6rem minmax(0, 1fr) 9rem;
        grid-template-areas:
          'no main aside'
          'no thumb thumb';
      }
      .proj-no { grid-area: no; }
      .proj-main { grid-area: main; }
      .proj-aside { grid-area: aside; }
      .proj-thumb {
        grid-area: thumb;
        width: 100%;
        max-width: 320px;
        aspect-ratio: 16 / 9;
        margin-top: 24px;
        align-self: start;
      }
    }

    @media (max-width: 720px) {
      .bar {
        grid-template-columns: 1fr auto;
        grid-template-areas:
          'wm social'
          'nav nav';
        row-gap: 16px;
      }
      .wordmark { grid-area: wm; }
      .social { grid-area: social; justify-self: end; }
      .nav {
        grid-area: nav;
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: 18px;
      }
      .hero-sub {
        margin-left: 0;
      }
      .proj-link {
        grid-template-columns: minmax(0, 1fr);
        grid-template-areas:
          'no'
          'main'
          'thumb'
          'aside';
        gap: 14px;
        align-items: start;
      }
      .proj-no { padding-top: 0; }
      .proj-aside {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 16px;
        align-items: baseline;
        padding-top: 0;
      }
      .proj-go { opacity: 1; transform: none; }
      .proj-thumb { margin-top: 8px; }
      .about-body { margin-left: 0; }
      .foot-grid {
        grid-template-columns: 1fr;
        gap: 28px;
      }
      .foot-nav { justify-content: flex-start; }
      .foot-x { justify-self: start; }
    }

    @media (prefers-reduced-motion: reduce) {
      .ln,
      .hero-meta,
      .hero-sub,
      .hero-foot,
      .hero-rule {
        animation: none;
        opacity: 1;
        transform: none;
        letter-spacing: -0.045em;
      }
      .proj {
        opacity: 1;
        transform: none;
        transition: none;
      }
      .marquee-track {
        animation: none;
      }
      .proj-link,
      .proj-thumb,
      .nav-link::after {
        transition: none;
      }
    }
  </style>
</GalleryShell>

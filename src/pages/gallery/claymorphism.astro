---
import GalleryShell from '../../layouts/GalleryShell.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Pearmill ships without a heroImage in frontmatter; fall back to the known asset.
const imageFor = (p: (typeof projects)[number]) =>
  p.data.heroImage ?? (p.slug === 'pearmill' ? '/media/pearmill/pearmill.png' : null);

const nav = [
  { label: 'Find Me', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Principles', href: '/principles' },
];

// Cycle a candy-pastel accent per card so each clay tile reads distinctly.
const tints = ['#A5C8FF', '#FFB3D1', '#B8F0D2', '#C9B8FF'];
---

<GalleryShell title="Nima Gardideh" trend="Claymorphism (Soft 3D)">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Quicksand:wght@500;600;700&family=Nunito:ital,wght@0,400;0,500;0,600;0,700;1,500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="stage">
    <!-- ambient floating clay blobs -->
    <div class="ambient" aria-hidden="true">
      <span class="blob blob--a"></span>
      <span class="blob blob--b"></span>
      <span class="blob blob--c"></span>
      <span class="blob blob--d"></span>
    </div>

    <header class="topbar">
      <a class="wordmark" href="/">
        <span class="wordmark__pin" aria-hidden="true"></span>
        NIMA GARDIDEH
      </a>
      <nav class="nav" aria-label="Primary">
        {nav.map((n) => (
          <a class="nav__link" href={n.href}>{n.label}</a>
        ))}
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero__copy">
          <p class="eyebrow">
            <span class="dot" aria-hidden="true"></span>
            Brooklyn, New York
          </p>
          <h1 class="hero__title">
            a <span class="pill pill--blue">founder</span>,
            <span class="pill pill--pink">artist</span>,
            <span class="pill pill--mint">engineer</span>, and
            <span class="pill pill--lilac">musician</span>
            based in Brooklyn.
          </h1>
          <p class="hero__sub">
            I build companies and make things — soft on the outside, carefully
            engineered underneath.
          </p>
          <div class="hero__cta">
            <a class="btn btn--press" href="/projects">See the work</a>
            <a class="btn btn--ghost" href="/about">Find me</a>
          </div>
        </div>

        <!-- rendered clay mascot, built entirely in CSS -->
        <div class="hero__mascot" aria-hidden="true">
          <div class="mascot">
            <span class="mascot__shadow"></span>
            <span class="mascot__body"></span>
            <span class="mascot__cheek mascot__cheek--l"></span>
            <span class="mascot__cheek mascot__cheek--r"></span>
            <span class="mascot__eye mascot__eye--l"></span>
            <span class="mascot__eye mascot__eye--r"></span>
            <span class="mascot__smile"></span>
            <span class="mascot__orbit mascot__orbit--1"></span>
            <span class="mascot__orbit mascot__orbit--2"></span>
          </div>
        </div>
      </section>

      <section class="work" aria-labelledby="work-h">
        <div class="work__head">
          <h2 id="work-h">Things I've shaped</h2>
          <p>Four projects, each pressable. Give one a poke.</p>
        </div>

        <ul class="grid">
          {projects.map((p, i) => {
            const img = imageFor(p);
            const tint = tints[i % tints.length];
            return (
              <li
                class="card"
                style={`--brand:${p.data.brandColor}; --tint:${tint};`}
              >
                <a
                  class="card__link"
                  href={p.data.link ?? `/projects/${p.slug}`}
                  target={p.data.link ? '_blank' : undefined}
                  rel={p.data.link ? 'noreferrer' : undefined}
                >
                  <div class="card__thumb">
                    {img ? (
                      <img
                        src={img}
                        alt={`${p.data.name} preview`}
                        loading="lazy"
                        style={`object-fit:${p.data.imageFit};`}
                      />
                    ) : (
                      <span class="card__thumb--block"></span>
                    )}
                  </div>
                  <div class="card__body">
                    <div class="card__row">
                      <h3 class="card__name">{p.data.name}</h3>
                      <span class="chip">{p.data.period}</span>
                    </div>
                    <p class="card__role">{p.data.role}</p>
                    <p class="card__summary">{p.data.summary}</p>
                    <span class="card__go">
                      Open
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M5 12h13M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </section>

      <section class="about" aria-labelledby="about-h">
        <div class="about__card">
          <h2 id="about-h">A little about me</h2>
          <p>
            I spend most of my time at <strong>Pearmill</strong>, where we help
            companies grow through art and technology — the only place I've felt
            like an artist, entrepreneur, and engineer at once. Beyond that I
            write poetry, blog, and dance.
          </p>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer__mark">NIMA GARDIDEH</div>
      <a class="footer__social btn btn--press" href="https://x.com/ngardideh" target="_blank" rel="noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/>
        </svg>
        @ngardideh
      </a>
      <p class="footer__note">Made soft in Brooklyn · pressable since 2026</p>
    </footer>
  </div>

  <style>
    /* ---------- claymorphism tokens ---------- */
    :global(:root) {
      --base: #f0f4ff;
      --base-deep: #e4ebff;
      --blue: #a5c8ff;
      --pink: #ffb3d1;
      --mint: #b8f0d2;
      --lilac: #c9b8ff;
      --ink: #4a4a6a;
      --ink-soft: #7b7ba0;
      --r-lg: 42px;
      --r-md: 34px;
      --r-sm: 22px;

      /* the signature clay recipe — light inner top-left, dark inner
         bottom-right, plus a soft floating outer drop shadow */
      --clay:
        8px 8px 22px rgba(150, 160, 210, 0.45),
        -6px -6px 16px rgba(255, 255, 255, 0.95),
        inset 6px 6px 12px rgba(255, 255, 255, 0.9),
        inset -7px -7px 14px rgba(150, 160, 210, 0.4);
      --clay-press:
        4px 4px 12px rgba(150, 160, 210, 0.35),
        -3px -3px 8px rgba(255, 255, 255, 0.8),
        inset 7px 7px 16px rgba(150, 160, 210, 0.55),
        inset -7px -7px 16px rgba(255, 255, 255, 0.95);
      --spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    :global(body) {
      margin: 0;
      background: var(--base);
      background-image:
        radial-gradient(120% 90% at 12% -10%, rgba(165, 200, 255, 0.5), transparent 55%),
        radial-gradient(120% 90% at 92% 0%, rgba(255, 179, 209, 0.45), transparent 55%),
        radial-gradient(140% 120% at 50% 120%, rgba(184, 240, 210, 0.5), transparent 55%);
      color: var(--ink);
      font-family: 'Nunito', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    .stage {
      position: relative;
      max-width: 1180px;
      margin: 0 auto;
      padding: 22px clamp(18px, 4vw, 40px) 60px;
      z-index: 1;
    }

    /* ---------- ambient blobs ---------- */
    .ambient { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
    .blob {
      position: absolute;
      border-radius: 50% 46% 52% 48% / 48% 52% 46% 54%;
      filter: blur(2px);
      opacity: 0.55;
      box-shadow:
        inset 10px 10px 20px rgba(255, 255, 255, 0.7),
        inset -12px -12px 24px rgba(120, 130, 190, 0.35);
      animation: bob 9s var(--spring) infinite;
    }
    .blob--a { width: 190px; height: 190px; top: 14%; left: -60px; background: radial-gradient(circle at 35% 30%, #c9defff0, var(--blue)); }
    .blob--b { width: 150px; height: 150px; top: 58%; right: -40px; background: radial-gradient(circle at 35% 30%, #ffd6e8f0, var(--pink)); animation-delay: -2.5s; }
    .blob--c { width: 120px; height: 120px; bottom: 8%; left: 8%; background: radial-gradient(circle at 35% 30%, #d8fcebf0, var(--mint)); animation-delay: -4s; }
    .blob--d { width: 100px; height: 100px; top: 6%; right: 22%; background: radial-gradient(circle at 35% 30%, #e3dcfff0, var(--lilac)); animation-delay: -6s; }

    /* ---------- topbar ---------- */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 14px 22px;
      border-radius: var(--r-md);
      background: var(--base);
      box-shadow: var(--clay);
      animation: drop-in 0.7s var(--spring) both;
    }
    .wordmark {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-family: 'Baloo 2', cursive;
      font-weight: 800;
      letter-spacing: 0.06em;
      font-size: 1.02rem;
      color: var(--ink);
      text-decoration: none;
    }
    .wordmark__pin {
      width: 26px; height: 26px; border-radius: 50%;
      background: radial-gradient(circle at 32% 28%, #fff, var(--pink) 70%, #ff8fbc);
      box-shadow:
        inset 3px 3px 5px rgba(255,255,255,0.9),
        inset -4px -4px 7px rgba(190,90,140,0.5),
        3px 3px 8px rgba(150,160,210,0.5);
      flex: none;
    }
    .nav { display: flex; gap: 8px; flex-wrap: wrap; }
    .nav__link {
      font-family: 'Quicksand', sans-serif;
      font-weight: 700;
      font-size: 0.92rem;
      color: var(--ink-soft);
      text-decoration: none;
      padding: 9px 16px;
      border-radius: 999px;
      transition: transform 0.35s var(--spring), color 0.25s ease, box-shadow 0.3s ease;
    }
    .nav__link:hover {
      color: var(--ink);
      transform: translateY(-2px);
      box-shadow: var(--clay);
      background: var(--base);
    }
    .nav__link:focus-visible {
      outline: 3px solid var(--lilac);
      outline-offset: 3px;
    }

    /* ---------- hero ---------- */
    .hero {
      display: grid;
      grid-template-columns: 1.25fr 0.9fr;
      align-items: center;
      gap: clamp(24px, 4vw, 60px);
      padding: clamp(34px, 6vw, 76px) 0 clamp(20px, 4vw, 50px);
    }
    .hero__copy { animation: drop-in 0.8s var(--spring) 0.08s both; }
    .eyebrow {
      display: inline-flex; align-items: center; gap: 9px;
      font-family: 'Quicksand', sans-serif; font-weight: 700;
      font-size: 0.8rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink-soft);
      background: var(--base);
      padding: 10px 18px; border-radius: 999px;
      box-shadow: var(--clay); margin: 0 0 22px;
    }
    .dot {
      width: 11px; height: 11px; border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #d8ffe8, var(--mint));
      box-shadow: 0 0 0 4px rgba(184,240,210,0.4);
    }
    .hero__title {
      font-family: 'Baloo 2', cursive;
      font-weight: 700;
      font-size: clamp(2.3rem, 5.4vw, 4rem);
      line-height: 1.12;
      letter-spacing: -0.01em;
      margin: 0 0 22px;
      color: var(--ink);
    }
    .pill {
      display: inline-block;
      padding: 0.02em 0.42em 0.1em;
      border-radius: 18px;
      color: #3c3c5c;
      box-shadow:
        inset 3px 3px 6px rgba(255,255,255,0.85),
        inset -4px -4px 8px rgba(120,130,190,0.28),
        4px 5px 12px rgba(150,160,210,0.4);
      transition: transform 0.4s var(--spring);
    }
    .hero__title:hover .pill { transform: translateY(-1px) rotate(-1.2deg); }
    .pill--blue { background: var(--blue); }
    .pill--pink { background: var(--pink); }
    .pill--mint { background: var(--mint); }
    .pill--lilac { background: var(--lilac); }
    .hero__sub {
      font-size: 1.12rem; line-height: 1.6; max-width: 38ch;
      color: var(--ink-soft); margin: 0 0 28px; font-weight: 500;
    }
    .hero__cta { display: flex; gap: 14px; flex-wrap: wrap; }

    .btn {
      font-family: 'Quicksand', sans-serif; font-weight: 700;
      font-size: 1rem; text-decoration: none;
      padding: 15px 28px; border-radius: 999px;
      display: inline-flex; align-items: center; gap: 9px;
      cursor: pointer;
      transition: transform 0.32s var(--spring), box-shadow 0.32s var(--spring);
    }
    .btn--press {
      background: var(--blue);
      color: #2e3a66;
      box-shadow: var(--clay);
    }
    .btn--press:hover { transform: translateY(-3px); }
    .btn--press:active { transform: translateY(1px) scale(0.98); box-shadow: var(--clay-press); }
    .btn--ghost {
      background: var(--base); color: var(--ink-soft);
      box-shadow: var(--clay);
    }
    .btn--ghost:hover { transform: translateY(-3px); color: var(--ink); }
    .btn--ghost:active { box-shadow: var(--clay-press); transform: translateY(1px); }
    .btn:focus-visible { outline: 3px solid var(--lilac); outline-offset: 4px; }

    /* ---------- CSS clay mascot ---------- */
    .hero__mascot {
      display: flex; justify-content: center; align-items: center;
      animation: drop-in 0.9s var(--spring) 0.18s both;
    }
    .mascot {
      position: relative; width: 320px; height: 340px;
      animation: bob 5.5s var(--spring) infinite;
    }
    .mascot__shadow {
      position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%);
      width: 160px; height: 28px; border-radius: 50%;
      background: rgba(120,130,190,0.35); filter: blur(12px);
      animation: shadow-pulse 5.5s var(--spring) infinite;
    }
    .mascot__body {
      position: absolute; top: 30px; left: 50%; transform: translateX(-50%);
      width: 250px; height: 250px;
      border-radius: 52% 48% 50% 50% / 56% 56% 44% 44%;
      background:
        radial-gradient(circle at 32% 26%, #d8e6ff, var(--blue) 62%, #88aef0 100%);
      box-shadow:
        12px 14px 30px rgba(120,130,190,0.45),
        inset 12px 12px 22px rgba(255,255,255,0.85),
        inset -14px -16px 28px rgba(90,120,200,0.45);
    }
    .mascot__cheek {
      position: absolute; top: 172px; width: 38px; height: 24px;
      border-radius: 50%; background: var(--pink); opacity: 0.85;
      filter: blur(2px);
    }
    .mascot__cheek--l { left: 78px; }
    .mascot__cheek--r { right: 78px; }
    .mascot__eye {
      position: absolute; top: 134px; width: 28px; height: 33px;
      border-radius: 50%;
      background: radial-gradient(circle at 36% 30%, #5a5a82, #2e2e4a);
      box-shadow: inset -2px -2px 4px rgba(0,0,0,0.4);
    }
    .mascot__eye::after {
      content: ''; position: absolute; top: 5px; left: 6px;
      width: 8px; height: 8px; border-radius: 50%; background: #fff;
    }
    .mascot__eye--l { left: 102px; }
    .mascot__eye--r { right: 102px; }
    .mascot__smile {
      position: absolute; top: 180px; left: 50%; transform: translateX(-50%);
      width: 60px; height: 30px;
      border-bottom: 7px solid #3c3c5c; border-radius: 0 0 60px 60px;
    }
    .mascot__orbit {
      position: absolute; border-radius: 50% 46% 52% 48% / 48% 52% 46% 54%;
      box-shadow:
        inset 4px 4px 8px rgba(255,255,255,0.8),
        inset -5px -5px 10px rgba(120,130,190,0.4),
        4px 5px 12px rgba(150,160,210,0.4);
    }
    .mascot__orbit--1 {
      width: 54px; height: 54px; top: -2px; right: 6px;
      background: radial-gradient(circle at 35% 30%, #d8fceb, var(--mint));
      animation: bob 4.2s var(--spring) infinite; animation-delay: -1s;
    }
    .mascot__orbit--2 {
      width: 40px; height: 40px; bottom: 26px; left: -8px;
      background: radial-gradient(circle at 35% 30%, #ffd6e8, var(--pink));
      animation: bob 4.8s var(--spring) infinite; animation-delay: -2.6s;
    }

    /* ---------- work ---------- */
    .work { margin-top: clamp(30px, 6vw, 70px); }
    .work__head { text-align: center; margin-bottom: 40px; animation: drop-in 0.7s var(--spring) both; }
    .work__head h2 {
      font-family: 'Baloo 2', cursive; font-weight: 700;
      font-size: clamp(1.8rem, 3.6vw, 2.6rem); margin: 0 0 8px; color: var(--ink);
    }
    .work__head p { margin: 0; color: var(--ink-soft); font-weight: 600; }

    .grid {
      list-style: none; margin: 0; padding: 0;
      display: grid; grid-template-columns: repeat(2, 1fr);
      gap: clamp(20px, 3vw, 30px);
    }
    .card {
      --enter-delay: 0s;
      animation: drop-in 0.7s var(--spring) both;
      animation-delay: var(--enter-delay);
    }
    .card:nth-child(1) { --enter-delay: 0.05s; }
    .card:nth-child(2) { --enter-delay: 0.13s; }
    .card:nth-child(3) { --enter-delay: 0.21s; }
    .card:nth-child(4) { --enter-delay: 0.29s; }

    .card__link {
      display: block; text-decoration: none; color: var(--ink);
      background: var(--base);
      border-radius: var(--r-lg);
      padding: 18px;
      box-shadow: var(--clay);
      transition: transform 0.4s var(--spring), box-shadow 0.4s var(--spring);
    }
    .card__link:hover { transform: translateY(-6px) scale(1.015); }
    .card__link:active { transform: translateY(2px) scale(0.99); box-shadow: var(--clay-press); }
    .card__link:focus-visible { outline: 3px solid var(--brand); outline-offset: 4px; }

    .card__thumb {
      border-radius: var(--r-md);
      overflow: hidden;
      aspect-ratio: 16 / 10;
      background:
        radial-gradient(circle at 30% 25%, color-mix(in srgb, var(--tint) 70%, #fff), var(--tint));
      box-shadow:
        inset 6px 6px 12px rgba(255,255,255,0.7),
        inset -7px -7px 14px rgba(120,130,190,0.3);
    }
    .card__thumb img {
      width: 100%; height: 100%; display: block;
      transition: transform 0.5s var(--spring);
    }
    .card__link:hover .card__thumb img { transform: scale(1.05); }
    .card__thumb--block {
      display: block; width: 100%; height: 100%;
      background: var(--brand);
    }

    .card__body { padding: 18px 8px 6px; }
    .card__row { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .card__name {
      font-family: 'Baloo 2', cursive; font-weight: 700;
      font-size: 1.45rem; margin: 0; color: var(--ink);
    }
    .chip {
      font-family: 'Quicksand', sans-serif; font-weight: 700;
      font-size: 0.72rem; white-space: nowrap;
      padding: 6px 13px; border-radius: 999px;
      color: #3c3c5c;
      background: var(--tint);
      box-shadow:
        inset 2px 2px 4px rgba(255,255,255,0.8),
        inset -3px -3px 6px rgba(120,130,190,0.3);
    }
    .card__role {
      font-family: 'Quicksand', sans-serif; font-weight: 700;
      color: var(--brand); margin: 8px 0 12px; font-size: 0.95rem;
    }
    .card__summary {
      margin: 0 0 18px; line-height: 1.62; color: var(--ink-soft);
      font-weight: 500; font-size: 0.98rem;
    }
    .card__go {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: 'Quicksand', sans-serif; font-weight: 700;
      color: var(--ink);
      padding: 10px 20px; border-radius: 999px;
      background: var(--base);
      box-shadow: var(--clay);
      transition: gap 0.35s var(--spring), transform 0.35s var(--spring);
    }
    .card__link:hover .card__go { gap: 13px; transform: translateY(-2px); }

    /* ---------- about ---------- */
    .about { margin-top: clamp(36px, 6vw, 80px); display: flex; justify-content: center; }
    .about__card {
      max-width: 720px; text-align: center;
      background: var(--base);
      border-radius: var(--r-lg);
      padding: clamp(30px, 5vw, 52px);
      box-shadow: var(--clay);
      animation: drop-in 0.7s var(--spring) both;
    }
    .about__card h2 {
      font-family: 'Baloo 2', cursive; font-weight: 700;
      font-size: clamp(1.6rem, 3vw, 2.2rem); margin: 0 0 16px; color: var(--ink);
    }
    .about__card p {
      margin: 0; font-size: 1.12rem; line-height: 1.7;
      color: var(--ink-soft); font-weight: 500;
    }
    .about__card strong {
      color: #d44f7d; font-weight: 700;
      background: rgba(255,179,209,0.4);
      padding: 0 6px; border-radius: 10px;
    }

    /* ---------- footer ---------- */
    .footer {
      margin-top: clamp(40px, 6vw, 80px);
      display: flex; flex-direction: column; align-items: center; gap: 18px;
      text-align: center;
      padding: clamp(30px, 5vw, 48px) 24px;
      border-radius: var(--r-lg);
      background: var(--base);
      box-shadow: var(--clay);
    }
    .footer__mark {
      font-family: 'Baloo 2', cursive; font-weight: 800;
      letter-spacing: 0.08em; font-size: 1.1rem; color: var(--ink);
    }
    .footer__social {
      background: var(--lilac); color: #3a2f6b;
      box-shadow: var(--clay);
    }
    .footer__social:hover { transform: translateY(-3px); }
    .footer__social:active { transform: translateY(1px); box-shadow: var(--clay-press); }
    .footer__note {

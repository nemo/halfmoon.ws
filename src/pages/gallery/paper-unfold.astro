---
import { getCollection } from 'astro:content';
import GalleryShell from '../../layouts/GalleryShell.astro';

const slugMap: Record<string, string> = {
  Pearmill: 'pearmill',
  Suto: 'suto',
  Venio: 'venio',
  'Sound Hallucinations': 'sound-hallucinations',
};

let projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((p) => ({
    name: p.data.name,
    role: p.data.role,
    slug: slugMap[p.data.name] ?? p.slug,
  }));

// Quiet fallback so the page is self-sufficient if the collection is empty.
if (projects.length === 0) {
  projects = [
    { name: 'Pearmill', role: 'Cofounder, President, CTO', slug: 'pearmill' },
    { name: 'Suto', role: 'Cofounder', slug: 'suto' },
    { name: 'Venio', role: 'Founder', slug: 'venio' },
    { name: 'Sound Hallucinations', role: 'Creator / Performer', slug: 'sound-hallucinations' },
  ];
}

const nav = [
  { label: 'Find Me', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Principles', href: '/principles' },
];
---

<GalleryShell title="Nima Gardideh" trend="Paper Unfold">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&family=Newsreader:ital,opsz@0,6..72;1,6..72&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <main class="sheet">
    <!-- the crease: a single soft fold line down the page -->
    <div class="crease" aria-hidden="true"></div>

    <article class="leaf">
      <header class="masthead">
        <p class="domain">halfmoon.ws</p>
        <h1 class="wordmark">Nima&nbsp;Gardideh</h1>
      </header>

      <section class="intro">
        <p class="hero">
          a founder, artist, engineer, and musician
          <span class="place">based in Brooklyn.</span>
        </p>
        <p class="about">I write poetry, build companies, and dance.</p>
      </section>

      <section class="works" aria-label="Projects">
        <ul class="index">
          {projects.map((p) => (
            <li class="entry">
              <a href={`/projects/${p.slug}`}>
                <span class="name">{p.name}</span>
                <span class="rule" aria-hidden="true"></span>
                <span class="role">{p.role}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <footer class="colophon">
        <nav aria-label="Site">
          {nav.map((n) => (
            <a href={n.href}>{n.label}</a>
          ))}
        </nav>
        <a class="social" href="https://x.com/ngardideh" rel="me">@ngardideh</a>
      </footer>
    </article>
  </main>

  <style>
    :root {
      --paper: #f4f0e7;
      --paper-shade: #ebe5d8;
      --ink: #2b2823;
      --ink-soft: #6f685c;
      --ink-faint: #a79f90;
      --fold: rgba(43, 40, 35, 0.07);
    }

    * { box-sizing: border-box; }

    :global(body) {
      margin: 0;
      background-color: var(--paper);
      /* faint paper grain via layered radial noise — quiet, not loud */
      background-image:
        radial-gradient(circle at 18% 22%, rgba(0, 0, 0, 0.012) 0 1px, transparent 1px),
        radial-gradient(circle at 71% 64%, rgba(0, 0, 0, 0.012) 0 1px, transparent 1px),
        radial-gradient(circle at 43% 88%, rgba(0, 0, 0, 0.01) 0 1px, transparent 1px);
      background-size: 7px 7px, 11px 11px, 9px 9px;
      color: var(--ink);
      font-family: 'Newsreader', Georgia, serif;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    .sheet {
      position: relative;
      min-height: 100vh;
      min-height: 100svh;
      display: flex;
      justify-content: center;
      padding: clamp(2.5rem, 9vh, 8rem) clamp(1.5rem, 6vw, 4rem);
      overflow: hidden;
    }

    /* The soft vertical crease — a breath of shadow down the sheet. */
    .crease {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 2px;
      transform: translateX(-50%);
      background: linear-gradient(
        to right,
        transparent,
        var(--fold) 46%,
        rgba(255, 255, 255, 0.38) 54%,
        transparent
      );
      /* fade the crease in at top and bottom so it never hits the edges hard */
      -webkit-mask-image: linear-gradient(to bottom, transparent, #000 18%, #000 82%, transparent);
      mask-image: linear-gradient(to bottom, transparent, #000 18%, #000 82%, transparent);
      opacity: 0;
      animation: crease-open 2800ms cubic-bezier(0.16, 0.84, 0.27, 1) 200ms forwards;
    }

    @keyframes crease-open {
      from { opacity: 0; transform: translateX(-50%) scaleY(0.4); }
      to   { opacity: 0.75; transform: translateX(-50%) scaleY(1); }
    }

    .leaf {
      position: relative;
      width: min(58ch, 100%);
      transform-origin: top center;
      will-change: transform, opacity;
    }

    /* Each band unfolds: tips up from a fold, settles flat. Staggered, slow. */
    .masthead,
    .intro,
    .works,
    .colophon {
      transform-origin: top center;
      opacity: 0;
      animation: unfold 1800ms cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    }

    .masthead { animation-delay: 360ms; }
    .intro    { animation-delay: 900ms; }
    .works    { animation-delay: 1400ms; }
    .colophon { animation-delay: 1920ms; }

    @keyframes unfold {
      0% {
        opacity: 0;
        transform: perspective(1500px) rotateX(-18deg) translateY(6px);
      }
      55% { opacity: 1; }
      100% {
        opacity: 1;
        transform: perspective(1500px) rotateX(0deg) translateY(0);
      }
    }

    /* ---- masthead ---- */
    .masthead { margin-bottom: clamp(3rem, 9vh, 6rem); }

    .domain {
      margin: 0 0 1.4rem;
      font-size: 0.72rem;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: var(--ink-faint);
    }

    .wordmark {
      margin: 0;
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 300;
      font-size: clamp(2.6rem, 7vw, 4.6rem);
      line-height: 1.02;
      letter-spacing: -0.012em;
    }

    /* ---- intro ---- */
    .intro { margin-bottom: clamp(3.2rem, 10vh, 6.5rem); }

    .hero {
      margin: 0 0 1.6rem;
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 300;
      font-style: italic;
      font-size: clamp(1.35rem, 3.1vw, 2rem);
      line-height: 1.42;
      color: var(--ink);
      max-width: 30ch;
    }

    .hero .place { color: var(--ink-soft); }

    .about {
      margin: 0;
      font-size: clamp(1rem, 2vw, 1.18rem);
      line-height: 1.6;
      color: var(--ink-soft);
    }

    /* ---- works / quiet index ---- */
    .works { margin-bottom: clamp(3.2rem, 10vh, 6.5rem); }

    .index {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .entry + .entry { margin-top: 0.2rem; }

    .entry a {
      display: flex;
      align-items: baseline;
      gap: 0.9rem;
      padding: 0.95rem 0;
      text-decoration: none;
      color: var(--ink);
      border-top: 1px solid var(--fold);
      transition: color 600ms ease;
    }

    .entry:last-child a { border-bottom: 1px solid var(--fold); }

    .entry .name {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.1rem, 2.4vw, 1.4rem);
      letter-spacing: -0.005em;
      white-space: nowrap;
    }

    .entry .rule {
      flex: 1 1 auto;
      height: 1px;
      align-self: center;
      background: linear-gradient(to right, var(--fold), transparent);
      opacity: 0.7;
    }

    .entry .role {
      flex: 0 0 auto;
      font-size: 0.86rem;
      letter-spacing: 0.02em;
      color: var(--ink-faint);
      text-align: right;
    }

    .entry a:hover .name,
    .entry a:focus-visible .name { color: var(--ink-soft); }

    .entry a:focus-visible {
      outline: 1px solid var(--ink-faint);
      outline-offset: 4px;
    }

    /* ---- colophon ---- */
    .colophon {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem 1.6rem;
    }

    .colophon nav {
      display: flex;
      flex-wrap: wrap;
      gap: 1.4rem;
    }

    .colophon a {
      font-size: 0.82rem;
      letter-spacing: 0.06em;
      text-decoration: none;
      color: var(--ink-soft);
      transition: color 500ms ease;
    }

    .colophon a:hover,
    .colophon a:focus-visible { color: var(--ink); }

    .colophon .social {
      font-style: italic;
      color: var(--ink-faint);
    }

    /* ---- responsive: the entries stack gently on narrow sheets ---- */
    @media (max-width: 460px) {
      .entry a {
        flex-direction: column;
        gap: 0.3rem;
        align-items: flex-start;
      }
      .entry .rule { display: none; }
      .entry .role { text-align: left; }
      .colophon { flex-direction: column; }
    }

    /* ---- the still, composed fallback ---- */
    @media (prefers-reduced-motion: reduce) {
      .crease,
      .masthead,
      .intro,
      .works,
      .colophon {
        animation: none;
        opacity: 1;
        transform: none;
      }
      .crease { opacity: 0.8; }
    }
  </style>
</GalleryShell>

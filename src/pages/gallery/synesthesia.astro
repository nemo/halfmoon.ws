---
import { getCollection } from 'astro:content';
import GalleryShell from '../../layouts/GalleryShell.astro';

const projectEntries = await getCollection('projects');
const projects = projectEntries
  .map((p) => ({
    slug: p.slug,
    name: p.data.name,
    role: p.data.role,
    period: p.data.period,
    summary: p.data.summary,
    color: p.data.brandColor,
    image: p.data.heroImage ?? null,
    link: p.data.link ?? `/projects/${p.slug}`,
    order: p.data.order,
  }))
  .sort((a, b) => a.order - b.order);

// Each project is a tuned resonator in the field. Pitches chosen as a
// just-intonation chord so struck tones never clash — the field is in tune.
const tuning: Record<string, number> = {
  pearmill: 196.0, // G3 — the root, the longest-running
  suto: 261.63, // C4
  venio: 329.63, // E4
  'sound-hallucinations': 392.0, // G4 — the octave, the loudest bloom
};

const principles = [
  'Life is struggle.',
  'Humans share a collective imagination.',
  'We are moved by the narratives we are told.',
  'Free will is limited — so make the years count.',
];

const navTargets = [
  { label: 'Find Me', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Principles', href: '/principles' },
];

const fieldData = {
  projects: projects.map((p) => ({
    name: p.name,
    role: p.role,
    period: p.period,
    summary: p.summary,
    color: p.color,
    link: p.link,
    image: p.image,
    freq: tuning[p.slug] ?? 220,
  })),
  principles,
};
---

<GalleryShell title="Nima Gardideh" trend="Synesthesia">
  <Fragment slot="head">
    <meta
      name="description"
      content="Nima Gardideh — a founder, artist, engineer, and musician based in Brooklyn. The page hears you."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300&family=Space+Grotesk:wght@300;400;500&family=Space+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <main id="stage" aria-label="An interactive field of sound made visible">
    <!-- The instrument. Looks like sound. Hears the cursor. -->
    <canvas id="field" aria-hidden="true"></canvas>

    <!-- Soft chromatic-aberration veil that breathes with the field -->
    <div class="veil" aria-hidden="true"></div>

    <!-- Persistent, legible scaffolding layered over the living field -->
    <div class="chrome">
      <header class="topbar">
        <div class="sig">
          <span class="dot" aria-hidden="true"></span>
          <span class="who">Nima Gardideh</span>
        </div>
        <nav class="nav" aria-label="Sections">
          {
            navTargets.map((n) => (
              <a class="nav-link" href={n.href}>
                {n.label}
              </a>
            ))
          }
          <a class="nav-link social" href="https://x.com/ngardideh" rel="me noopener" target="_blank"
            >@ngardideh</a
          >
        </nav>
      </header>

      <section class="hero" aria-label="Introduction">
        <p class="kicker">
          <span class="line" aria-hidden="true"></span>
          Sound, made visible
        </p>
        <h1 class="title">
          <span class="hyphen" data-word="founder">founder</span>
          <span class="sep" aria-hidden="true">·</span>
          <span class="hyphen" data-word="artist">artist</span>
          <span class="sep" aria-hidden="true">·</span>
          <span class="hyphen" data-word="engineer">engineer</span>
          <span class="sep" aria-hidden="true">·</span>
          <span class="hyphen" data-word="musician">musician</span>
        </h1>
        <p class="sub">
          a founder, artist, engineer, and musician based in Brooklyn — though home is
          <em>planet earth</em>. Move across the field. It hears you.
        </p>
      </section>

      <!-- Principles surface from the noise like hallucinations, one at a time -->
      <p class="hallucination" id="hallucination" aria-live="off"></p>

      <footer class="bottombar">
        <p class="hint" id="hint">
          <span class="pulse" aria-hidden="true"></span>
          <span class="hint-text">move to play · click a resonator to strike it</span>
        </p>
        <p class="meta">Four resonators, tuned to one chord ↓</p>
      </footer>
    </div>

    <!-- Accessible, real navigable list of projects.
         Visually these become floating resonators painted on the canvas,
         but the markup stays as real, focusable links. -->
    <ul class="resonators" id="resonators" aria-label="Projects">
      {
        projects.map((p, i) => (
          <li class="res" style={`--c:${p.color}`}>
            <a
              class="res-link"
              href={p.link}
              data-index={i}
              data-name={p.name}
              rel={p.link.startsWith('http') ? 'noopener' : undefined}
              target={p.link.startsWith('http') ? '_blank' : undefined}
            >
              <span class="res-orb" aria-hidden="true" />
              <span class="res-body">
                <span class="res-name">{p.name}</span>
                <span class="res-role">
                  {p.role} · {p.period}
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Calm, fully legible fallback for reduced motion / no JS -->
    <noscript>
      <style>
        #field,
        .veil,
        .hint {
          display: none !important;
        }
      </style>
    </noscript>
  </main>

  <script
    is:inline
    type="application/json"
    id="field-data"
    set:html={JSON.stringify(fieldData)}
  />

  <style>
    :root {
      --bg: #05060a;
      --ink: #f4f1ea;
      --dim: rgba(244, 241, 234, 0.5);
      --faint: rgba(244, 241, 234, 0.22);
      --hair: rgba(244, 241, 234, 0.12);
      --serif: 'Fraunces', Georgia, serif;
      --sans: 'Space Grotesk', system-ui, sans-serif;
      --mono: 'Space Mono', 'SF Mono', ui-monospace, monospace;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--ink);
      font-family: var(--sans);
      overflow: hidden;
      height: 100%;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    #stage {
      position: fixed;
      inset: 0;
      cursor: none;
    }
    @media (pointer: coarse) {
      #stage {
        cursor: auto;
      }
    }

    #field {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
      /* The plate itself — a deep indigo void with a faint horizon glow */
      background:
        radial-gradient(120% 80% at 50% 120%, rgba(122, 77, 255, 0.16), transparent 60%),
        radial-gradient(90% 60% at 50% -10%, rgba(0, 184, 148, 0.07), transparent 55%),
        var(--bg);
    }

    .veil {
      position: absolute;
      inset: 0;
      pointer-events: none;
      mix-blend-mode: screen;
      opacity: 0.5;
      background:
        radial-gradient(60% 40% at var(--mx, 50%) var(--my, 45%), rgba(108, 92, 231, 0.1), transparent 70%);
      transition: background 0.35s ease;
    }

    /* Grain + a vignette so the field reads as projected light in a dark room */
    .veil::after {
      content: '';
      position: absolute;
      inset: 0;
      box-shadow: inset 0 0 220px 60px rgba(0, 0, 0, 0.75);
    }

    .chrome {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      padding: clamp(18px, 3.2vw, 40px);
      pointer-events: none;
      z-index: 3;
    }
    .chrome a,
    .chrome button {
      pointer-events: auto;
    }

    /* ---- top bar ---- */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .sig {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: #7a4dff;
      box-shadow: 0 0 0 0 rgba(122, 77, 255, 0.6);
      animation: beat 3.4s ease-in-out infinite;
    }
    @keyframes beat {
      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(122, 77, 255, 0.5);
      }
      50% {
        box-shadow: 0 0 0 9px rgba(122, 77, 255, 0);
      }
    }
    .who {
      font-family: var(--mono);
      font-size: 12.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--dim);
    }
    .nav {
      display: flex;
      align-items: center;
      gap: clamp(12px, 1.8vw, 26px);
      flex-wrap: wrap;
    }
    .nav-link {
      color: var(--dim);
      text-decoration: none;
      font-size: 13px;
      letter-spacing: 0.04em;
      position: relative;
      transition: color 0.25s ease;
      white-space: nowrap;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -4px;
      width: 0;
      height: 1px;
      background: currentColor;
      transition: width 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .nav-link:hover,
    .nav-link:focus-visible {
      color: var(--ink);
    }
    .nav-link:hover::after,
    .nav-link:focus-visible::after {
      width: 100%;
    }
    .nav-link.social {
      color: var(--faint);
      font-family: var(--mono);
    }

    /* ---- hero ---- */
    .hero {
      position: relative;
      margin-top: auto;
      margin-bottom: auto;
      max-width: 18ch;
      max-width: min(880px, 92vw);
    }
    /* soft directional scrim so the identity statement always reads as the
       loudest thing on the plate, no matter what the field does behind it */
    .hero::before {
      content: '';
      position: absolute;
      inset: -10% -10% -10% -60%;
      background: radial-gradient(
        85% 95% at 28% 50%,
        rgba(4, 5, 9, 0.78),
        rgba(4, 5, 9, 0.4) 50%,
        transparent 78%
      );
      pointer-events: none;
      z-index: -1;
    }
    .kicker {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 0 0 18px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: var(--faint);
    }
    .kicker .line {
      width: clamp(26px, 5vw, 60px);
      height: 1px;
      background: var(--hair);
    }
    .title {
      font-family: var(--serif);
      font-weight: 300;
      font-size: clamp(2.6rem, 9.2vw, 7.4rem);
      line-height: 0.94;
      letter-spacing: -0.02em;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0 0.3em;
      text-wrap: balance;
      text-shadow: 0 2px 40px rgba(4, 5, 9, 0.9), 0 0 2px rgba(4, 5, 9, 0.8);
    }
    .title .hyphen {
      position: relative;
      transition:
        opacity 0.5s ease,
        filter 0.5s ease;
      will-change: opacity, filter;
    }
    .title .sep {
      color: var(--faint);
      font-size: 0.55em;
      transform: translateY(-0.1em);
    }
    .sub {
      margin: clamp(22px, 3vw, 34px) 0 0;
      max-width: 46ch;
      font-size: clamp(0.98rem, 1.3vw, 1.18rem);
      line-height: 1.55;
      color: var(--dim);
      font-weight: 300;
    }
    .sub em {
      font-style: normal;
      color: var(--ink);
      border-bottom: 1px solid var(--hair);
      padding-bottom: 1px;
    }

    /* ---- hallucinated principle ---- */
    .hallucination {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      margin: 0;
      max-width: min(720px, 86vw);
      text-align: center;
      font-family: var(--serif);
      font-style: italic;
      font-weight: 300;
      font-size: clamp(1.3rem, 3.4vw, 2.6rem);
      line-height: 1.3;
      letter-spacing: -0.01em;
      color: rgba(244, 241, 234, 0.92);
      opacity: 0;
      filter: blur(14px);
      pointer-events: none;
      text-shadow: 0 0 40px rgba(122, 77, 255, 0.35);
      transition:
        opacity 1.6s ease,
        filter 1.6s ease;
    }
    .hallucination.show {
      opacity: 1;
      filter: blur(0);
    }

    /* ---- bottom bar ---- */
    .bottombar {
      margin-top: auto;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .hint {
      margin: 0;
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--faint);
    }
    .pulse {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--ink);
      opacity: 0.7;
      animation: blip 1.8s ease-in-out infinite;
    }
    @keyframes blip {
      0%,
      100% {
        opacity: 0.2;
        transform: scale(1);
      }
      50% {
        opacity: 0.9;
        transform: scale(1.5);
      }
    }
    .meta {
      margin: 0;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--faint);
    }

    /* ---- resonators (the projects) ---- */
    .resonators {
      position: absolute;
      list-style: none;
      margin: 0;
      padding: 0;
      inset: 0;
      z-index: 2;
      pointer-events: none;
    }
    .res {
      position: absolute;
      pointer-events: none;
      transform: translate(-50%, -50%);
      will-change: left, top;
    }
    .res-link {
      pointer-events: auto;
      display: flex;
      align-items: center;
      gap: 13px;
      text-decoration: none;
      color: var(--ink);
      padding: 10px 16px 10px 10px;
      border-radius: 999px;
      background: rgba(8, 9, 16, 0.32);
      border: 1px solid var(--hair);
      backdrop-filter: blur(7px);
      -webkit-backdrop-filter: blur(7px);
      transition:
        transform 0.4s cubic-bezier(0.2, 0.9, 0.2, 1),
        border-color 0.35s ease,
        background 0.35s ease,
        box-shadow 0.35s ease;
    }
    .res-link:hover,
    .res-link:focus-visible {
      transform: scale(1.05);
      border-color: color-mix(in oklab, var(--c) 70%, transparent);
      background: rgba(8, 9, 16, 0.6);
      box-shadow:
        0 0 0 1px color-mix(in oklab, var(--c) 40%, transparent),
        0 14px 60px color-mix(in oklab, var(--c) 45%, transparent);
      outline: none;
    }
    .res-orb {
      flex: 0 0 auto;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 30%, #fff, var(--c) 55%, color-mix(in oklab, var(--c) 50%, #000) 100%);
      box-shadow:
        0 0 18px color-mix(in oklab, var(--c) 70%, transparent),
        inset 0 0 8px rgba(255, 255, 255, 0.4);
      position: relative;
    }
    .res-orb::after {
      content: '';
      position: absolute;
      inset: -8px;
      border-radius: 50%;
      border: 1px solid color-mix(in oklab, var(--c) 50%, transparent);
      opacity: 0.5;
      animation: ring 4s ease-out infinite;
    }
    @keyframes ring {
      0% {
        transform: scale(0.8);
        opacity: 0.55;
      }
      100% {
        transform: scale(1.7);
        opacity: 0;
      }
    }
    .res-body {
      display: flex;
      flex-direction: column;
      line-height: 1.15;
      max-width: 0;
      overflow: hidden;
      white-space: nowrap;
      opacity: 0;
      transition:
        max-width 0.45s cubic-bezier(0.2, 0.9, 0.2, 1),
        opacity 0.35s ease;
    }
    .res-link:hover .res-body,
    .res-link:focus-visible .res-body,
    .res.near .res-body {
      max-width: 240px;
      opacity: 1;
    }
    .res-name {
      font-family: var(--serif);
      font-size: 1.06rem;
      font-weight: 400;
    }
    .res-role {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.06em;
      color: var(--dim);
      text-transform: uppercase;
      margin-top: 3px;
    }

    /* custom cursor — a soft sound source */
    .cursor {
      position: fixed;
      top: 0;
      left: 0;
      width: 14px;
      height: 14px;
      margin: -7px 0 0 -7px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.95), rgba(122, 77, 255, 0.4) 60%, transparent 75%);
      pointer-events: none;
      z-index: 5;
      mix-blend-mode: screen;
      transition: transform 0.18s ease;
    }
    .cursor.struck {
      transform: scale(2.4);
    }
    @media (pointer: coarse) {
      .cursor {
        display: none;
      }
    }

    /* ---- responsive ---- */
    @media (max-width: 720px) {
      .chrome {
        padding: 16px;
      }
      .who {
        display: none;
      }
      .nav {
        gap: 12px;
        font-size: 12px;
      }
      .nav-link {
        font-size: 12px;
      }
      .hero {
        margin-top: 96px;
        margin-bottom: 0;
      }
      .sub {
        font-size: 0.96rem;
      }
      /* On small screens, stop floating the resonators and stack them
         as a legible tray so they remain tappable + readable. */
      .resonators {
        position: absolute;
        inset: auto 0 0 0;
        top: auto;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 14px 16px 84px;
        background: linear-gradient(to top, rgba(5, 6, 10, 0.92), transparent);
        pointer-events: auto;
      }
      .res {
        position: static;
        transform: none;
      }
      .res-body {
        max-width: 240px;
        opacity: 1;
      }
      .res-role {
        display: none;
      }
      .bottombar {
        display: none;
      }
      .hallucination {
        top: 42%;
      }
    }

    /* ---- reduced motion: a calm, fully legible still ---- */
    @media (prefers-reduced-motion: reduce) {
      #stage {
        cursor: auto;
      }
      .dot,
      .pulse,
      .res-orb::after {
        animation: none !important;
      }
      .cursor {
        display: none !important;
      }
      .hallucination {
        transition-duration: 0.6s;
      }
    }
  </style>

  <script>
    type Project = {
      name: string;
      role: string;
      period: string;
      summary: string;
      color: string;
      link: string;
      image: string | null;
      freq: number;
    };
    type FieldData = { projects: Project[]; principles: string[] };

    const dataEl = document.getElementById('field-data');
    const DATA: FieldData = dataEl ? JSON.parse(dataEl.textContent || '{}') : { projects: [], principles: [] };

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const coarse = window.matchMedia('(pointer: coarse)').matches;

    const canvas = document.getElementById('field') as HTMLCanvasElement | null;
    const stage = document.getElementById('stage') as HTMLElement | null;
    const veil = document.querySelector('.veil') as HTMLElement | null;
    const hallucEl = document.getElementById('hallucination') as HTMLElement | null;
    const hyphens = Array.from(document.querySelectorAll<HTMLElement>('.title .hyphen'));
    const resEls = Array.from(document.querySelectorAll<HTMLElement>('.res'));
    const resLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.res-link'));
    const hintEl = document.getElementById('hint');

    if (!canvas || !stage) {
      // Nothing to enhance; the static chrome is the fallback.
    } else {
      const cv: HTMLCanvasElement = canvas;
      const ctx = cv.getContext('2d', { alpha: true })!;

      // ---------- hex helpers ----------
      function hexToRgb(hex: string) {
        let h = hex.replace('#', '');
        if (h.length === 3) h = h.split('').map((c) => c + c).join('');
        const n = parseInt(h, 16);
        return { r: (n >> 16) & 255, g: (n >> 8) & 255, b: n & 255 };
      }
      const projColors = DATA.projects.map((p) => hexToRgb(p.color));

      // ---------- sizing ----------
      let W = 0,
        H = 0,
        DPR = 1;
      function resize() {
        DPR = Math.min(window.devicePixelRatio || 1, 2);
        W = window.innerWidth;
        H = window.innerHeight;
        cv.width = Math.floor(W * DPR);
        cv.height = Math.floor(H * DPR);
        cv.style.width = W + 'px';
        cv.style.height = H + 'px';
        ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
        placeResonators();
      }

      // ---------- the field: a coarse grid of standing-wave samples ----------
      // We sample a wave-interference field on a grid and paint it as soft
      // additive blobs — cymatics / sand-on-a-plate, sound made visible.
      const STEP = Math.max(14, Math.min(26, Math.round(Math.min(W, H) / 46))) || 20;

      // Resonator positions (normalized 0..1), spread across the field.
      // Pearmill (root) sits lowest/largest; SH (octave) highest.
      const resonators = DATA.projects.map((p, i) => {
        const n = DATA.projects.length;
        return {
          ...p,
          rgb: projColors[i],
          // arrange on a gentle arc
          nx: 0.5 + Math.cos((i / Math.max(1, n - 1)) * Math.PI - Math.PI / 2) * 0.34,
          ny: 0.34 + (i / Math.max(1, n - 1)) * 0.32,
          x: 0,
          y: 0,
          phase: Math.random() * Math.PI * 2,
          energy: 0, // pops on strike
        };
      });

      function placeResonators() {
        resonators.forEach((r, i) => {
          r.x = r.nx * W;
          r.y = r.ny * H;
          const el = resEls[i];
          if (el && !coarse) {
            el.style.left = r.x + 'px';
            el.style.top = r.y + 'px';
          }
        });
      }

      // pointer = the player's hand. Eased so the field feels like it "follows".
      const pointer = { x: W / 2, y: H * 0.5, tx: W / 2, ty: H * 0.5, speed: 0, down: 0 };

      // transient ripples (from clicks / strikes) — expanding rings
      type Ripple = { x: number; y: number; t: number; life: number; rgb: { r: number; g: number; b: number }; amp: number };
      const ripples: Ripple[] = [];

      // ---------- audio (gated on first gesture) ----------
      let audio: AudioContext | null = null;
      let master: GainNode | null = null;
      let drone: { osc: OscillatorNode; gain: GainNode; filt: BiquadFilterNode } | null = null;
      let started = false;

      function startAudio() {
        if (started || reduced) return;
        started = true;
        try {
          const AC = window.AudioContext || (window as any).webkitAudioContext;
          audio = new AC();
          master = audio.createGain();
          master.gain.value = 0.0;
          master.connect(audio.destination);
          // gentle fade-in so silence -> sound is a swell, not a click
          master.gain.linearRampToValueAtTime(0.5, audio.currentTime + 1.6);

          // a low drone whose pitch bends with the cursor's height
          const osc = audio.createOscillator();
          osc.type = 'sine';
          osc.frequency.value = 98; // G2 — under everything
          const sub = audio.createGain();
          sub.gain.value = 0.16;
          const filt = audio.createBiquadFilter();
          filt.type = 'lowpass';
          filt.frequency.value = 600;
          filt.Q.value = 0.7;
          osc.connect(filt);
          filt.connect(sub);
          sub.connect(master);
          osc.start();
          drone = { osc, gain: sub, filt };
        } catch (e) {
          /* audio optional */
        }
        if (hintEl) {
          const t = hintEl.querySelector('.hint-text');
          if (t) t.textContent = 'now it hears you · click a resonator to strike it';
        }
      }

      // struck tone for a resonator — a plucked, decaying sine+triangle
      function strike(freq: number, gainScale = 1) {
        if (!audio || !master) return;
        const now = audio.currentTime;
        const g = audio.createGain();
        g.gain.setValueAtTime(0.0001, now);
        g.gain.exponentialRampToValueAtTime(0.32 * gainScale, now + 0.012);
        g.gain.exponentialRampToValueAtTime(0.0001, now + 2.4);
        const o1 = audio.createOscillator();
        o1.type = 'sine';
        o1.frequency.value = freq;
        const o2 = audio.createOscillator();
        o2.type = 'triangle';
        o2.frequency.value = freq * 2.001;
        const og = audio.createGain();
        og.gain.value = 0.35;
        o2.connect(og);
        og.connect(g);
        o1.connect(g);
        g.connect(master);
        o1.start(now);
        o2.start(now);
        o1.stop(now + 2.5);
        o2.stop(now + 2.5);
      }

      function softTone(freq: number) {
        // tiny grace note when cursor passes through a resonator
        if (!audio || !master) return;
        const now = audio.currentTime;
        const g = audio.createGain();
        g.gain.setValueAtTime(0.0001, now);
        g.gain.exponentialRampToValueAtTime(0.05, now + 0.04);
        g.gain.exponentialRampToValueAtTime(0.0001, now + 0.9);
        const o = audio.createOscillator();
        o.type = 'sine';
        o.frequency.value = freq;
        o.connect(g);
        g.connect(master);
        o.start(now);
        o.stop(now + 1);
      }

      // ---------- strike: the unforgettable moment ----------
      const cursorEl = document.createElement('div');
      cursorEl.className = 'cursor';
      if (!coarse && !reduced) document.body.appendChild(cursorEl);

      function detonate(r: (typeof resonators)[number]) {
        // visible ripple across the whole field + audible struck tone
        ripples.push({ x: r.x, y: r.y, t: 0, life: 1, rgb: r.rgb, amp: 1 });
        ripples.push({ x: r.x, y: r.y, t: -0.18, life: 1, rgb: r.rgb, amp: 0.6 });
        r.energy = 1;
        strike(r.freq, 1);
        // chromatic bloom flash on the veil
        if (veil) {
          veil.style.transition = 'none';
          veil.style.background = `radial-gradient(120% 120% at ${(r.x / W) * 100}% ${(r.y / H) * 100}%, rgba(${r.rgb.r},${r.rgb.g},${r.rgb.b},0.5), transparent 60%)`;
          requestAnimationFrame(() => {
            veil!.style.transition = 'background 1.4s ease';
            veil!.style.background = '';
          });
        }
        cursorEl.classList.add('struck');
        setTimeout(() => cursorEl.classList.remove('struck'), 220);
      }

      resLinks.forEach((link, i) => {
        link.addEventListener('pointerdown', () => {
          startAudio();
          const r = resonators[i];
          if (r) detonate(r);
        });
        // keyboard activation should also ripple
        link.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            startAudio();
            const r = resonators[i];
            if (r) detonate(r);
          }
        });
      });

      // ---------- input ----------
      let lastTone = 0;
      function onMove(x: number, y: number) {
        pointer.tx = x;
        pointer.ty = y;
        if (veil) {
          veil.style.setProperty('--mx', (x / W) * 100 + '%');
          veil.style.setProperty('--my', (y / H) * 100 + '%');
        }
        if (cursorEl) {
          cursorEl.style.transform = `translate(${x}px, ${y}px)`;
        }
        // bend the drone pitch with vertical position (low at bottom, high at top)
        if (drone && audio) {
          const target = 78 + (1 - y / H) * 64;
          drone.osc.frequency.setTargetAtTime(target, audio.currentTime, 0.25);
          drone.filt.frequency.setTargetAtTime(380 + pointer.speed * 14, audio.currentTime, 0.2);
        }
      }

      window.addEventListener(
        'pointermove',
        (e) => {
          onMove(e.clientX, e.clientY);
        },
        { passive: true }
      );

      // first gesture anywhere wakes the sound
      window.addEventListener('pointerdown', startAudio, { once: false });
      window.addEventListener('keydown', startAudio, { once: true });

      // ---------- title words react like antinodes ----------
      let phraseT = 0;

      // ---------- hallucinated principles cycle ----------
      let pIndex = 0;
      function cycleHallucination() {
        if (!hallucEl || DATA.principles.length === 0) return;
        hallucEl.textContent = DATA.principles[pIndex % DATA.principles.length];
        hallucEl.classList.add('show');
        setTimeout(() => hallucEl.classList.remove('show'), 4200);
        pIndex++;
      }

      // ---------- reduced-motion path: paint one gorgeous still, no loop ----------
      function paintStill() {
        ctx.clearRect(0, 0, W, H);
        for (let y = 0; y < H; y += STEP) {
          for (let x = 0; x < W; x += STEP) {
            let v = 0;
            for (const r of resonators) {
              const dx = x - r.x;
              const dy = y - r.y;
              const d = Math.sqrt(dx * dx + dy * dy);
              v += Math.cos(d * 0.018) * Math.exp(-d * 0.0016);
            }
            const a = Math.max(0, v) * 0.16;
            if (a < 0.02) continue;
            ctx.fillStyle = `rgba(160,150,230,${a})`;
            ctx.beginPath();
            ctx.arc(x, y, STEP * 0.42, 0, Math.PI * 2);
            ctx.fill();
          }
        }
        // bright resonator cores
        for (const r of resonators) {
          const grd = ctx.createRadialGradient(r.x, r.y, 0, r.x, r.y, 70);
          grd.addColorStop(0, `rgba(${r.rgb.r},${r.rgb.g},${r.rgb.b},0.5)`);
          grd.addColorStop(1, 'transparent');
          ctx.fillStyle = grd;
          ctx.fillRect(r.x - 70, r.y - 70, 140, 140);
        }
      }

      // ---------- main render loop ----------
      let raf = 0;
      let time = 0;

      function frame(ts: number) {
        time = ts / 1000;

        // ease the pointer for that "the field follows your hand" feel
        const px = pointer.x,
          py = pointer.y;
        pointer.x += (pointer.tx - pointer.x) * 0.12;
        pointer.y += (pointer.ty - pointer.y) * 0.12;
        const dpx = pointer.x - px,
          dpy = pointer.y - py;
        pointer.speed += (Math.sqrt(dpx * dpx + dpy * dpy) - pointer.speed) * 0.15;

        // fade-trail compositing: paint a translucent black so motion leaves wakes
        ctx.globalCompositeOperation = 'source-over';
        ctx.fillStyle = 'rgba(5,6,10,0.20)';
        ctx.fillRect(0, 0, W, H);

        // advance ripples
        for (let i = ripples.length - 1; i >= 0; i--) {
          ripples[i].t += 0.016;
          if (ripples[i].t > 1.8) ripples.splice(i, 1);
        }

        // additive light
        ctx.globalCompositeOperation = 'lighter';

        const t = time;
        const moveAmp = Math.min(1, pointer.speed * 0.06);

        // A horizontal corridor down the left where the hero type lives —
        // we suppress field brightness here so the identity statement always
        // reads. Sound still ripples through it, just dimmer (a "quiet zone").
        const typeGuardX = Math.min(W * 0.66, 900);
        const typeGuardTop = H * 0.2;
        const typeGuardBot = H * 0.78;

        // The interference field. Cursor is a live source; resonators are
        // standing sources; ripples are transient sources. We accumulate a
        // *chromatic* weighted color and keep luminance disciplined so the
        // field glows in saturated color instead of blowing out to white.
        for (let y = 0; y < H; y += STEP) {
          for (let x = 0; x < W; x += STEP) {
            let v = 0;
            // weighted color accumulators (no grey base — start from black,
            // so hue comes purely from the resonators bleeding through)
            let cr = 0,
              cg = 0,
              cb = 0;
            let colW = 0;

            // resonator standing waves
            for (const r of resonators) {
              const dx = x - r.x;
              const dy = y - r.y;
              const d = Math.sqrt(dx * dx + dy * dy);
              const wave = Math.cos(d * 0.02 - t * 1.4 + r.phase) * Math.exp(-d * 0.0018);
              const e = wave + r.energy * Math.cos(d * 0.05 - t * 7) * Math.exp(-d * 0.004);
              v += e;
              const w = Math.max(0, e) * (0.7 + r.energy * 2.2);
              cr += r.rgb.r * w;
              cg += r.rgb.g * w;
              cb += r.rgb.b * w;
              colW += w;
            }

            // the cursor as a roving source — a cool white-violet spark
            {
              const dx = x - pointer.x;
              const dy = y - pointer.y;
              const d = Math.sqrt(dx * dx + dy * dy);
              const wave =
                Math.cos(d * 0.028 - t * 3.2) * Math.exp(-d * 0.0024) * (0.4 + moveAmp * 1.7);
              v += wave;
              const w = Math.max(0, wave);
              cr += 150 * w;
              cg += 130 * w;
              cb += 255 * w;
              colW += w;
            }

            // transient ripple rings from strikes
            for (const rp of ripples) {
              if (rp.t < 0) continue;
              const dx = x - rp.x;
              const dy = y - rp.y;
              const d = Math.sqrt(dx * dx + dy * dy);
              const radius = rp.t * 900;
              const band = Math.exp(-((d - radius) * (d - radius)) * 0.00035);
              const fade = 1 - rp.t / 1.8;
              const e = band * fade * rp.amp * 2.4;
              v += e;
              cr += rp.rgb.r * e * 1.4;
              cg += rp.rgb.g * e * 1.4;
              cb += rp.rgb.b * e * 1.4;
              colW += e;
            }

            let inten = Math.max(0, v);
            if (inten < 0.05) continue;

            // protect the type corridor: fade field down where the hero sits
            if (x < typeGuardX && y > typeGuardTop && y < typeGuardBot) {
              const edge = 1 - x / typeGuardX; // 1 at far left, 0 at corridor edge
              // also taper vertically so the dimming hugs the text band
              const yc = (y - typeGuardTop) / (typeGuardBot - typeGuardTop); // 0..1
              const yband = 1 - Math.abs(yc - 0.5) * 1.4; // strongest mid-band
              inten *= 1 - edge * Math.max(0, yband) * 0.7;
              if (inten < 0.05) continue;
            }

            // hue comes from the weighted resonator color; normalize so it
            // stays a *color* rather than averaging up to white
            let rr, gg, bb;
            if (colW > 0) {
              rr = cr / colW;
              gg = cg / colW;
              bb = cb / colW;
            } else {
              rr = 120;
              gg = 110;
              bb = 200;
            }
            // push intensity into the color as a controlled lift toward its
            // own bright tint (not pure white) — keeps saturation at peaks
            const lift = Math.min(1, inten * 0.5);
            rr = rr + (255 - rr) * lift * 0.55;
            gg = gg + (255 - gg) * lift * 0.55;
            bb = bb + (255 - bb) * lift * 0.55;

            const a = Math.min(0.78, inten * 0.3);
            const rad = STEP * (0.32 + Math.min(1, inten) * 0.26);
            ctx.fillStyle = `rgba(${rr | 0},${gg | 0},${bb | 0},${a})`;
            ctx.beginPath();
            ctx.arc(x, y, rad, 0, Math.PI * 2);
            ctx.fill();
          }
        }

        // resonator cores: bright struck orbs that pulse with energy
        for (const r of resonators) {
          r.energy *= 0.94;
          const glow = 28 + r.energy * 90;
          const grd = ctx.createRadialGradient(r.x, r.y, 0, r.x, r.y, glow);
          grd.addColorStop(0, `rgba(${r.rgb.r},${r.rgb.g},${r.rgb.b},${0.55 + r.energy * 0.4})`);
          grd.addColorStop(1, 'transparent');
          ctx.fillStyle = grd;
          ctx.fillRect(r.x - glow, r.y - glow, glow * 2, glow * 2);
        }

        // ---- identity words brighten as waves wash over them (antinodes) ----
        for (const span of hyphens) {
          const rect = span.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          const dx = cx - pointer.x;
          const dy = cy - pointer.y;
          const d = Math.sqrt(dx * dx + dy * dy);
          const near = Math.max(0, 1 - d / 360);
          const shimmer = (Math.cos(d * 0.02 - t * 1.4) + 1) / 2;
          const lit = 0.55 + near * 0.45 + shimmer * 0.12 * near;
          span.style.opacity = String(Math.min(1, lit));
          span.style.filter = near > 0.05 ? `blur(0px) drop-shadow(0 0 ${near * 22}px rgba(122,77,255,${near * 0.7}))` : 'none';
        }

        // ---- cursor passing through a resonator plays a soft grace note + reveals label ----
        for (let i = 0; i < resonators.length; i++) {
          const r = resonators[i];
          const dx = r.x - pointer.x;
          const dy = r.y - pointer.y;
          const d = Math.sqrt(dx * dx + dy * dy);
          const el = resEls[i];
          if (el) el.classList.toggle('near', d < 120 && !coarse);
          if (d < 64 && started && ts - lastTone > 420) {
            softTone(r.freq);
            r.energy = Math.max(r.energy, 0.4);
            ripples.push({ x: r.x, y: r.y, t: 0, life: 1, rgb: r.rgb, amp: 0.4 });
            lastTone = ts;
          }
        }

        raf = requestAnimationFrame(frame);
      }

      // ---------- boot ----------
      resize();
      window.addEventListener('resize', resize);

      if (reduced) {
        paintStill();
        // still let principles surface, calmly
        cycleHallucination();
        setInterval(cycleHallucination, 9000);
        // strikes still flash quietly without the loop
        resLinks.forEach((link, i) => {
          link.addEventListener('pointerdown', () => {
            const r = resonators[i];
            if (r) {
              r.energy = 1;
              paintStill();
            }
          });
        });
      } else {
        raf = requestAnimationFrame(frame);
        // begin the hallucination cycle after a beat
        setTimeout(cycleHallucination, 5200);
        setInterval(cycleHallucination, 12000);
        // give first-time visitors a tiny self-playing intro ripple so the
        // initial paint is alive even before they move
        setTimeout(() => {
          if (resonators[0]) {
            ripples.push({ x: resonators[0].x, y: resonators[0].y, t: 0, life: 1, rgb: resonators[0].rgb, amp: 0.5 });
            resonators[0].energy = 0.6;
          }
        }, 900);
      }

      window.addEventListener('beforeunload', () => {
        cancelAnimationFrame(raf);
        if (audio) audio.close();
      });
    }
  </script>
</GalleryShell>

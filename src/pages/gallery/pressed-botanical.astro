---
import GalleryShell from '../../layouts/GalleryShell.astro';
import { getCollection } from 'astro:content';

const slugMap: Record<string, string> = {
  pearmill: 'pearmill',
  suto: 'suto',
  venio: 'venio',
  'sound-hallucinations': 'sound-hallucinations',
};

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((p) => ({
    name: p.data.name,
    role: p.data.role,
    period: p.data.period,
    slug: `/projects/${slugMap[p.slug] ?? p.slug}`,
  }));
---

<GalleryShell title="Nima Gardideh" trend="Pressed Botanical">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=EB+Garamond:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <main class="page">
    <!-- Top archival rule + filing line -->
    <header class="masthead">
      <div class="rule rule--top"></div>
      <div class="filing">
        <span class="filing__cat">Herbarium</span>
        <span class="filing__sep">·</span>
        <span>halfmoon.ws</span>
        <span class="filing__sep">·</span>
        <span class="filing__loc">Brooklyn, NY</span>
      </div>
    </header>

    <section class="plate">
      <!-- The single motif: a pressed sprig, drawn slowly -->
      <figure class="specimen" aria-hidden="true">
        <svg viewBox="0 0 200 460" class="sprig" role="presentation">
          <g class="stem-group">
            <path
              class="stroke stem"
              d="M100 450 C 100 360, 98 280, 100 210 C 102 150, 100 90, 100 30"
              fill="none"
            />
            <!-- leaves, paired, fanning up the stem -->
            <path class="stroke leaf l1" d="M100 380 C 70 372, 52 350, 50 322 C 78 330, 96 352, 100 380 Z" />
            <path class="stroke leaf l2" d="M100 350 C 130 342, 148 320, 150 292 C 122 300, 104 322, 100 350 Z" />
            <path class="stroke leaf l3" d="M100 300 C 74 294, 60 276, 58 254 C 82 260, 96 278, 100 300 Z" />
            <path class="stroke leaf l4" d="M100 272 C 126 266, 140 248, 142 226 C 118 232, 104 250, 100 272 Z" />
            <!-- blossom at the crown -->
            <g class="bloom">
              <path class="stroke petal" d="M100 30 C 86 18, 86 2, 100 -6 C 114 2, 114 18, 100 30 Z" transform="rotate(0 100 18)" />
              <path class="stroke petal" d="M100 30 C 86 18, 86 2, 100 -6 C 114 2, 114 18, 100 30 Z" transform="rotate(72 100 18)" />
              <path class="stroke petal" d="M100 30 C 86 18, 86 2, 100 -6 C 114 2, 114 18, 100 30 Z" transform="rotate(144 100 18)" />
              <path class="stroke petal" d="M100 30 C 86 18, 86 2, 100 -6 C 114 2, 114 18, 100 30 Z" transform="rotate(216 100 18)" />
              <path class="stroke petal" d="M100 30 C 86 18, 86 2, 100 -6 C 114 2, 114 18, 100 30 Z" transform="rotate(288 100 18)" />
              <circle class="stroke pollen" cx="100" cy="18" r="4" />
            </g>
          </g>
        </svg>
      </figure>

      <!-- The words: the design proper -->
      <div class="text">
        <p class="eyebrow">Specimen no. 1 — Self</p>
        <h1 class="name">Nima Gardideh</h1>
        <p class="hero">
          a founder, artist, engineer, and musician
          <br class="hero__br" />based in Brooklyn.
        </p>
        <p class="about"><em>I write poetry, build companies, and dance.</em></p>
      </div>
    </section>

    <!-- Quiet index of works, as pressed labels -->
    <section class="register">
      <div class="rule"></div>
      <h2 class="register__title">Collected works</h2>
      <ul class="works">
        {projects.map((p) => (
          <li class="work">
            <a class="work__link" href={p.slug}>
              <span class="work__name">{p.name}</span>
              <span class="work__role">{p.role}</span>
              <span class="work__period">{p.period}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <footer class="colophon">
      <div class="rule"></div>
      <nav class="nav" aria-label="Sections">
        <a href="/about">Find Me</a>
        <a href="/projects">Projects</a>
        <a href="/blog">Blog</a>
        <a href="/principles">Principles</a>
        <a href="https://x.com/ngardideh" rel="me noopener" target="_blank">@ngardideh</a>
      </nav>
      <p class="mark">Pressed &amp; mounted at halfmoon.ws — MMXXVI</p>
    </footer>
  </main>

  <style>
    :root {
      --paper: #f4f1ea;
      --paper-deep: #ece7db;
      --ink: #2c2a25;
      --ink-soft: #6f6a5f;
      --hair: #c9c2b2;
      --accent: #6d7a5e; /* dried sage */
      --serif: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
      --serif-body: 'EB Garamond', Georgia, serif;
    }

    * { box-sizing: border-box; }

    :global(body) {
      margin: 0;
      background: var(--paper);
      background-image:
        radial-gradient(circle at 18% 22%, rgba(0,0,0,0.015) 0, transparent 60%),
        radial-gradient(circle at 82% 78%, rgba(0,0,0,0.02) 0, transparent 55%);
      color: var(--ink);
      font-family: var(--serif-body);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    .page {
      max-width: 980px;
      margin: 0 auto;
      padding: clamp(2.5rem, 6vw, 5.5rem) clamp(1.5rem, 6vw, 4rem) 4rem;
    }

    .rule {
      height: 1px;
      background: var(--hair);
      width: 100%;
    }
    .rule--top { margin-bottom: 1rem; }

    /* Masthead filing line */
    .masthead { margin-bottom: clamp(3rem, 9vw, 6rem); }
    .filing {
      font-family: var(--serif-body);
      font-size: 0.72rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--ink-soft);
      display: flex;
      gap: 0.7em;
      flex-wrap: wrap;
    }
    .filing__sep { color: var(--hair); }

    /* Plate: motif + words */
    .plate {
      display: grid;
      grid-template-columns: minmax(140px, 200px) 1fr;
      gap: clamp(2rem, 6vw, 5rem);
      align-items: center;
      min-height: 56vh;
    }

    .specimen { margin: 0; align-self: stretch; display: flex; align-items: center; justify-content: center; padding-top: 1.5rem; }
    .sprig { width: 100%; max-width: 168px; height: auto; overflow: visible; }

    .stroke {
      stroke: var(--ink);
      stroke-width: 1.1;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      vector-effect: non-scaling-stroke;
    }
    .stem { stroke-width: 1.3; }
    .leaf { fill: rgba(109,122,94,0.08); }
    .petal { fill: rgba(109,122,94,0.10); stroke: var(--accent); }
    .pollen { fill: var(--accent); stroke: var(--accent); }

    /* Slow, single ambient gesture: the specimen draws itself, then breathes */
    .stroke {
      stroke-dasharray: 1100;
      stroke-dashoffset: 1100;
      animation: ink 3.4s ease-out forwards;
    }
    .leaf, .petal, .pollen { opacity: 0; animation: ink 3.4s ease-out forwards, fade 1.6s ease-out forwards; }
    .leaf.l1 { animation-delay: 0.9s, 1.4s; }
    .leaf.l2 { animation-delay: 1.2s, 1.7s; }
    .leaf.l3 { animation-delay: 1.5s, 2.0s; }
    .leaf.l4 { animation-delay: 1.8s, 2.3s; }
    .bloom .petal { animation-delay: 2.3s, 2.7s; }
    .pollen { animation-delay: 2.7s, 3.1s; }
    .stem { animation-delay: 0s; }

    .stem-group {
      transform-origin: 100px 450px;
      animation: sway 14s ease-in-out 3.6s infinite;
    }

    @keyframes ink { to { stroke-dashoffset: 0; } }
    @keyframes fade { to { opacity: 1; } }
    @keyframes sway {
      0%, 100% { transform: rotate(0deg); }
      50% { transform: rotate(0.8deg); }
    }

    /* Words */
    .text { padding: 0.5rem 0; }
    .eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 1.4rem;
      font-family: var(--serif-body);
    }
    .name {
      font-family: var(--serif);
      font-weight: 500;
      font-size: clamp(3rem, 9vw, 5.4rem);
      line-height: 0.98;
      letter-spacing: -0.01em;
      margin: 0 0 1.3rem;
    }
    .hero {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      line-height: 1.4;
      color: var(--ink);
      margin: 0 0 1.1rem;
      max-width: 34ch;
    }
    .about {
      font-size: clamp(1rem, 2.4vw, 1.18rem);
      color: var(--ink-soft);
      margin: 0;
    }
    .about em { font-style: italic; }

    /* Register / works */
    .register { margin-top: clamp(4rem, 11vw, 8rem); }
    .register__title {
      font-family: var(--serif-body);
      font-weight: 400;
      font-size: 0.72rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--ink-soft);
      margin: 1rem 0 1.8rem;
    }
    .works { list-style: none; margin: 0; padding: 0; }
    .work { border-bottom: 1px solid var(--hair); }
    .work:first-child { border-top: 1px solid var(--hair); }
    .work__link {
      display: grid;
      grid-template-columns: 1fr auto auto;
      align-items: baseline;
      gap: 1.5rem;
      padding: 1.15rem 0;
      text-decoration: none;
      color: var(--ink);
      transition: padding-left 0.6s cubic-bezier(0.22,0.61,0.36,1), color 0.4s ease;
    }
    .work__link:hover, .work__link:focus-visible {
      padding-left: 0.9rem;
      color: var(--accent);
      outline: none;
    }
    .work__name {
      font-family: var(--serif);
      font-size: clamp(1.4rem, 3.6vw, 2rem);
      font-weight: 500;
      line-height: 1;
    }
    .work__role {
      font-size: 0.82rem;
      letter-spacing: 0.04em;
      color: var(--ink-soft);
      text-align: right;
    }
    .work__period {
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--hair);
      min-width: 6.5em;
      text-align: right;
    }

    /* Colophon */
    .colophon { margin-top: clamp(4rem, 11vw, 8rem); }
    .nav {
      display: flex;
      flex-wrap: wrap;
      gap: 1.6rem 2.4rem;
      margin: 1.6rem 0 1.4rem;
    }
    .nav a {
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-soft);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition: color 0.4s ease, border-color 0.4s ease;
    }
    .nav a:hover, .nav a:focus-visible {
      color: var(--accent);
      border-color: var(--accent);
      outline: none;
    }
    .mark {
      font-style: italic;
      font-size: 0.9rem;
      color: var(--ink-soft);
      margin: 0;
    }

    /* Responsive — 390 */
    @media (max-width: 640px) {
      .plate {
        grid-template-columns: 1fr;
        gap: 2.5rem;
        min-height: auto;
      }
      .specimen { order: -1; }
      .sprig { max-width: 110px; }
      .hero__br { display: none; }
      .work__link {
        grid-template-columns: 1fr auto;
        gap: 0.3rem 1rem;
      }
      .work__period {
        grid-column: 1 / -1;
        text-align: left;
        min-width: 0;
        margin-top: 0.1rem;
      }
      .work__role { text-align: right; }
    }

    /* Serene static fallback */
    @media (prefers-reduced-motion: reduce) {
      .stroke {
        stroke-dasharray: none;
        stroke-dashoffset: 0;
        animation: none;
      }
      .leaf, .petal, .pollen { opacity: 1; animation: none; }
      .stem-group { animation: none; }
      .work__link { transition: color 0.2s ease; }
    }
  </style>
</GalleryShell>

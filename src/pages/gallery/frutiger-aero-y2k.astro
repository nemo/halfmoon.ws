---
import GalleryShell from '../../layouts/GalleryShell.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

const nav = [
  { label: 'Find Me', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Principles', href: '/principles' },
];

// Pearmill has no heroImage in frontmatter; fall back to the known asset.
const imgFor = (p: (typeof projects)[number]) =>
  p.data.heroImage ?? '/media/pearmill/pearmill.png';
---

<GalleryShell title="Nima Gardideh" trend="Frutiger Aero / Y2K Revival">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Titillium+Web:ital,wght@0,300;0,400;0,600;0,700;0,900;1,400&family=Exo+2:wght@500;700;800;900&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <!-- Sky + nature backdrop -->
  <div class="sky" aria-hidden="true">
    <div class="sun"></div>
    <div class="bokeh b1"></div>
    <div class="bokeh b2"></div>
    <div class="bokeh b3"></div>
    <div class="bokeh b4"></div>
    <div class="grass"></div>
    <div class="bubbles">
      <span style="--x:6%;--s:14px;--d:17s;--delay:-2s"></span>
      <span style="--x:18%;--s:26px;--d:23s;--delay:-9s"></span>
      <span style="--x:31%;--s:9px;--d:14s;--delay:-5s"></span>
      <span style="--x:44%;--s:34px;--d:27s;--delay:-13s"></span>
      <span style="--x:58%;--s:12px;--d:19s;--delay:-1s"></span>
      <span style="--x:69%;--s:20px;--d:21s;--delay:-7s"></span>
      <span style="--x:80%;--s:30px;--d:25s;--delay:-11s"></span>
      <span style="--x:91%;--s:16px;--d:16s;--delay:-4s"></span>
      <span style="--x:50%;--s:8px;--d:13s;--delay:-3s"></span>
      <span style="--x:25%;--s:18px;--d:20s;--delay:-15s"></span>
    </div>
  </div>

  <div class="desktop">
    <!-- OS top bar -->
    <header class="taskbar" data-load>
      <a class="wordmark" href="/">
        <span class="orb"></span>
        <span class="chrome-text">NIMA GARDIDEH</span>
      </a>
      <nav class="nav" aria-label="Primary">
        {nav.map((n) => (
          <a class="gel" href={n.href}>{n.label}</a>
        ))}
      </nav>
      <span class="clock" aria-hidden="true">
        <span class="dot"></span>online
      </span>
    </header>

    <!-- Hero glass window -->
    <section class="window hero" data-load style="--delay:.08s">
      <div class="titlebar">
        <span class="lights"><i></i><i></i><i></i></span>
        <span class="title">welcome.app</span>
        <span class="badge">v.2026</span>
      </div>
      <div class="window-body hero-body">
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Personal Build · Brooklyn, NY</p>
            <h1>
              a founder, artist, engineer,<br />
              and musician based in <em>Brooklyn.</em>
            </h1>
            <p class="hero-sub">
              Building beautiful, optimistic software at the intersection of
              art and technology — glossy, alive, and a little nostalgic.
            </p>
            <div class="hero-cta">
              <a class="gel solid" href="/projects">Open Projects</a>
              <a class="gel ghost" href="/about">Find Me</a>
            </div>
          </div>
          <div class="hero-orb" aria-hidden="true">
            <span class="orb-ring r1"></span>
            <span class="orb-ring r2"></span>
            <span class="orb-core"></span>
            <span class="orb-spec"></span>
            <span class="orb-bubble bb1"></span>
            <span class="orb-bubble bb2"></span>
            <span class="orb-bubble bb3"></span>
          </div>
        </div>
        <div class="sheen" aria-hidden="true"></div>
      </div>
    </section>

    <!-- Projects: glossy widget panels -->
    <section class="window panels" data-load style="--delay:.16s">
      <div class="titlebar">
        <span class="lights"><i></i><i></i><i></i></span>
        <span class="title">projects.dir</span>
        <span class="badge">{projects.length} items</span>
      </div>
      <div class="window-body grid">
        {projects.map((p, i) => (
          <a
            class="widget"
            href={p.data.link ?? `/projects/${p.slug}`}
            style={`--brand:${p.data.brandColor};--i:${i}`}
            target={p.data.link ? '_blank' : undefined}
            rel={p.data.link ? 'noopener' : undefined}
          >
            <div class="widget-head">
              <span class="widget-icon"><img src={imgFor(p)} alt="" loading="lazy" /></span>
              <span class="widget-meta">
                <strong>{p.data.name}</strong>
                <small>{p.data.role}</small>
              </span>
              <span class="period">{p.data.period}</span>
            </div>
            <p class="widget-sum">{p.data.summary}</p>
            <span class="widget-foot">
              <span class="launch">launch <i>›</i></span>
            </span>
            <span class="gloss" aria-hidden="true"></span>
          </a>
        ))}
      </div>
    </section>

    <!-- About widget -->
    <section class="window about" data-load style="--delay:.24s">
      <div class="titlebar">
        <span class="lights"><i></i><i></i><i></i></span>
        <span class="title">about_me.txt</span>
        <span class="badge">read</span>
      </div>
      <div class="window-body about-body">
        <h2>readme</h2>
        <p>
          I spend most of my time at <b>Pearmill</b>, where we help companies grow
          through art and technology — the only place I've felt like an artist,
          entrepreneur, and engineer at once. Beyond that I write poetry, blog,
          and dance.
        </p>
      </div>
    </section>

    <!-- Footer dock -->
    <footer class="dock" data-load style="--delay:.3s">
      <span class="dock-mark">© NIMA GARDIDEH</span>
      <a class="gel dock-x" href="https://x.com/ngardideh" target="_blank" rel="noopener">
        <span class="x-glyph">𝕏</span> @ngardideh
      </a>
    </footer>
  </div>

  <style>
    /* ---------- tokens ---------- */
    :global(:root) {
      --aqua: #2ea8ff;
      --aqua-bright: #00c2ff;
      --green: #5fd35f;
      --pink: #ff45b5;
      --chrome-a: #c8d2dc;
      --chrome-b: #ffffff;
      --ink: #0b2a44;
      --ink-soft: #2a5a82;
    }

    :global(*) { box-sizing: border-box; }
    :global(html) { scroll-behavior: smooth; }
    :global(body) {
      margin: 0;
      font-family: 'Titillium Web', system-ui, sans-serif;
      color: var(--ink);
      background: #aee6ff;
      min-height: 100vh;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ---------- backdrop ---------- */
    .sky {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(120% 80% at 70% -10%, #eafaff 0%, #9fe0ff 28%, #3aa8ff 62%, #0d6fd6 100%);
      overflow: hidden;
    }
    .sun {
      position: absolute;
      top: -14vmax; left: 55%;
      width: 46vmax; height: 46vmax;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,.95), rgba(255,255,255,0) 60%);
      filter: blur(6px);
      animation: pulse 9s ease-in-out infinite;
    }
    .grass {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      height: 16vh;
      background:
        radial-gradient(140% 140% at 50% 160%, #2f9b3e 0%, #57cf57 38%, rgba(120,215,120,.35) 62%, rgba(120,215,120,0) 78%);
      filter: blur(3px);
      opacity: .8;
    }
    .bokeh {
      position: absolute;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, rgba(255,255,255,.9), rgba(255,255,255,.05) 70%);
      mix-blend-mode: screen;
      filter: blur(1px);
      animation: drift 24s ease-in-out infinite;
    }
    .b1 { width: 220px; height: 220px; top: 12%; left: 8%; opacity:.5; }
    .b2 { width: 120px; height: 120px; top: 40%; left: 78%; opacity:.45; animation-duration: 30s; }
    .b3 { width: 320px; height: 320px; top: 60%; left: 20%; opacity:.3; animation-duration: 36s; }
    .b4 { width: 90px;  height: 90px;  top: 24%; left: 52%; opacity:.55; animation-duration: 21s; }
    .b3 {
      background: radial-gradient(circle at 35% 35%, rgba(255,180,228,.7), rgba(255,69,181,.04) 70%);
    }

    .bubbles { position: absolute; inset: 0; }
    .bubbles span {
      position: absolute;
      bottom: -8%;
      left: var(--x);
      width: var(--s); height: var(--s);
      border-radius: 50%;
      background:
        radial-gradient(circle at 30% 28%, rgba(255,255,255,.95), rgba(255,255,255,.15) 38%, rgba(120,200,255,.25) 70%, rgba(120,200,255,0) 72%);
      box-shadow: inset 0 0 6px rgba(255,255,255,.7), 0 0 8px rgba(120,200,255,.35);
      animation: rise var(--d) linear infinite;
      animation-delay: var(--delay);
    }

    /* ---------- desktop layout ---------- */
    .desktop {
      position: relative;
      z-index: 1;
      max-width: 1080px;
      margin: 0 auto;
      padding: 22px 22px 64px;
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    /* ---------- aqua glass surface (shared) ---------- */
    .window, .taskbar, .dock, .gel {
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.65) 0%, rgba(255,255,255,.18) 46%, rgba(120,180,235,.22) 100%);
      border: 1px solid rgba(255,255,255,.75);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.95),
        inset 0 -16px 28px rgba(40,120,200,.18),
        0 18px 40px rgba(10,70,140,.28);
      -webkit-backdrop-filter: blur(12px) saturate(150%);
      backdrop-filter: blur(12px) saturate(150%);
    }

    /* ---------- taskbar ---------- */
    .taskbar {
      border-radius: 999px;
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 9px 9px 9px 18px;
      position: sticky;
      top: 14px;
      z-index: 5;
    }
    .wordmark {
      display: inline-flex;
      align-items: center;
      gap: 11px;
      text-decoration: none;
      flex-shrink: 0;
    }
    .orb {
      width: 22px; height: 22px; border-radius: 50%;
      background:
        radial-gradient(circle at 32% 28%, #fff, #bfe9ff 30%, var(--aqua) 60%, #0d6fd6 100%);
      box-shadow: inset 0 1px 2px rgba(255,255,255,.9), 0 0 10px rgba(0,194,255,.7);
    }
    .chrome-text {
      font-family: 'Exo 2', sans-serif;
      font-weight: 900;
      letter-spacing: .06em;
      font-size: 16px;
      background: linear-gradient(180deg, #ffffff 0%, #cdd9e6 26%, #8499ad 50%, #3f566c 52%, #b9c8d6 76%, #ffffff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-stroke: .5px rgba(60,90,120,.45);
      filter: drop-shadow(0 1px 0 rgba(255,255,255,.9)) drop-shadow(0 2px 4px rgba(8,45,95,.55));
    }
    .nav {
      display: flex;
      gap: 7px;
      margin-left: auto;
      flex-wrap: wrap;
    }
    .clock {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 600;
      color: var(--ink-soft);
      padding-right: 8px;
      flex-shrink: 0;
    }
    .clock .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #c6ffb0, var(--green));
      box-shadow: 0 0 8px var(--green);
      animation: pulse 2.4s ease-in-out infinite;
    }

    /* ---------- gel buttons ---------- */
    .gel {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 9px 16px;
      border-radius: 999px;
      font-family: 'Titillium Web', sans-serif;
      font-weight: 600;
      font-size: 13.5px;
      color: var(--ink);
      text-decoration: none;
      overflow: hidden;
      transition: transform .25s cubic-bezier(.2,.9,.3,1.2), box-shadow .25s;
    }
    .gel::before {
      content: '';
      position: absolute;
      left: 6%; right: 6%; top: 4%;
      height: 42%;
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255,255,255,.95), rgba(255,255,255,0));
      pointer-events: none;
    }
    .gel:hover {
      transform: translateY(-2px) scale(1.03);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.95),
        0 10px 22px rgba(10,70,140,.34),
        0 0 0 1.5px rgba(0,194,255,.45);
    }
    .gel.solid {
      background: linear-gradient(180deg, #7fd0ff 0%, var(--aqua) 50%, #0d77da 100%);
      color: #fff;
      border-color: rgba(255,255,255,.6);
      text-shadow: 0 1px 1px rgba(8,60,120,.5);
    }
    .gel.ghost { color: var(--ink); }

    /* ---------- windows ---------- */
    .window { overflow: hidden; }
    .titlebar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      background: linear-gradient(180deg, rgba(255,255,255,.7), rgba(190,222,250,.45));
      border-bottom: 1px solid rgba(255,255,255,.6);
    }
    .lights { display: inline-flex; gap: 6px; }
    .lights i {
      width: 11px; height: 11px; border-radius: 50%;
      box-shadow: inset 0 1px 1px rgba(255,255,255,.8);
    }
    .lights i:nth-child(1){ background: radial-gradient(circle at 30% 30%, #ffd1d1, #ff5f6d); }
    .lights i:nth-child(2){ background: radial-gradient(circle at 30% 30%, #fff0c2, #ffbd2e); }
    .lights i:nth-child(3){ background: radial-gradient(circle at 30% 30%, #d4ffce, #34c84a); }
    .title {
      font-family: 'Exo 2', sans-serif;
      font-weight: 700;
      font-size: 12.5px;
      letter-spacing: .04em;
      color: var(--ink-soft);
    }
    .badge {
      margin-left: auto;
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 999px;
      color: #0d6fd6;
      background: linear-gradient(180deg, rgba(255,255,255,.9), rgba(180,225,255,.7));
      border: 1px solid rgba(255,255,255,.8);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.9);
    }
    .window-body { padding: 30px; }

    /* ---------- hero ---------- */
    .hero-body { position: relative; padding: 46px 36px 50px; }
    .eyebrow {
      margin: 0 0 14px;
      font-family: 'Exo 2', sans-serif;
      font-weight: 700;
      letter-spacing: .22em;
      text-transform: uppercase;
      font-size: 12px;
      color: var(--aqua);
    }
    h1 {
      margin: 0;
      font-family: 'Titillium Web', sans-serif;
      font-weight: 700;
      font-size: clamp(32px, 6vw, 60px);
      line-height: 1.04;
      letter-spacing: -.015em;
      color: var(--ink);
      text-shadow: 0 1px 0 rgba(255,255,255,.7);
    }
    h1 em {
      font-style: italic;
      background: linear-gradient(120deg, var(--aqua-bright), var(--pink) 90%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 24px;
    }
    .hero-sub {
      margin: 18px 0 0;
      max-width: 44ch;
      font-size: 15.5px;
      line-height: 1.6;
      color: var(--ink-soft);
      font-weight: 400;
    }
    .hero-cta { display: flex; gap: 12px; margin-top: 28px; flex-wrap: wrap; }
    .hero-cta .gel { padding: 13px 24px; font-size: 15px; }

    /* ---------- glossy aqua orb (Frutiger hero motif) ---------- */
    .hero-orb {
      position: relative;
      width: 210px; height: 210px;
      flex-shrink: 0;
      filter: drop-shadow(0 20px 30px rgba(10,70,140,.35));
    }
    .orb-core {
      position: absolute; inset: 22px;
      border-radius: 50%;
      background:
        radial-gradient(circle at 36% 30%, #ffffff 0%, #d6f3ff 12%, #6ec8ff 38%, #1f8eef 66%, #0a5dc0 88%, #074aa0 100%);
      box-shadow:
        inset 0 -18px 36px rgba(6,40,90,.5),
        inset 0 10px 22px rgba(255,255,255,.45),
        0 0 40px rgba(0,194,255,.5);
    }
    .orb-spec {
      position: absolute; left: 32%; top: 18%;
      width: 42%; height: 30%;
      border-radius: 50%;
      background: radial-gradient(circle at 50% 40%, rgba(255,255,255,.95), rgba(255,255,255,0) 70%);
      transform: rotate(-18deg);
    }
    .orb-ring {
      position: absolute; inset: 0;
      border-radius: 50%;
      border: 1.5px solid rgba(255,255,255,.5);
      animation: spin 18s linear infinite;
    }
    .orb-ring.r1 {
      inset: 4px;
      border-color: rgba(255,255,255,.55);
      box-shadow: 0 0 18px rgba(0,194,255,.4);
    }
    .orb-ring.r2 {
      inset: -8px;
      border-style: dashed;
      border-color: rgba(255,255,255,.4);
      animation-duration: 30s;
      animation-direction: reverse;
    }
    .orb-bubble {
      position: absolute;
      border-radius: 50%;
      background:
        radial-gradient(circle at 30% 28%, rgba(255,255,255,.98), rgba(255,255,255,.2) 40%, rgba(120,200,255,.3) 72%, rgba(120,200,255,0) 74%);
      box-shadow: inset 0 0 4px rgba(255,255,255,.8);
      animation: orbit 9s ease-in-out infinite;
    }
    .orb-bubble.bb1 { width: 22px; height: 22px; top: 6%; left: 60%; animation-delay: -1s; }
    .orb-bubble.bb2 { width: 14px; height: 14px; top: 72%; left: 18%; animation-duration: 11s; animation-delay: -4s; }
    .orb-bubble.bb3 { width: 30px; height: 30px; top: 40%; left: 88%; animation-duration: 13s; animation-delay: -7s; }
    .sheen {
      position: absolute;
      top: 0; left: -60%;
      width: 45%; height: 100%;
      background: linear-gradient(105deg, transparent, rgba(255,255,255,.55), transparent);
      transform: skewX(-18deg);
      pointer-events: none;
    }
    .hero:hover .sheen { animation: sweep 1.1s ease; }

    /* ---------- projects grid ---------- */
    .grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }
    .widget {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 18px;
      border-radius: 16px;
      text-decoration: none;
      color: var(--ink);
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(255,255,255,.78), rgba(255,255,255,.32) 50%, color-mix(in srgb, var(--brand) 16%, rgba(255,255,255,.3)) 100%);
      border: 1px solid rgba(255,255,255,.8);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.95),
        0 10px 22px rgba(10,70,140,.18);
      transition: transform .3s cubic-bezier(.2,.9,.3,1.2), box-shadow .3s;
    }
    .widget:hover {
      transform: translateY(-4px) rotate(-.4deg);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.95),
        0 22px 40px rgba(10,70,140,.3),
        0 0 0 2px color-mix(in srgb, var(--brand) 60%, white);
    }
    .widget-head { display: flex; align-items: center; gap: 12px; }
    .widget-icon {
      width: 52px; height: 52px;
      border-radius: 14px;
      flex-shrink: 0;
      display: grid;
      place-items: center;
      overflow: hidden;
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--brand) 35%, white), color-mix(in srgb, var(--brand) 85%, black 4%));
      border: 1px solid rgba(255,255,255,.85);
      box-shadow:
        inset 0 2px 3px rgba(255,255,255,.9),
        inset 0 -6px 10px rgba(0,0,0,.18),
        0 4px 10px color-mix(in srgb, var(--brand) 45%, transparent);
    }
    .widget-icon img { width: 78%; height: 78%; object-fit: contain; }
    .widget-meta { display: flex; flex-direction: column; line-height: 1.15; }
    .widget-meta strong {
      font-family: 'Exo 2', sans-serif;
      font-weight: 800;
      font-size: 18px;
      letter-spacing: .01em;
    }
    .widget-meta small { font-size: 12px; color: var(--ink-soft); font-weight: 600; }
    .period {
      margin-left: auto;
      align-self: flex-start;
      font-size: 11px;
      font-weight: 700;
      color: color-mix(in srgb, var(--brand) 70%, var(--ink));
      background: rgba(255,255,255,.7);
      padding: 3px 9px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.8);
      white-space: nowrap;
    }
    .widget-sum {
      margin: 0;
      font-size: 13.5px;
      line-height: 1.5;
      color: var(--ink-soft);
    }
    .widget-foot { margin-top: auto; }
    .launch {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-family: 'Exo 2', sans-serif;
      font-weight: 800;
      font-size: 12.5px;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: color-mix(in srgb, var(--brand) 78%, #0d6fd6);
    }
    .launch i { font-style: normal; transition: transform .25s; }
    .widget:hover .launch i { transform: translateX(4px); }
    .gloss {
      position: absolute;
      top: 0; left: -70%;
      width: 50%; height: 100%;
      background: linear-gradient(105deg, transparent, rgba(255,255,255,.5), transparent);
      transform: skewX(-18deg);
      pointer-events: none;
    }
    .widget:hover .gloss { animation: sweep 1s ease; }

    /* ---------- about ---------- */
    .about-body h2 {
      margin: 0 0 12px;
      font-family: 'Exo 2', sans-serif;
      font-weight: 900;
      font-size: 14px;
      letter-spacing: .24em;
      text-transform: uppercase;
      color: var(--aqua);
    }
    .about-body p {
      margin: 0;
      font-size: clamp(16px, 2.2vw, 20px);
      line-height: 1.6;
      color: var(--ink);
      max-width: 62ch;
    }
    .about-body b {
      background: linear-gradient(120deg, var(--aqua-bright), var(--pink));

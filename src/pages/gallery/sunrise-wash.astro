---
import GalleryShell from '../../layouts/GalleryShell.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

const links = [
  { label: 'Find Me', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Principles', href: '/principles' },
];
---

<GalleryShell title="Nima Gardideh" trend="Sunrise Wash">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&family=Inter:wght@300;400&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <main class="page">
    <!-- The wash: a slow ambient gradient sky from pre-dawn to soft daylight -->
    <div class="sky" aria-hidden="true">
      <div class="wash"></div>
      <!-- a single thin horizon line -->
      <svg class="horizon" viewBox="0 0 1000 2" preserveAspectRatio="none">
        <line x1="0" y1="1" x2="1000" y2="1" />
      </svg>
    </div>

    <div class="frame">
      <header class="masthead">
        <span class="wordmark">Nima&nbsp;Gardideh</span>
        <span class="domain">halfmoon.ws</span>
      </header>

      <section class="hero">
        <h1>
          a founder, artist, engineer,<br />
          and musician based in Brooklyn.
        </h1>
        <p class="about">I write poetry, build companies, and dance.</p>
      </section>

      <section class="work" aria-label="Selected work">
        <ul class="projects">
          {
            projects.map((p) => (
              <li>
                <a href={`/projects/${p.slug}`}>
                  <span class="name">{p.data.name}</span>
                  <span class="role">{p.data.role}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <footer class="foot">
        <nav class="nav" aria-label="Sections">
          {
            links.map((l) => (
              <a href={l.href}>{l.label}</a>
            ))
          }
        </nav>
        <a class="social" href="https://x.com/ngardideh" rel="me">@ngardideh</a>
      </footer>
    </div>
  </main>
</GalleryShell>

<style>
  :global(html) {
    height: 100%;
  }
  :global(body) {
    margin: 0;
    min-height: 100%;
    /* a calm paper base; the wash sits in front and slowly warms */
    background: #f5f2ee;
    color: #2b2622;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 300;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .page {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ---- the single motif: a slow sunrise wash ---- */
  .sky {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  .wash {
    position: absolute;
    inset: 0;
    /* pre-dawn -> soft daylight, vertical: warm low band, paper above */
    background: linear-gradient(
      to top,
      #f7e6d2 0%,
      #f2dcd4 18%,
      #efe2dc 36%,
      #f2ece7 60%,
      #f5f2ee 100%
    );
    animation: dawn 60s ease-in-out infinite alternate;
  }

  /* the warmth gently swells and recedes — like light over a long minute.
     light only changes; nothing moves, so the wash always fills the frame */
  @keyframes dawn {
    0% {
      filter: saturate(0.8) brightness(0.97) hue-rotate(-3deg);
    }
    100% {
      filter: saturate(1.08) brightness(1.02) hue-rotate(0deg);
    }
  }

  .horizon {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 8%;
    width: 100%;
    height: 1px;
    overflow: visible;
  }
  .horizon line {
    stroke: #c2ae93;
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
    opacity: 0;
    animation: horizon-in 6s cubic-bezier(0.22, 0.61, 0.36, 1) 0.8s forwards;
  }
  @keyframes horizon-in {
    to {
      opacity: 0.55;
    }
  }

  /* ---- content sits quietly above the wash ---- */
  .frame {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 64rem;
    margin: 0 auto;
    padding: 3rem 2.5rem 2.75rem;
    box-sizing: border-box;
  }

  .masthead {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6f6457;
  }
  .wordmark {
    color: #4a4036;
  }
  .domain {
    opacity: 0.7;
  }

  .hero {
    margin: auto 0;
    padding: 4rem 0;
  }
  .hero h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 300;
    font-optical-sizing: auto;
    font-size: clamp(1.9rem, 5.2vw, 3.4rem);
    line-height: 1.28;
    letter-spacing: -0.01em;
    color: #332c25;
    margin: 0;
    max-width: 22ch;
  }
  .about {
    margin: 1.6rem 0 0;
    font-style: italic;
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1rem, 2.2vw, 1.18rem);
    color: #6a5f52;
    letter-spacing: 0.005em;
  }

  .work {
    margin-top: 1rem;
  }
  .projects {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 30rem;
  }
  .projects li {
    border-top: 1px solid rgba(120, 104, 84, 0.18);
  }
  .projects li:last-child {
    border-bottom: 1px solid rgba(120, 104, 84, 0.18);
  }
  .projects a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.85rem 0.1rem;
    text-decoration: none;
    color: #463d33;
    transition: color 0.5s ease, padding-left 0.5s ease;
  }
  .projects a:hover {
    color: #1f1a15;
    padding-left: 0.4rem;
  }
  .projects .name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.05rem;
  }
  .projects .role {
    font-size: 0.74rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #87796a;
    text-align: right;
  }

  .foot {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-top: 3.25rem;
    padding-top: 1.25rem;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .foot a {
    color: #6f6457;
    text-decoration: none;
    transition: color 0.4s ease;
  }
  .foot a:hover {
    color: #2b2620;
  }
  .social {
    color: #87796a;
  }

  @media (max-width: 540px) {
    .frame {
      padding: 2rem 1.5rem 2.25rem;
    }
    .hero {
      padding: 2.5rem 0;
    }
    .horizon {
      bottom: 24%;
    }
    .foot {
      gap: 1.25rem 1rem;
    }
  }

  /* serene static fallback — light settles, nothing moves */
  @media (prefers-reduced-motion: reduce) {
    .wash {
      animation: none;
      filter: saturate(0.98) brightness(1);
      transform: none;
    }
    .horizon line {
      animation: none;
      opacity: 0.5;
    }
    .projects a {
      transition: none;
    }
  }
</style>

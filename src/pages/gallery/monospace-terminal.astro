---
import GalleryShell from '../../layouts/GalleryShell.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Pearmill has no heroImage in frontmatter — fall back to its known asset.
const imageFor = (slug: string, hero?: string) =>
  hero ?? (slug === 'pearmill' ? '/media/pearmill/pearmill.png' : undefined);

const nav = [
  { label: 'Find Me', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'Principles', href: '/principles' },
];

const now = new Date();
const tz = '— Brooklyn, NY';
const idx = (n: number) => String(n + 1).padStart(2, '0');
---

<GalleryShell title="Nima Gardideh" trend="Monospace / Design-Engineer Minimal">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="scanline" aria-hidden="true"></div>
  <div class="vignette" aria-hidden="true"></div>

  <main class="shell">
    <!-- titlebar -->
    <header class="bar reveal" style="--d:0">
      <div class="bar-l">
        <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
        <span class="path">~/nima-gardideh <span class="dim">— zsh</span></span>
      </div>
      <div class="bar-r dim">
        <span class="blink">●</span> online &nbsp;{tz}
      </div>
    </header>

    <div class="frame">
      <!-- wordmark + nav -->
      <section class="top reveal" style="--d:1">
        <a class="wordmark" href="/">
          <span class="prompt">&gt;</span> NIMA GARDIDEH
        </a>
        <nav class="nav" aria-label="Primary">
          {
            nav.map((n) => (
              <a class="navlink" href={n.href}>
                {n.label}
              </a>
            ))
          }
        </nav>
      </section>

      <hr class="rule reveal" style="--d:2" />

      <!-- hero -->
      <section class="hero reveal" style="--d:3">
        <p class="kicker">// whoami</p>
        <h1>
          <span class="caret">$</span> a founder, artist, engineer, and
          musician <span class="loc">based in Brooklyn.</span><span class="cursor" aria-hidden="true"></span>
        </h1>
      </section>

      <hr class="rule reveal" style="--d:4" />

      <!-- about / now -->
      <section class="about reveal" style="--d:5">
        <p class="kicker">// cat about.md</p>
        <p class="body">
          I spend most of my time at <span class="hl">Pearmill</span>, where we
          help companies grow through art and technology — the only place I've
          felt like an artist, entrepreneur, and engineer at once. Beyond that I
          write poetry, blog, and dance.
        </p>
      </section>

      <hr class="rule reveal" style="--d:6" />

      <!-- projects -->
      <section class="projects reveal" style="--d:7">
        <header class="sec-head">
          <p class="kicker">// ls -la ~/projects</p>
          <span class="count dim">{projects.length} entries</span>
        </header>

        <ol class="list">
          {
            projects.map((p, i) => {
              const img = imageFor(p.slug, p.data.heroImage);
              const fit = p.data.imageFit ?? 'cover';
              return (
                <li class="item" style={`--brand:${p.data.brandColor}`}>
                  <a class="row" href={p.data.link ?? '#'} target="_blank" rel="noopener">
                    <span class="num dim">{idx(i)}</span>
                    <span class="thumb" data-fit={fit}>
                      {img ? (
                        <img src={img} alt={p.data.name} loading="lazy" />
                      ) : (
                        <span class="thumb-fallback" />
                      )}
                    </span>
                    <span class="meta">
                      <span class="name-line">
                        <span class="name">{p.data.name}</span>
                        <span class="role dim">{p.data.role}</span>
                      </span>
                      <span class="summary">{p.data.summary}</span>
                    </span>
                    <span class="period dim">{p.data.period}</span>
                    <span class="arrow" aria-hidden="true">↗</span>
                  </a>
                </li>
              );
            })
          }
        </ol>
      </section>

      <hr class="rule reveal" style="--d:8" />

      <!-- footer -->
      <footer class="foot reveal" style="--d:9">
        <span class="dim">
          <span class="caret">$</span> echo $CONTACT
        </span>
        <a class="social" href="https://x.com/ngardideh" target="_blank" rel="noopener">
          @ngardideh <span class="arrow">↗</span>
        </a>
      </footer>

      <p class="sig dim reveal" style="--d:10">
        Built in Brooklyn · No frameworks harmed · {now.getFullYear()}
      </p>
    </div>
  </main>
</GalleryShell>

<style>
  :global(html) {
    background: #0d0d0d;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  :global(body) {
    margin: 0;
    background: #0d0d0d;
    color: #c9c9c9;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 14px;
    line-height: 1.65;
    min-height: 100vh;
    overflow-x: hidden;
    --bg: #0d0d0d;
    --ink: #c9c9c9;
    --dim: #6e6e6e;
    --line: #1f1f1f;
    --line-2: #161616;
    --accent: #7dd3fc;
    --accent-dim: #345766;
    --inter: 'Inter', system-ui, sans-serif;
  }
  :global(*) {
    box-sizing: border-box;
  }
  :global(::selection) {
    background: var(--accent);
    color: #0d0d0d;
  }

  /* atmosphere */
  .vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(120% 90% at 50% -10%, rgba(125, 211, 252, 0.05), transparent 55%),
      radial-gradient(100% 100% at 50% 120%, rgba(0, 0, 0, 0.7), transparent 60%);
  }
  .scanline {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.4;
    background: repeating-linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.012) 0px,
      rgba(255, 255, 255, 0.012) 1px,
      transparent 1px,
      transparent 3px
    );
  }

  .shell {
    position: relative;
    z-index: 2;
    max-width: 720px;
    margin: 0 auto;
    padding: 28px 24px 96px;
  }

  /* titlebar */
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 11.5px;
    letter-spacing: 0.02em;
    padding-bottom: 14px;
  }
  .bar-l {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .dots {
    display: inline-flex;
    gap: 6px;
  }
  .dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--line);
    border: 1px solid #262626;
  }
  .dots i:nth-child(1) {
    background: #2b2b2b;
  }
  .path {
    color: var(--ink);
  }
  .dim {
    color: var(--dim);
  }
  .blink {
    color: var(--accent);
    animation: blink 1.6s steps(1) infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0.25;
    }
  }

  .frame {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: linear-gradient(180deg, #0f0f0f, #0c0c0c);
    padding: 30px 30px 26px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.03) inset,
      0 40px 80px -40px rgba(0, 0, 0, 0.9);
  }

  /* top */
  .top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 14px;
  }
  .wordmark {
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.14em;
    color: var(--ink);
    text-decoration: none;
  }
  .prompt,
  .caret {
    color: var(--accent);
  }
  .nav {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .navlink {
    color: var(--dim);
    text-decoration: none;
    font-size: 12.5px;
    padding: 4px 8px;
    border-radius: 5px;
    border: 1px solid transparent;
    transition:
      color 0.14s ease,
      border-color 0.14s ease,
      background 0.14s ease;
  }
  .navlink:hover {
    color: var(--accent);
    border-color: var(--accent-dim);
    background: rgba(125, 211, 252, 0.06);
  }
  .navlink:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    color: var(--accent);
  }

  .rule {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 24px 0;
  }

  .kicker {
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.04em;
    margin: 0 0 14px;
    opacity: 0.85;
  }

  /* hero */
  .hero h1 {
    font-family: var(--inter);
    font-weight: 500;
    font-size: clamp(22px, 4.4vw, 31px);
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: #ededed;
    margin: 0;
    max-width: 34ch;
  }
  .hero .caret {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 0.78em;
    margin-right: 8px;
    vertical-align: 0.06em;
  }
  .hero .loc {
    color: var(--dim);
  }
  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 1.05em;
    margin-left: 0.18em;
    transform: translateY(0.14em);
    background: var(--accent);
    box-shadow: 0 0 8px rgba(125, 211, 252, 0.55);
    animation: caret 1.1s steps(1) infinite;
  }
  @keyframes caret {
    50% {
      opacity: 0;
    }
  }

  /* about */
  .body {
    font-family: var(--inter);
    font-size: 15px;
    line-height: 1.7;
    color: #b7b7b7;
    margin: 0;
    max-width: 60ch;
  }
  .hl {
    color: var(--accent);
    border-bottom: 1px solid var(--accent-dim);
  }

  /* projects */
  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .sec-head .kicker {
    margin-bottom: 18px;
  }
  .count {
    font-size: 11px;
  }
  .list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .item {
    border-top: 1px solid var(--line-2);
  }
  .item:last-child {
    border-bottom: 1px solid var(--line-2);
  }
  .row {
    display: grid;
    grid-template-columns: 22px 56px 1fr auto 16px;
    align-items: center;
    gap: 16px;
    padding: 16px 6px 16px 10px;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: background 0.16s ease;
  }
  .row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--brand);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.2s ease;
  }
  .row:hover {
    background: rgba(255, 255, 255, 0.022);
  }
  .row:hover::before {
    transform: scaleY(1);
  }
  .row:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }
  .num {
    font-size: 11px;
    font-variant-numeric: tabular-nums;
  }
  .thumb {
    width: 56px;
    height: 42px;
    border-radius: 5px;
    overflow: hidden;
    background: #131313;
    border: 1px solid var(--line);
    display: grid;
    place-items: center;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05) brightness(0.92);
    transition:
      filter 0.25s ease,
      transform 0.3s ease;
  }
  .thumb[data-fit='contain'] img {
    object-fit: contain;
    padding: 6px;
  }
  .row:hover .thumb img {
    filter: grayscale(0) contrast(1) brightness(1);
    transform: scale(1.04);
  }
  .thumb-fallback {
    width: 100%;
    height: 100%;
    background: var(--brand);
  }
  .meta {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .name-line {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .name {
    font-weight: 500;
    font-size: 14px;
    color: #ededed;
    letter-spacing: 0.01em;
  }
  .row:hover .name {
    color: var(--accent);
  }
  .role {
    font-size: 11px;
    white-space: nowrap;
  }
  .summary {
    font-family: var(--inter);
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--dim);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    max-width: 52ch;
  }
  .row:hover .summary {
    color: #9a9a9a;
  }
  .period {
    font-size: 11px;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    text-align: right;
  }
  .arrow {
    color: var(--dim);
    font-size: 12px;
    opacity: 0;
    transform: translate(-3px, 3px);
    transition:
      opacity 0.16s ease,
      transform 0.16s ease,
      color 0.16s ease;
  }
  .row:hover .arrow {
    opacity: 1;
    transform: translate(0, 0);
    color: var(--accent);
  }

  /* footer */
  .foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12.5px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .social {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color 0.14s ease,
      border-color 0.14s ease;
  }
  .social .arrow {
    opacity: 1;
    transform: none;
    color: inherit;
  }
  .social:hover {
    color: var(--accent);
    border-bottom-color: var(--accent-dim);
  }
  .social:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .sig {
    font-size: 10.5px;
    letter-spacing: 0.03em;
    margin: 22px 0 0;
    text-align: center;
    opacity: 0.7;
  }

  /* load-in */
  .reveal {
    opacity: 0;
    transform: translateY(8px);
    animation: rise 0.55s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    animation-delay: calc(var(--d) * 70ms + 100ms);
  }
  @keyframes rise {
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .blink,
    .cursor {
      animation: none;
    }
  }

  /* responsive */
  @media (max-width: 560px) {
    .shell {
      padding: 18px 14px 70px;
    }
    .frame {
      padding: 22px 16px 20px;
      border-radius: 8px;
    }
    .top {
      flex-direction: column;
      align-items: flex-start;
    }
    .nav {
      margin-left: -8px;
    }
    .row {
      grid-template-columns: 18px 1fr;
      gap: 6px 12px;
      padding: 14px 4px;
    }
    .thumb {
      grid-row: 1 / span 2;
      grid-column: 1;
      width: 18px;
      height: 18px;
      border: 0;
      background: var(--brand);
      border-radius: 3px;
    }
    .thumb img {
      display: none;
    }
    .thumb::after {
      content: '';
    }
    .meta {
      grid-column: 2;
    }
    .period {
      grid-column: 2;
      text-align: left;
    }
    .arrow {
      display: none;
    }
    .summary {
      -webkit-line-clamp: 3;
    }
  }
</style>
</GalleryShell>

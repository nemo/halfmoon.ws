---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Box from '../../components/Box.astro';
import TileRow from '../../components/TileRow.astro';
import Prose from '../../components/Prose.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { name, role, summary, brandColor, link, heroImage, gallery } =
  project.data;

const image =
  heroImage ?? (project.slug === 'pearmill' ? '/media/pearmill/pearmill.png' : undefined);
---

<Base title={name} description={summary} image={image ?? '/og-default.png'}>
  <Box class="project" as="article">
    <header class="project__head">
      <h1 class="project__title">{name}</h1>
      <p class="project__sub">{role}</p>
    </header>

    <div class="project__sub-container">
      <div class="project__media" style={`--brand: ${brandColor};`}>
        {image ? <img src={image} alt={`${name}`} /> : null}
      </div>

      <div class="project__content">
        <Prose accent="var(--accent)">
          <Content />
        </Prose>

        {
          link && (
            <a
              class="project__link"
              href={link}
              target="_blank"
              rel="noopener"
            >
              Learn more
            </a>
          )
        }
      </div>
    </div>

  </Box>

  {
    gallery && gallery.length > 0 && (
      <div class="project-gallery">
        {Array.from({ length: Math.ceil(gallery.length / 2) }).map((_, r) => (
          <TileRow class="project-gallery__row" stackAt="mobile">
            {gallery.slice(r * 2, r * 2 + 2).map((src) => (
              <Box class="project-gallery__cell">
                <img
                  src={src}
                  alt={`${name} photo`}
                  loading="lazy"
                  decoding="async"
                />
              </Box>
            ))}
          </TileRow>
        ))}
      </div>
    )
  }
</Base>

<style>
  .project__head {
    padding-bottom: 15px;
  }

  .project__title {
    font-family: var(--font-display);
    font-size: var(--fs-title);
    font-weight: var(--fw-regular);
    text-transform: uppercase;
    color: var(--box-fg);
  }

  .project__sub {
    font-family: var(--font-display);
    font-size: var(--fs-sub);
    font-weight: var(--fw-regular);
    color: var(--box-muted);
  }

  .project__sub-container {
    display: flex;
    align-items: flex-start;
    max-width: var(--subcontainer-max);
  }

  .project__media {
    flex: 0 0 auto;
    width: 500px;
    max-width: 100%;
    aspect-ratio: 500 / 285.58;
    border-radius: var(--radius);
    background-color: var(--brand);
    overflow: hidden;
  }

  .project__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project__content {
    flex: 1 0 0;
    min-width: 0;
    padding-left: var(--box-pad);
  }

  .project__content :global(.prose) {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-tight);
    color: var(--box-fg);
  }

  .project__link {
    display: inline-block;
    margin-top: var(--box-pad);
    font-family: var(--font-display);
    font-size: var(--fs-list);
    color: var(--accent);
    transition: opacity 0.15s ease;
  }

  .project__link:hover {
    opacity: 0.75;
  }

  /* Gallery photos as their own tiled boxes, 2-up rows. */
  .project-gallery {
    display: flex;
    flex-direction: column;
    gap: var(--gutter);
  }

  .project-gallery__cell {
    display: flex;
  }

  .project-gallery__cell img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: var(--radius);
  }

  /* Mobile: image block on top, content below. */
  @media (max-width: 480px) {
    .project__sub-container {
      flex-direction: column;
      align-items: stretch;
    }

    .project__media {
      width: 100%;
    }

    .project__content {
      padding-left: 0;
      padding-top: var(--box-pad);
    }
  }
</style>

---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TileRow from '../../components/TileRow.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base
  title="Projects"
  description="Companies, products, and performances Nima Gardideh has built."
>
  <TileRow class="projects" stackAt="mobile" aria-label="All projects">
    {
      projects.map((project) => (
        <ProjectCard
          name={project.data.name}
          role={project.data.role}
          summary={project.data.summary}
          brandColor={project.data.brandColor}
          link={project.data.link}
          href={`/projects/${project.slug}`}
          heroImage={
            project.data.heroImage ??
            (project.slug === 'pearmill'
              ? '/media/pearmill/pearmill.png'
              : undefined)
          }
        />
      ))
    }
  </TileRow>
</Base>

<style>
  .projects :global(.box) {
    min-height: 350px;
  }
</style>

---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

// Only public-resolvable hero paths can be used as a plain <img> src.
const thumbSrc = (src?: string) =>
  src && !src.startsWith('/src/') ? src : undefined;
---

<Base
  title="Blog"
  description="Writing by Nima Gardideh on product, engineering, and building."
>
  <header class="page-head">
    <p class="eyebrow">Blog</p>
    <p class="page-head__lead">
      Essays and notes, originally published on Medium.
    </p>
  </header>

  <ul class="posts">
    {
      posts.map((post) => {
        const thumb = thumbSrc(post.data.heroImage);
        return (
          <li class="post">
            <a class="post__link" href={`/blog/${post.slug}`}>
              {thumb && (
                <div class="post__thumb">
                  <img src={thumb} alt="" loading="lazy" decoding="async" />
                </div>
              )}
              <div class="post__text">
                <time class="post__date" datetime={post.data.pubDate.toISOString()}>
                  {dateFmt(post.data.pubDate)}
                </time>
                <h2 class="post__title">{post.data.title}</h2>
                <p class="post__desc">{post.data.description}</p>
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>
</Base>

<style>
  .page-head {
    margin-top: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .page-head__lead {
    margin-top: var(--space-2);
    max-width: var(--prose-max);
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--muted);
  }

  .posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post {
    border-bottom: 1px solid var(--border);
  }

  .post__link {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    padding-block: var(--space-3);
  }

  .post__link:hover {
    opacity: 1;
  }

  .post__link:hover .post__title {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .post__thumb {
    flex: 0 0 200px;
    aspect-ratio: 3 / 2;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--border);
  }

  .post__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post__text {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .post__date {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .post__title {
    font-family: var(--font-sans);
    font-size: var(--fs-display);
    font-weight: var(--fw-regular);
    line-height: var(--lh-tight);
  }

  .post__desc {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--muted);
    max-width: var(--prose-max);
  }

  @media (max-width: 800px) {
    .post__thumb {
      flex-basis: 140px;
    }

    .post__title {
      font-size: var(--fs-body);
    }
  }

  @media (max-width: 480px) {
    .post__link {
      flex-direction: column;
      gap: var(--space-2);
    }

    .post__thumb {
      flex-basis: auto;
      width: 100%;
    }
  }
</style>

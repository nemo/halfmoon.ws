---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Box from '../../components/Box.astro';
import TileRow from '../../components/TileRow.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

// Only public-resolvable hero paths can be used as a plain <img> src.
const thumbSrc = (src?: string) =>
  src && !src.startsWith('/src/') ? src : undefined;

// Chunk posts into rows of 2 so each row tiles to equal height.
const rows: (typeof posts)[] = [];
for (let i = 0; i < posts.length; i += 2) rows.push(posts.slice(i, i + 2));
---

<Base
  title="Blog"
  description="Writing by Nima Gardideh on product, engineering, and building."
>
  <!-- Header box -->
  <Box class="blog-intro">
    <header class="blog-head">
      <h1 class="blog-head__title">BLOG</h1>
      <p class="blog-head__sub">
        Essays and notes, originally published on Medium.
      </p>
    </header>
  </Box>

  <!-- Post boxes, tiled 2-up per row, stacking on mobile. -->
  {
    rows.map((row) => (
      <TileRow class="blog-grid" stackAt="mobile" aria-label="Writing">
        {row.map((post) => {
          const thumb = thumbSrc(post.data.heroImage);
          return (
            <Box class="post" as="article">
              <a class="post__link" href={`/blog/${post.slug}`}>
                <header class="post__head">
                  <time
                    class="post__date"
                    datetime={post.data.pubDate.toISOString()}
                  >
                    {dateFmt(post.data.pubDate)}
                  </time>
                  <h2 class="post__title">{post.data.title}</h2>
                </header>
                <div class="post__sub-container">
                  {thumb && (
                    <div class="post__media">
                      <img
                        src={thumb}
                        alt=""
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="post__content">
                    <p class="post__desc">{post.data.description}</p>
                    <span class="post__cta">Read more</span>
                  </div>
                </div>
              </a>
            </Box>
          );
        })}
      </TileRow>
    ))
  }
</Base>

<style>
  .blog-head__title {
    font-family: var(--font-display);
    font-size: var(--fs-title);
    font-weight: var(--fw-regular);
    text-transform: uppercase;
    color: var(--box-fg);
  }

  .blog-head__sub {
    margin-top: 4px;
    font-family: var(--font-display);
    font-size: var(--fs-sub);
    color: var(--box-muted);
  }

  .post {
    display: flex;
    flex-direction: column;
    min-height: 200px;
  }

  .post__link {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post__head {
    padding-bottom: 15px;
  }

  .post__date {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-sub);
    text-transform: uppercase;
    color: var(--box-muted);
  }

  .post__title {
    margin-top: 4px;
    font-family: var(--font-display);
    font-size: var(--fs-title);
    font-weight: var(--fw-regular);
    text-transform: uppercase;
    color: var(--box-fg);
  }

  .post__link:hover .post__title {
    color: var(--accent);
  }

  .post__sub-container {
    display: flex;
    align-items: flex-start;
    max-width: var(--subcontainer-max);
  }

  .post__media {
    flex: 0 0 auto;
    width: 200px;
    max-width: 45%;
    aspect-ratio: 3 / 2;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .post__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post__content {
    flex: 1 0 0;
    min-width: 0;
    padding-left: var(--box-pad);
  }

  /* No-thumb posts: content takes the full width. */
  .post__sub-container:not(:has(.post__media)) .post__content {
    padding-left: 0;
  }

  .post__desc {
    font-family: var(--font-display);
    font-size: var(--fs-list);
    line-height: var(--lh-tight);
    color: var(--box-fg);
  }

  .post__cta {
    display: inline-block;
    margin-top: var(--box-pad);
    font-family: var(--font-display);
    font-size: var(--fs-list);
    color: var(--accent);
  }

  /* Mobile: thumb on top, content below. */
  @media (max-width: 480px) {
    .post__sub-container {
      flex-direction: column;
      align-items: stretch;
    }

    .post__media {
      width: 100%;
      max-width: 100%;
    }

    .post__content {
      padding-left: 0;
      padding-top: var(--box-pad);
    }
  }
</style>

---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Box from '../../components/Box.astro';
import Prose from '../../components/Prose.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, originalUrl, heroImage } = post.data;

const dateFmt = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Only public-resolvable hero paths render as a plain <img> src.
const hero = heroImage && !heroImage.startsWith('/src/') ? heroImage : undefined;
---

<Base title={title} description={description} image={hero ?? '/og-default.png'}>
  <!-- Header box: date + title, optional hero image block. -->
  <Box class="article-head" as="header">
    <a class="article-head__back" href="/blog">All writing</a>
    <time class="article-head__date" datetime={pubDate.toISOString()}>
      {dateFmt}
    </time>
    <h1 class="article-head__title">{title}</h1>
    {
      hero && (
        <div class="article-head__hero">
          <img src={hero} alt="" />
        </div>
      )
    }
  </Box>

  <!-- Body box: long-form Inter prose. -->
  <Box class="article-body" as="article">
    <Prose>
      <Content />
    </Prose>

    <footer class="article-foot">
      <a href={originalUrl} target="_blank" rel="noopener">
        Originally published on Medium
      </a>
    </footer>
  </Box>
</Base>

<style>
  .article-head__back {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--fs-sub);
    text-transform: uppercase;
    color: var(--box-muted);
    transition: color 0.15s ease;
  }

  .article-head__back:hover {
    color: var(--accent);
  }

  .article-head__date {
    display: block;
    margin-top: 15px;
    font-family: var(--font-display);
    font-size: var(--fs-sub);
    text-transform: uppercase;
    color: var(--box-muted);
  }

  .article-head__title {
    margin-top: 4px;
    font-family: var(--font-display);
    font-size: var(--fs-title);
    font-weight: var(--fw-regular);
    text-transform: uppercase;
    line-height: var(--lh-tight);
    color: var(--box-fg);
    max-width: var(--subcontainer-max);
  }

  .article-head__hero {
    margin-top: 15px;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .article-head__hero img {
    width: 100%;
    object-fit: cover;
  }

  .article-body :global(.prose) {
    max-width: var(--subcontainer-max);
  }

  .article-foot {
    margin-top: 20px;
    font-family: var(--font-display);
    font-size: var(--fs-list);
  }

  .article-foot a {
    color: var(--accent);
    transition: opacity 0.15s ease;
  }

  .article-foot a:hover {
    opacity: 0.75;
  }
</style>

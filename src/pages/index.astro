---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Box from '../components/Box.astro';
import TileRow from '../components/TileRow.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base title="Nima Gardideh">
  <!-- Fold: full-width tall dark box -->
  <Box class="fold">
    <h1 class="fold__headline">
      a founder, artist, engineer, and musician based in Brooklyn.
    </h1>
  </Box>

  <!-- Projects-list: wrapping row of equal flex project boxes, 2-up desktop -->
  <TileRow class="projects" stackAt="mobile" aria-label="Selected projects">
    {
      projects.map((project) => (
        <ProjectCard
          name={project.data.name}
          role={project.data.role}
          summary={project.data.summary}
          brandColor={project.data.brandColor}
          link={project.data.link}
          href={`/projects/${project.slug}`}
          heroImage={
            project.data.heroImage ??
            (project.slug === 'pearmill'
              ? '/media/pearmill/pearmill.png'
              : undefined)
          }
        />
      ))
    }
  </TileRow>
</Base>

<style>
  .fold {
    display: flex;
    /* tall stature — headline sits at the top, big empty space below */
    min-height: 260px;
  }

  .fold__headline {
    font-family: var(--font-display);
    font-size: var(--fs-headline);
    font-weight: var(--fw-light);
    line-height: var(--lh-tight);
    text-transform: uppercase;
    align-self: flex-start;
  }

  /* On the home list the project boxes are tall panes. */
  .projects :global(.box) {
    min-height: 350px;
  }

  /* 2-up on desktop: each project box takes ~half the row (minus the gutter)
     so exactly two tile per row and the rest wrap to the next row. */
  .projects :global(> .box) {
    flex: 1 1 calc(50% - var(--gutter));
  }

  @media (max-width: 480px) {
    .fold {
      min-height: 300px;
    }

    /* 1-up on mobile — each project box spans the full row. */
    .projects :global(> .box) {
      flex: 1 1 100%;
    }
  }
</style>
